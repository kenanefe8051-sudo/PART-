/* ─── Fuzzy matching yardımcı fonksiyonları ─── */

// Türkçe dahil tüm karakterleri normalize et
function kbNorm(s){
  return s.toLowerCase()
    .replace(/ğ/g,'g').replace(/Ğ/g,'g')
    .replace(/ü/g,'u').replace(/Ü/g,'u')
    .replace(/ş/g,'s').replace(/Ş/g,'s')
    .replace(/ı/g,'i').replace(/İ/g,'i')
    .replace(/ö/g,'o').replace(/Ö/g,'o')
    .replace(/ç/g,'c').replace(/Ç/g,'c')
    .replace(/[^a-z0-9 ]/g,'')
    .replace(/\s+/g,' ').trim();
}

// Levenshtein mesafesi — iki string arası düzenleme mesafesi
function levenshtein(a, b){
  const m=a.length, n=b.length;
  const dp=Array.from({length:m+1},(_,i)=>Array.from({length:n+1},(_,j)=>j===0?i:0));
  for(let j=1;j<=n;j++) dp[0][j]=j;
  for(let i=1;i<=m;i++)
    for(let j=1;j<=n;j++)
      dp[i][j] = a[i-1]===b[j-1] ? dp[i-1][j-1]
        : 1+Math.min(dp[i-1][j], dp[i][j-1], dp[i-1][j-1]);
  return dp[m][n];
}

// Benzerlik skoru 0–1 arası (1=tam eşleşme)
function similarity(a, b){
  const na=kbNorm(a), nb=kbNorm(b);
  if(na===nb) return 1;
  const maxLen=Math.max(na.length, nb.length);
  if(maxLen===0) return 1;
  return 1 - levenshtein(na,nb)/maxLen;
}

// Soyad eşleşmesi — sadece soyadını yazmak da kabul edilsin
function lastNameMatch(guess, answer){
  const parts = kbNorm(answer).split(' ');
  if(parts.length < 2) return false;
  const lastName = parts[parts.length-1];
  const g = kbNorm(guess);
  // Tam soyad eşleşmesi veya soyadına %85+ benzerlik
  return g===lastName || (lastName.length>=4 && similarity(g,lastName)>=0.85);
}

// Genel fuzzy kontrol — %80+ benzerlik veya soyad eşleşmesi
function isCorrectGuess(guess, answer){
  if(!guess) return false;
  const sim = similarity(guess, answer);
  if(sim >= 0.80) return true;
  if(lastNameMatch(guess, answer)) return true;
  // Kelimeleri sırasız compare — "messi lionel" de geçsin
  const gWords = kbNorm(guess).split(' ').sort().join(' ');
  const aWords = kbNorm(answer).split(' ').sort().join(' ');
  if(similarity(gWords, aWords) >= 0.80) return true;
  return false;
}

function submitKbGuess(){
  if(kb.solved || kb.skipped) return;
  const q = kb.pool[kb.idx];
  const input = document.getElementById('kbInput');
  const guess = input.value.trim();
  if(!guess) return;

  const sim = similarity(guess, q.name);
  const correct = isCorrectGuess(guess, q.name);

  // "Yakın ama yetmedi" mesajı için eşik — %60-79 arası
  const veryClose = !correct && sim >= 0.60;

  if(correct){
    // ✅ DOĞRU (tam veya fuzzy)
    kb.solved = true;
    const pts = kb.triesLeft * 10 + (kb.cluesShown===1?20:kb.cluesShown===2?10:5);
    kb.totalScore += pts;
    playSoundCorrect();
    renderKbBlanks(q.name, true);
    const fuzzyNote = sim < 1 && sim >= 0.80 ? `<div style="font-size:11px;color:rgba(255,255,255,.4);margin-top:4px;">yakın sayıldı ✓</div>` : '';
    document.getElementById('kbResultBox').innerHTML=`
      <div class="kb-result-win">
        <div class="kb-result-title" style="color:#6bcb77">🎉 Doğru!</div>
        <div class="kb-result-name">${q.name}</div>
        ${fuzzyNote}
        <div class="kb-score-pill">+${pts} puan</div>
      </div>`;
    document.getElementById('kbInput').disabled=true;
    document.getElementById('btnKbSubmit').disabled=true;
    document.getElementById('btnKbNext').style.display='';
    document.getElementById('btnKbSkipQ').style.display='none';
    document.getElementById('btnKbHint').style.display='none';
    document.getElementById('kbScore').textContent=kb.totalScore+' puan';
    launchConfetti();
  } else {
    // ❌ YANLIŞ
    playSoundWrong();
    kb.triesLeft--;
    input.value='';
    document.querySelectorAll('.kb-letter').forEach(l=>{
      l.classList.add('wrong-flash');
      setTimeout(()=>l.classList.remove('wrong-flash'),400);
    });
    if(kb.triesLeft<=0){
      kbGameOver();
    } else {
      const tryMsg = kb.triesLeft===2 ? '2 hakkın kaldı' : 'Son hakkın!';
      const closeMsg = veryClose ? ' 🔥 Çok yaklaştın!' : '';
      document.getElementById('kbTries').textContent = tryMsg + closeMsg;
      revealLetterHint(q.name);
    }
  }
}


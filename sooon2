function answerQuiz(choiceIdx){
  if(qz.answered) return;
  qz.answered = true;
  const q = qz.questions[qz.qIdx];
  const correct = (choiceIdx === q.answer);

  // Tüm şıkları kilitle ve renk ver
  document.querySelectorAll('.quiz-choice').forEach((btn,i)=>{
    btn.classList.add('disabled');
    if(i===q.answer) btn.classList.add('correct');
    else if(i===choiceIdx && !correct) btn.classList.add('wrong');
  });

  // Açıklama göster
  const exp = document.getElementById('quizExplain');
  exp.textContent = q.explain;
  exp.classList.add('show');

  if(correct){
    qz.currentStreak++;
    if(qz.currentStreak>qz.bestStreak) qz.bestStreak=qz.currentStreak;
    // Puan: temel 10, streak bonusu
    const bonus = Math.min(qz.currentStreak-1,3)*5;
    const pts = 10+bonus;
    qz.score += pts;
    document.getElementById('quizPts').textContent = qz.score+' puan';
    playSoundCorrect();
  } else {
    qz.currentStreak=0;
    playSoundWrong();
  }

  document.getElementById('btnQuizNext').style.display='';
  document.getElementById('btnQuizSkip').style.display='none';
}

function quizSkip(){
  if(qz.answered) return;
  qz.answered=true;
  qz.currentStreak=0;
  const q=qz.questions[qz.qIdx];
  // Doğru cevabı göster
  document.querySelectorAll('.quiz-choice').forEach((btn,i)=>{
    btn.classList.add('disabled');
    if(i===q.answer) btn.classList.add('correct');
  });
  const exp=document.getElementById('quizExplain');
  exp.textContent=q.explain; exp.classList.add('show');
  document.getElementById('btnQuizNext').style.display='';
  document.getElementById('btnQuizSkip').style.display='none';
  playSoundSkip();
}

function showQuizResult(){
  document.getElementById('quizGameArea').style.display='none';
  document.getElementById('quizResultArea').style.display='flex';
  const total=qz.questions.length;
  const maxPts=total*10;
  const pct=qz.score/maxPts;
  let emoji='😅', streakMsg='';
  if(pct>=0.9) emoji='🏆';
  else if(pct>=0.7) emoji='🎉';
  else if(pct>=0.5) emoji='👍';
  document.getElementById('quizResEmoji').textContent=emoji;
  document.getElementById('quizResPts').textContent=qz.score;
  if(qz.bestStreak>=3) streakMsg=`🔥 En uzun seri: ${qz.bestStreak} doğru!`;
  document.getElementById('quizResStreak').textContent=streakMsg;
  if(pct>=0.7) setTimeout(()=>launchConfetti(),300);
}


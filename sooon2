/* ── QUIZ OYUNU ── */
#screen-quiz{gap:0;justify-content:flex-start;padding-top:28px;padding-bottom:22px;}

/* Seri seçim grid */
.quiz-series-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;width:100%;margin-top:4px;}
.quiz-series-btn{border:none;border-radius:18px;padding:16px 12px;
  display:flex;flex-direction:column;align-items:center;gap:7px;
  cursor:pointer;touch-action:manipulation;-webkit-appearance:none;
  transition:transform .15s,opacity .15s;position:relative;overflow:hidden;}
.quiz-series-btn:active{transform:scale(.96);opacity:.85;}
.quiz-series-emoji{font-size:34px;line-height:1;}
.quiz-series-name{font-family:'Bebas Neue',cursive;font-size:16px;color:#fff;
  letter-spacing:.5px;text-align:center;line-height:1.2;}
.quiz-series-count{font-size:10px;color:rgba(255,255,255,.5);font-weight:700;}

/* Header progress */
.quiz-header{width:100%;display:flex;flex-direction:column;gap:6px;margin-bottom:10px;}
.quiz-top-row{display:flex;justify-content:space-between;align-items:center;}
.quiz-series-label{font-family:'Bebas Neue',cursive;font-size:18px;letter-spacing:.5px;
  color:rgba(255,255,255,.7);}
.quiz-pts{font-size:12px;color:rgba(255,255,255,.35);}
.quiz-prog-wrap{height:4px;background:rgba(255,255,255,.1);border-radius:99px;overflow:hidden;}
.quiz-prog-bar{height:100%;border-radius:99px;transition:width .4s ease;}

/* Soru kartı */
.quiz-q-area{flex:1;display:flex;align-items:center;justify-content:center;width:100%;}
.quiz-card{width:100%;background:linear-gradient(145deg,#1a1530,#211940);
  border:1.5px solid rgba(255,255,255,.08);border-radius:24px;
  padding:20px 18px;box-shadow:0 16px 40px rgba(0,0,0,.45);
  display:flex;flex-direction:column;gap:14px;}
.quiz-q-num{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  color:rgba(255,255,255,.3);}
.quiz-q-text{font-size:16px;font-weight:700;color:#fff;line-height:1.4;min-height:44px;}
.quiz-choices{display:flex;flex-direction:column;gap:8px;}
.quiz-choice{width:100%;border:1.5px solid rgba(255,255,255,.14);border-radius:14px;
  background:rgba(255,255,255,.07);padding:13px 16px;
  display:flex;align-items:center;gap:12px;
  font-family:'Nunito',sans-serif;font-weight:700;font-size:14px;color:#fff;
  cursor:pointer;touch-action:manipulation;-webkit-appearance:none;
  transition:all .2s;text-align:left;}
.quiz-choice:active{transform:scale(.98);}
.quiz-choice-letter{width:26px;height:26px;border-radius:8px;
  background:rgba(255,255,255,.12);display:flex;align-items:center;
  justify-content:center;font-family:'Bebas Neue',cursive;font-size:16px;
  flex-shrink:0;transition:background .2s;}
/* Seçim sonrası renkler */
.quiz-choice.correct{background:rgba(34,197,94,.18);border-color:rgba(34,197,94,.6);}
.quiz-choice.correct .quiz-choice-letter{background:#22c55e;color:#fff;}
.quiz-choice.wrong{background:rgba(255,107,107,.15);border-color:rgba(255,107,107,.4);}
.quiz-choice.wrong .quiz-choice-letter{background:#ff4757;color:#fff;}
.quiz-choice.disabled{opacity:.55;cursor:default;}

/* Açıklama kutusu */
.quiz-explain{font-size:13px;color:rgba(255,255,255,.55);line-height:1.45;
  background:rgba(255,255,255,.05);border-radius:12px;padding:10px 14px;
  border-left:3px solid rgba(255,255,255,.15);display:none;}
.quiz-explain.show{display:block;animation:slideIn .25s ease;}

/* Alt butonlar */
.quiz-footer{display:flex;gap:10px;width:100%;margin-top:8px;}

/* Sonuç ekranı */
.quiz-result-wrap{display:flex;flex-direction:column;align-items:center;gap:14px;
  width:100%;flex:1;justify-content:center;text-align:center;}
.quiz-result-emoji{font-size:64px;animation:bounce 1.5s infinite;}
.quiz-result-title{font-family:'Bebas Neue',cursive;font-size:44px;

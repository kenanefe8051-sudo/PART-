// ── Mekanik tik-tak — iki ton (tik/tak), kuru ve kısa ──
let tikTak = true; // true=tik (yüksek), false=tak (alçak)

function playTikTak(timeLeft, totalTime){
  const ctx = getAudioCtx();
  const t = ctx.currentTime;
  const pct = timeLeft / totalTime;

  // TİK: daha yüksek ve net / TAK: biraz alçak ve tombul
  const freq  = tikTak ? 1050 : 820;
  const freq2 = tikTak ? 620  : 480;   // hızlı pitch düşüşü
  // Ses kısık — süre azaldıkça sadece çok hafif artar
  const vol = 0.07 + (1 - pct) * 0.05; // 0.07 → 0.12 arası

  // Kısa transient noise — mekanik "klik" hissi
  const bufLen = Math.floor(ctx.sampleRate * 0.025);
  const buf = ctx.createBuffer(1, bufLen, ctx.sampleRate);
  const d = buf.getChannelData(0);
  for(let i = 0; i < bufLen; i++) d[i] = (Math.random()*2-1) * (1 - i/bufLen);
  const noise = ctx.createBufferSource();
  noise.buffer = buf;
  const nFilt = ctx.createBiquadFilter();
  nFilt.type = 'bandpass';
  nFilt.frequency.value = tikTak ? 3500 : 2200;
  nFilt.Q.value = 1.8;
  const nGain = ctx.createGain();
  nGain.gain.setValueAtTime(vol * 0.6, t);
  nGain.gain.exponentialRampToValueAtTime(0.001, t + 0.022);
  noise.connect(nFilt); nFilt.connect(nGain); nGain.connect(ctx.destination);
  noise.start(t); noise.stop(t + 0.025);

  // Ton katmanı — hızla sönen sine darbesi
  const osc = ctx.createOscillator();
  const oGain = ctx.createGain();
  osc.connect(oGain); oGain.connect(ctx.destination);
  osc.type = 'sine';
  osc.frequency.setValueAtTime(freq, t);
  osc.frequency.exponentialRampToValueAtTime(freq2, t + 0.04);
  oGain.gain.setValueAtTime(vol, t);
  oGain.gain.exponentialRampToValueAtTime(0.001, t + 0.045);
  osc.start(t); osc.stop(t + 0.05);

  tikTak = !tikTak; // bir sonraki çağrıda diğer ton
}

function startHeartbeat(timeLeft, totalTime){
  stopHeartbeat();
  if(timeLeft <= 0) return;
  const pct = timeLeft / totalTime;

  // Hız sadece son %25'te hızlanır, geri kalan sabit 1 sn
  let interval;
  if(pct > 0.25)      interval = 1000;
  else if(pct > 0.12) interval = 750;
  else                interval = 500;

  playTikTak(timeLeft, totalTime);
  heartbeatInterval = setInterval(()=>{
    playTikTak(st.tabu.timeLeft, totalTime);
  }, interval);
}

function stopHeartbeat(){
  if(heartbeatInterval){ clearInterval(heartbeatInterval); heartbeatInterval=null; }
}
function stopAllTabuSounds(){ stopHeartbeat(); }

/* ══════════════════════════════════════════════
   KONFETİ MOTORU
══════════════════════════════════════════════ */
const CONFETTI_COLORS=['#ff6b6b','#ffd93d','#6bcb77','#4d96ff','#c77dff','#ff9f43','#00d2d3','#ff9ff3','#fff'];
let confettiParticles=[];
let confettiRAF=null;

function launchConfetti(){
  const canvas=document.getElementById('confetti-canvas');
  const W=canvas.width=window.innerWidth;
  const H=canvas.height=window.innerHeight;
  const ctx=canvas.getContext('2d');
  confettiParticles=[];

  // 180 parçacık patlat
  for(let i=0;i<180;i++){
    const angle=(Math.random()*360)*Math.PI/180;
    const speed=4+Math.random()*8;
    confettiParticles.push({
      x: W/2 + (Math.random()-0.5)*W*0.6,
      y: H*0.4,
      vx: Math.cos(angle)*speed,
      vy: Math.sin(angle)*speed - 6,
      w: 7+Math.random()*7,
      h: 5+Math.random()*5,
      rot: Math.random()*360,
      rotV: (Math.random()-0.5)*8,
      color: CONFETTI_COLORS[Math.floor(Math.random()*CONFETTI_COLORS.length)],
      alpha:1, life:1
    });
  }

  cancelAnimationFrame(confettiRAF);
  function draw(){
    ctx.clearRect(0,0,W,H);
    let alive=false;
    confettiParticles.forEach(p=>{
      p.x+=p.vx; p.y+=p.vy;
      p.vy+=0.28;          // yerçekimi
      p.vx*=0.99;          // hava direnci
      p.rot+=p.rotV;
      p.life-=0.012;
      p.alpha=Math.max(0,p.life);
      if(p.alpha>0){
        alive=true;
        ctx.save();
        ctx.globalAlpha=p.alpha;
        ctx.translate(p.x,p.y);
        ctx.rotate(p.rot*Math.PI/180);
        ctx.fillStyle=p.color;
        ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);
        ctx.restore();
      }
    });
    if(alive) confettiRAF=requestAnimationFrame(draw);
    else ctx.clearRect(0,0,W,H);
  }
  draw();

  // Konfeti patlama sesi — yükselen çok sesli parıltı
  const ac=getAudioCtx();
  [523,659,784,880,1047,1318].forEach((f,i)=>{
    const o=ac.createOscillator(), g=ac.createGain();
    o.connect(g); g.connect(ac.destination);
    o.type='sine'; o.frequency.value=f;
    const st2=ac.currentTime+i*0.05;
    g.gain.setValueAtTime(0,st2);
    g.gain.linearRampToValueAtTime(0.18,st2+0.03);
    g.gain.exponentialRampToValueAtTime(0.001,st2+0.4);
    o.start(st2); o.stop(st2+0.4);
  });
  // Gürültü patlaması
  const bufSz=ac.sampleRate*0.15;
  const buf=ac.createBuffer(1,bufSz,ac.sampleRate);
  const d=buf.getChannelData(0);
  for(let i=0;i<bufSz;i++) d[i]=(Math.random()*2-1);
  const ns=ac.createBufferSource();
  ns.buffer=buf;
  const flt=ac.createBiquadFilter(); flt.type='highpass'; flt.frequency.value=3000;
  const gn=ac.createGain(); gn.gain.setValueAtTime(0.3,ac.currentTime);
  gn.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+0.15);
  ns.connect(flt); flt.connect(gn); gn.connect(ac.destination);
  ns.start(); ns.stop(ac.currentTime+0.15);
}

/* ══════════════ TABU TIMER ══════════════ */
function startTabuTimer(){
  clearInterval(st.tabu.timerInterval);
  stopAllTabuSounds();
  const total=st.tabu.totalTime;
  st.tabu.timeLeft=total;
  updateTimerBar();
  startHeartbeat(total, total);
  st.tabu.timerInterval=setInterval(()=>{
    st.tabu.timeLeft--;
    updateTimerBar();
    // Her saniye kalp atışını güncelle (hız için yeniden başlat)
    startHeartbeat(st.tabu.timeLeft, total);
    if(st.tabu.timeLeft<=0){
      clearInterval(st.tabu.timerInterval);
      stopHeartbeat();
      playSoundTimeUp();
      tabuTimeUp();
    }
  },1000);
}

function updateTimerBar(){
  const pct=(st.tabu.timeLeft/st.tabu.totalTime)*100;
  const bar=document.getElementById('tabuTimerBar');
  const txt=document.getElementById('tabuTimerText');
  
  bar.style.width=pct+'%';
  txt.textContent = st.tabu.timeLeft + 's';
  
  // Renk ve animasyon güncellemeleri
  if(pct > 50) {
    bar.style.background='linear-gradient(90deg,#22c55e,#86efac)';
    bar.classList.remove('timer-danger');
    txt.classList.remove('timer-text-danger');
  } 
  else if(pct > 25 && st.tabu.timeLeft > 10) {
    bar.style.background='linear-gradient(90deg,#f59e0b,#fcd34d)';
    bar.classList.remove('timer-danger');
    txt.classList.remove('timer-text-danger');
  } 
  else {
    // Kırmızı alarm durumu (Sürenin %25'i altı VEYA son 10 saniye)
    bar.style.background='linear-gradient(90deg,#ef4444,#fca5a5)';
    if(st.tabu.timeLeft <= 10) {
      bar.classList.add('timer-danger');
      txt.classList.add('timer-text-danger');
    }
  }
}


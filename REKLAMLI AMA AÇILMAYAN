function drawDial(){
  const cv=document.getElementById('dialCanvas');
  const W=cv.offsetWidth||420;
  const TW=Math.round(W*0.092);
  const R=W*0.42;
  const PAD=10;
  const H=R+TW/2+PAD+32;
  cv.width=W; cv.height=Math.round(H);
  const ctx=cv.getContext('2d');
  ctx.clearRect(0,0,W,H);
  const cx=W/2, cy=H;
  const isGuess=state.phase==='guess', isResult=state.phase==='result', isReveal=state.phase==='reveal';
  const showTarget=isReveal||isResult;

  if(showTarget){
    const ta=Math.PI+state.targetAngle/180*Math.PI;
    const gx=cx+Math.cos(ta)*R, gy=cy+Math.sin(ta)*R;
    const radG=ctx.createRadialGradient(gx,gy,0,gx,gy,R*0.6);
    radG.addColorStop(0,'rgba(94,207,190,.12)');radG.addColorStop(1,'rgba(94,207,190,0)');
    ctx.fillStyle=radG;ctx.fillRect(0,0,W,H);
  }

  // Tick marklar
  const tickOuter=R+TW/2+2;
  ctx.textAlign='center';ctx.textBaseline='middle';
  for(let i=0;i<=18;i++){
    const a=Math.PI+(i/18)*Math.PI, isMajor=i%3===0, len=isMajor?14:7;
    ctx.beginPath();
    ctx.moveTo(cx+Math.cos(a)*tickOuter, cy+Math.sin(a)*tickOuter);
    ctx.lineTo(cx+Math.cos(a)*(tickOuter+len), cy+Math.sin(a)*(tickOuter+len));
    ctx.strokeStyle=isMajor?'rgba(218,234,234,.25)':'rgba(218,234,234,.08)';
    ctx.lineWidth=isMajor?2:1;ctx.stroke();
    if(state.concept){
      const labelR=tickOuter+22;
      if(i===0){ctx.font='bold 11px "Space Mono",monospace';ctx.fillStyle='#c98a82';ctx.fillText(state.concept[0],cx+Math.cos(Math.PI)*labelR,cy+Math.sin(Math.PI)*labelR);}
      if(i===18){ctx.font='bold 11px "Space Mono",monospace';ctx.fillStyle='#7ea8cc';ctx.fillText(state.concept[1],cx+Math.cos(2*Math.PI)*labelR,cy+Math.sin(2*Math.PI)*labelR);}
    }
  }

  // Track arka plan
  ctx.beginPath();ctx.arc(cx,cy,R+TW/2+3,Math.PI,2*Math.PI);
  ctx.strokeStyle='rgba(0,0,0,.55)';ctx.lineWidth=7;ctx.stroke();
  ctx.beginPath();ctx.arc(cx,cy,R,Math.PI,2*Math.PI);
  ctx.strokeStyle='#080c1e';ctx.lineWidth=TW+6;ctx.stroke();
  const baseG=ctx.createLinearGradient(cx-R,0,cx+R,0);
  baseG.addColorStop(0,'rgba(160,80,70,.32)');baseG.addColorStop(.5,'rgba(94,207,190,.08)');baseG.addColorStop(1,'rgba(70,110,170,.32)');
  ctx.beginPath();ctx.arc(cx,cy,R,Math.PI,2*Math.PI);ctx.strokeStyle=baseG;ctx.lineWidth=TW;ctx.stroke();
  ctx.beginPath();ctx.arc(cx,cy,R-TW/2,Math.PI,2*Math.PI);ctx.strokeStyle='rgba(255,255,255,.07)';ctx.lineWidth=1.5;ctx.stroke();
  ctx.beginPath();ctx.arc(cx,cy,R+TW/2,Math.PI,2*Math.PI);ctx.strokeStyle='rgba(255,255,255,.05)';ctx.lineWidth=1.5;ctx.stroke();

  if(showTarget){
    // Bölgeler
    const zones=[
      {spread:56,color:'#c46c1a',opacity:.75},
      {spread:34,color:'#c8b820',opacity:.85},
      {spread:20,color:'#28b865',opacity:.90},
      {spread: 9,color:'#3de8cc',opacity:1.00},
    ];
    zones.forEach(z=>{
      const a1=Math.PI+(state.targetAngle-z.spread/2)/180*Math.PI;
      const a2=Math.PI+(state.targetAngle+z.spread/2)/180*Math.PI;
      const r2=parseInt(z.color.slice(1,3),16),g2=parseInt(z.color.slice(3,5),16),b2=parseInt(z.color.slice(5,7),16);
      if(z.spread===9){ctx.shadowColor='rgba(61,232,204,.8)';ctx.shadowBlur=26;}
      ctx.beginPath();ctx.arc(cx,cy,R,a1,a2);
      ctx.strokeStyle=`rgba(${r2},${g2},${b2},${z.opacity})`;ctx.lineWidth=TW;ctx.stroke();
      ctx.shadowBlur=0;
    });
    // Ayırıcılar
    [28,17,9.5].forEach(d=>{
      [-1,1].forEach(side=>{
        const a=Math.PI+(state.targetAngle+side*d)/180*Math.PI;
        ctx.beginPath();
        ctx.moveTo(cx+Math.cos(a)*(R-TW/2),cy+Math.sin(a)*(R-TW/2));
        ctx.lineTo(cx+Math.cos(a)*(R+TW/2),cy+Math.sin(a)*(R+TW/2));
        ctx.strokeStyle='rgba(5,8,25,.65)';ctx.lineWidth=2;ctx.stroke();
      });
    });
    // Merkez çizgi
    const ta=Math.PI+state.targetAngle/180*Math.PI;
    ctx.beginPath();
    ctx.moveTo(cx+Math.cos(ta)*(R-TW/2-3),cy+Math.sin(ta)*(R-TW/2-3));
    ctx.lineTo(cx+Math.cos(ta)*(R+TW/2+3),cy+Math.sin(ta)*(R+TW/2+3));
    ctx.strokeStyle='rgba(255,255,255,.92)';ctx.lineWidth=2.5;ctx.lineCap='round';
    ctx.shadowColor='#fff';ctx.shadowBlur=8;ctx.stroke();ctx.shadowBlur=0;
    // Merkez top
    const dotX=cx+Math.cos(ta)*R, dotY=cy+Math.sin(ta)*R;
    const dotG=ctx.createRadialGradient(dotX,dotY,0,dotX,dotY,12);
    dotG.addColorStop(0,'#ffffff');dotG.addColorStop(0.4,'#a0f4e8');dotG.addColorStop(1,'rgba(94,207,190,0)');
    ctx.shadowColor='rgba(94,207,190,.9)';ctx.shadowBlur=24;
    ctx.beginPath();ctx.arc(dotX,dotY,9,0,2*Math.PI);ctx.fillStyle=dotG;ctx.fill();ctx.shadowBlur=0;
    // Puan etiketleri — düz, döndürülmeden
    const scoreLabels=[
      {midDeg:4.5, text:'+4', color:'#ffffff', bg:'rgba(20,30,60,.72)', size:12},
      {midDeg:14.5,text:'+3', color:'#78f0a0', bg:'rgba(20,30,60,.72)', size:11},
      {midDeg:27,  text:'+2', color:'#f0d840', bg:'rgba(20,30,60,.72)', size:11},
      {midDeg:45,  text:'+1', color:'#f0a040', bg:'rgba(20,30,60,.72)', size:11},
    ];
    scoreLabels.forEach(lb=>{
      [-1,1].forEach(side=>{
        const lAngle=Math.PI+(state.targetAngle+side*lb.midDeg)/180*Math.PI;
        const labelR=R-TW/2+TW*0.35;
        const lx=cx+Math.cos(lAngle)*labelR, ly=cy+Math.sin(lAngle)*labelR;
        ctx.font=`bold ${lb.size}px "Space Mono",monospace`;
        ctx.textAlign='center';ctx.textBaseline='middle';
        const metrics=ctx.measureText(lb.text);
        const pw=metrics.width+8, ph=lb.size+6;
        ctx.fillStyle=lb.bg;ctx.beginPath();
        if(ctx.roundRect)ctx.roundRect(lx-pw/2,ly-ph/2,pw,ph,4);
        else ctx.rect(lx-pw/2,ly-ph/2,pw,ph);
        ctx.fill();
        ctx.fillStyle=lb.color;ctx.shadowColor='rgba(0,0,0,.95)';ctx.shadowBlur=3;
        ctx.fillText(lb.text,lx,ly);ctx.shadowBlur=0;
      });
    });
  }

  // İbre
  if(isGuess||isResult){
    const na=Math.PI+state.needleAngle/180*Math.PI;
    const nc=state.guessTeam===0?'#5ecfbe':'#d97fc4';
    const nGlow=state.guessTeam===0?'rgba(94,207,190,.8)':'rgba(217,127,196,.8)';
    const needleTip=R+TW/2+4;
    ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(cx+Math.cos(na)*needleTip,cy+Math.sin(na)*needleTip);
    ctx.strokeStyle='rgba(0,0,0,.5)';ctx.lineWidth=9;ctx.lineCap='round';ctx.stroke();
    const nGrad=ctx.createLinearGradient(cx,cy,cx+Math.cos(na)*needleTip,cy+Math.sin(na)*needleTip);
    nGrad.addColorStop(0,nc);nGrad.addColorStop(0.7,nc);nGrad.addColorStop(1,'#fff');
    ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(cx+Math.cos(na)*needleTip,cy+Math.sin(na)*needleTip);
    ctx.shadowColor=nGlow;ctx.shadowBlur=isGuess?20:8;ctx.strokeStyle=nGrad;ctx.lineWidth=5;ctx.lineCap='round';ctx.stroke();ctx.shadowBlur=0;
    const tipX=cx+Math.cos(na)*needleTip, tipY=cy+Math.sin(na)*needleTip;
    const tipG=ctx.createRadialGradient(tipX,tipY,0,tipX,tipY,10);
    tipG.addColorStop(0,'#fff');tipG.addColorStop(0.4,nc);tipG.addColorStop(1,'rgba(0,0,0,0)');
    ctx.beginPath();ctx.arc(tipX,tipY,8,0,2*Math.PI);ctx.fillStyle=tipG;
    ctx.shadowColor=nGlow;ctx.shadowBlur=isGuess?24:10;ctx.fill();ctx.shadowBlur=0;
    const bG=ctx.createRadialGradient(cx,cy,0,cx,cy,16);
    bG.addColorStop(0,'#fff');bG.addColorStop(0.35,nc);bG.addColorStop(1,'rgba(0,0,0,0)');
    ctx.beginPath();ctx.arc(cx,cy,14,0,2*Math.PI);ctx.fillStyle=bG;
    ctx.shadowColor=nGlow;ctx.shadowBlur=isGuess?28:10;ctx.fill();ctx.shadowBlur=0;
    if(isGuess){
      const dlR=R*0.55;
      ctx.font='bold 14px "Space Mono",monospace';ctx.fillStyle='rgba(255,255,255,.75)';
      ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.shadowColor='rgba(0,0,0,.9)';ctx.shadowBlur=6;
      ctx.fillText(Math.round(state.needleAngle)+'°',cx+Math.cos(na)*dlR,cy+Math.sin(na)*dlR-10);
      ctx.shadowBlur=0;
    }
  } else {
    const idleG=ctx.createRadialGradient(cx,cy,0,cx,cy,12);
    idleG.addColorStop(0,'rgba(218,234,234,.25)');idleG.addColorStop(1,'rgba(218,234,234,0)');
    ctx.beginPath();ctx.arc(cx,cy,12,0,2*Math.PI);ctx.fillStyle=idleG;ctx.fill();
    ctx.beginPath();ctx.arc(cx,cy,4,0,2*Math.PI);ctx.fillStyle='rgba(218,234,234,.3)';ctx.fill();
  }
}

/* Dial events */
function setupDialEvents(){
  const cv=document.getElementById('dialCanvas');
  cv.removeEventListener('mousedown',onDown);cv.removeEventListener('touchstart',onTouchStart);
  cv.addEventListener('mousedown',onDown);cv.addEventListener('touchstart',onTouchStart,{passive:false});
}
function getAngle(e,cv){
  const rc=cv.getBoundingClientRect();
  const x=(e.touches?e.touches[0].clientX:e.clientX)-rc.left-rc.width/2;
  const y=(e.touches?e.touches[0].clientY:e.clientY)-rc.top-rc.height;
  let a=Math.atan2(y,x)*180/Math.PI-180;if(a<0)a+=360;return Math.max(0,Math.min(180,a));
}
function onDown(e){if(state.phase!=='guess')return;state.dragging=true;state.needleAngle=getAngle(e,e.currentTarget);drawDial();document.addEventListener('mousemove',onMove);document.addEventListener('mouseup',onUp);}
function onMove(e){if(!state.dragging||state.phase!=='guess')return;e.preventDefault();state.needleAngle=getAngle(e,document.getElementById('dialCanvas'));drawDial();}
function onUp(){state.dragging=false;document.removeEventListener('mousemove',onMove);document.removeEventListener('mouseup',onUp);}
function onTouchStart(e){if(state.phase!=='guess')return;e.preventDefault();state.needleAngle=getAngle(e,e.currentTarget);drawDial();e.currentTarget.addEventListener('touchmove',onTouchMove,{passive:false});e.currentTarget.addEventListener('touchend',onTouchEnd);}
function onTouchMove(e){if(state.phase!=='guess')return;e.preventDefault();state.needleAngle=getAngle(e,e.currentTarget);drawDial();}
function onTouchEnd(e){e.currentTarget.removeEventListener('touchmove',onTouchMove);e.currentTarget.removeEventListener('touchend',onTouchEnd);}
window.addEventListener('resize',()=>{if(document.getElementById('game').classList.contains('active'))drawDial();});

/* Ses */
let AC;
function ac(){if(!AC)AC=new(window.AudioContext||window.webkitAudioContext)();if(AC.state==='suspended')AC.resume();return AC;}
function playSuccess(){const c=ac();[523,659,784,1047].forEach((f,i)=>{const o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.type='sine';o.frequency.value=f;const t=c.currentTime+i*.09;g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(.17,t+.02);g.gain.exponentialRampToValueAtTime(.001,t+.22);o.start(t);o.stop(t+.22);});}
function playOk(){const c=ac();[440,550].forEach((f,i)=>{const o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.type='sine';o.frequency.value=f;const t=c.currentTime+i*.1;g.gain.setValueAtTime(.12,t);g.gain.exponentialRampToValueAtTime(.001,t+.2);o.start(t);o.stop(t+.2);});}
function playFail(){const c=ac();[280,220].forEach((f,i)=>{const o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.type='sawtooth';o.frequency.value=f;const t=c.currentTime+i*.13;g.gain.setValueAtTime(.13,t);g.gain.exponentialRampToValueAtTime(.001,t+.22);o.start(t);o.stop(t+.23);});}

/* Konfeti */
const CONF_COLORS=['#5ecfbe','#d97fc4','#e8c96a','#7ea8cc','#c98a82','#b8dcd8'];
let confParts=[],confRAF;
function launchConfetti(){
  const cv=document.getElementById('confetti');
  const W=cv.width=window.innerWidth,H=cv.height=window.innerHeight;
  const ctx=cv.getContext('2d');confParts=[];
  for(let i=0;i<140;i++){const a=(Math.random()*360)*Math.PI/180,sp=3+Math.random()*6;
    confParts.push({x:W/2+(Math.random()-.5)*W*.7,y:H*.45,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-5,
      w:5+Math.random()*7,h:4+Math.random()*5,rot:Math.random()*360,rv:(Math.random()-.5)*7,
      c:CONF_COLORS[Math.floor(Math.random()*CONF_COLORS.length)],life:1});}
  cancelAnimationFrame(confRAF);
  function draw(){ctx.clearRect(0,0,W,H);let alive=false;
    confParts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.vy+=.24;p.vx*=.99;p.rot+=p.rv;p.life-=.013;
      const a=Math.max(0,p.life);if(a>0){alive=true;ctx.save();ctx.globalAlpha=a;ctx.translate(p.x,p.y);
        ctx.rotate(p.rot*Math.PI/180);ctx.fillStyle=p.c;ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);ctx.restore();}});
    if(alive)confRAF=requestAnimationFrame(draw);else ctx.clearRect(0,0,W,H);}
  draw();
}

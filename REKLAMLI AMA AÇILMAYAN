document.getElementById('modeCards').addEventListener('click', e=>{
  const card = e.target.closest('[data-mode]');
  if(!card) return;
  const mode = card.dataset.mode;
  if(mode === 'general' || ownedModes[mode]){
    selectedMode = mode;
    // Setup ekranına geç
    const meta = MODE_META[mode];
    document.getElementById('setupHeading').textContent = meta.icon + ' ' + meta.name;
    // Mod chip ayarla
    const chip = document.getElementById('modeChip');
    chip.textContent = meta.icon + ' ' + meta.name.split(' ')[0];
    chip.style.background = meta.chipColor;
    chip.style.color = meta.chipTextColor;
    chip.style.padding = '2px 8px';
    chip.style.borderRadius = '20px';
    chip.style.fontSize = '10px';
    chip.style.fontWeight = '700';
    show('setup');
  } else {
    openUnlockModal(mode);
  }
});

/* ══ UNLOCK MODAL ══ */
let pendingUnlockMode = null;

function openUnlockModal(mode){
  pendingUnlockMode = mode;
  const meta = MODE_META[mode];
  document.getElementById('unlockIcon').textContent = meta.icon;
  document.getElementById('unlockName').textContent = meta.name;
  document.getElementById('unlockDesc').textContent = meta.desc;
  document.getElementById('unlockPrice').textContent = meta.price;
  document.getElementById('btnUnlockBuy').textContent = `${meta.price} — SATIN AL ⭐`;
  const featEl = document.getElementById('unlockFeatures');
  featEl.innerHTML = meta.features.map(f=>`
    <div class="uf-row"><span class="uf-icon">${f.icon}</span>
    <div class="uf-text">${f.text}</div></div>`).join('');
  document.getElementById('unlockModal').classList.add('open');
}

document.getElementById('btnUnlockClose').addEventListener('click',()=>{
  document.getElementById('unlockModal').classList.remove('open');
  pendingUnlockMode = null;
});
document.getElementById('unlockModal').addEventListener('click',e=>{
  if(e.target===document.getElementById('unlockModal')){
    document.getElementById('unlockModal').classList.remove('open');
    pendingUnlockMode = null;
  }
});
document.getElementById('btnUnlockBuy').addEventListener('click',()=>{
  if(!pendingUnlockMode) return;
  const meta = MODE_META[pendingUnlockMode];
  if(confirm(`${meta.name} modu ${meta.price} olacak.\n\n(Bu bir simülasyondur — gerçek ödeme alınmaz)`)){
    ownedModes[pendingUnlockMode] = true;
    saveModes(ownedModes);
    refreshModeBadges();
    document.getElementById('unlockModal').classList.remove('open');
    setTimeout(()=>{
      alert(`✓ ${meta.name} modu açıldı! Artık oynayabilirsin.`);
      selectedMode = pendingUnlockMode;
      const chip = document.getElementById('modeChip');
      chip.textContent = meta.icon + ' ' + meta.name.split(' ')[0];
      chip.style.background = meta.chipColor;
      chip.style.color = meta.chipTextColor;
      chip.style.padding = '2px 8px';
      chip.style.borderRadius = '20px';
      chip.style.fontSize = '10px';
      chip.style.fontWeight = '700';
      document.getElementById('setupHeading').textContent = meta.icon + ' ' + meta.name;
      show('setup');
      pendingUnlockMode = null;
    }, 200);
  }
});


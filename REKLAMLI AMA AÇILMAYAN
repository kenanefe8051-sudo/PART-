<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Frekans 〰️</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;touch-action:manipulation;}
:root{
  --bg:#07091a;--bg2:#0c1024;--surface:#111628;--surface2:#161d35;
  --border:rgba(130,200,210,.1);--border2:rgba(130,200,210,.18);
  --accent:#5ecfbe;--accent2:#d97fc4;--text:#daeaea;
  --text2:rgba(218,234,234,.55);--text3:rgba(218,234,234,.28);
}
body{font-family:'Syne',sans-serif;background:var(--bg);color:var(--text);
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  overflow:hidden;position:relative;}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:linear-gradient(rgba(94,207,190,.025) 1px,transparent 1px),
  linear-gradient(90deg,rgba(94,207,190,.025) 1px,transparent 1px);
  background-size:52px 52px;animation:gridDrift 24s linear infinite;}
@keyframes gridDrift{from{background-position:0 0}to{background-position:52px 52px}}
body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:radial-gradient(ellipse 55% 38% at 18% 25%,rgba(94,207,190,.055) 0%,transparent 70%),
  radial-gradient(ellipse 48% 32% at 82% 72%,rgba(217,127,196,.055) 0%,transparent 70%);}

/* ── SCREENS ── */
.screen{display:none;width:100%;max-width:480px;min-height:100vh;
  padding:24px 20px 80px;flex-direction:column;align-items:center;
  justify-content:center;position:relative;z-index:1;gap:14px;}
.screen.active{display:flex;}
#game{justify-content:flex-start;padding-top:18px;padding-bottom:18px;gap:0;}
#mode-select{justify-content:flex-start;padding-top:40px;gap:14px;}
#setup{justify-content:flex-start;padding-top:40px;gap:15px;}

/* ── SPLASH ── */
#splash{text-align:center;gap:0;}
.splash-logo{font-size:68px;margin-bottom:14px;filter:drop-shadow(0 0 16px rgba(94,207,190,.3));animation:floatLogo 3.2s ease-in-out infinite;}
@keyframes floatLogo{0%,100%{transform:translateY(0) rotate(-3deg)}50%{transform:translateY(-9px) rotate(3deg)}}
.splash-title{font-family:'Space Mono',monospace;font-size:clamp(38px,10vw,54px);font-weight:700;
  letter-spacing:-2px;background:linear-gradient(135deg,var(--accent),#a0e8de,var(--accent2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1;margin-bottom:8px;}
.splash-sub{font-size:12px;color:var(--text3);letter-spacing:3px;text-transform:uppercase;
  margin-bottom:28px;font-family:'Space Mono',monospace;}

/* ── BUTTONS ── */
.btn{width:100%;padding:15px 22px;border:none;border-radius:12px;
  font-family:'Space Mono',monospace;font-size:13px;font-weight:700;
  cursor:pointer;touch-action:manipulation;-webkit-appearance:none;transition:all .18s;letter-spacing:1px;}
.btn:active{transform:scale(.97);}
.btn-primary{background:linear-gradient(135deg,var(--accent),#3aafa0);color:var(--bg);box-shadow:0 0 22px rgba(94,207,190,.2);}
.btn-secondary{background:transparent;color:var(--text2);border:1.5px solid rgba(218,234,234,.1);font-size:12px;}
.btn-ghost{background:transparent;color:var(--text3);font-size:12px;padding:10px;border:none;}
.btn-sm{width:auto;padding:10px 16px;font-size:12px;border-radius:10px;}
.btn-pink{background:linear-gradient(135deg,var(--accent2),#b05898);color:#fff;box-shadow:0 0 18px rgba(217,127,196,.2);}
.btn-gold{background:linear-gradient(135deg,#f0c040,#d4860a);color:#1a0f00;box-shadow:0 0 18px rgba(240,192,64,.25);font-weight:700;}

/* ── COMMON ── */
.label-sm{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:3px;
  text-transform:uppercase;color:var(--accent);align-self:flex-start;opacity:.75;}
.divider{width:100%;height:1px;background:linear-gradient(90deg,transparent,var(--border2),transparent);}
input[type=text]{flex:1;background:transparent;border:none;color:var(--text);
  font-family:'Syne',sans-serif;font-size:15px;font-weight:600;outline:none;}
input::placeholder{color:var(--text3);}
.team-inputs{display:flex;flex-direction:column;gap:10px;width:100%;}
.team-input-row{display:flex;align-items:center;gap:12px;background:var(--surface);
  border:1.5px solid var(--border);border-radius:14px;padding:14px 16px;}
.team-color-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.rounds-row{display:flex;gap:8px;width:100%;}
.round-btn{flex:1;padding:11px 6px;border:1.5px solid var(--border);border-radius:10px;
  background:transparent;font-family:'Space Mono',monospace;font-size:14px;font-weight:700;
  color:var(--text3);cursor:pointer;transition:all .15s;}
.round-btn.active{background:rgba(94,207,190,.09);border-color:rgba(94,207,190,.38);color:var(--accent);}

/* ── MODE SELECT ── */
.mode-select-title{font-family:'Space Mono',monospace;font-size:22px;font-weight:700;
  align-self:flex-start;letter-spacing:-1px;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.mode-cards{display:flex;flex-direction:column;gap:10px;width:100%;}

.mode-card{width:100%;border:none;border-radius:18px;padding:18px 20px;
  display:flex;align-items:center;gap:14px;text-align:left;
  cursor:pointer;-webkit-appearance:none;transition:all .2s;position:relative;overflow:hidden;}
.mode-card:active{transform:scale(.98);}

/* FREE — teal */
.mode-card-free{background:linear-gradient(135deg,rgba(15,50,44,.95),rgba(10,36,32,.95));
  border:1.5px solid rgba(94,207,190,.3);box-shadow:0 8px 24px rgba(94,207,190,.1);}
/* Couples — rose/pink */
.mode-card-couple{background:linear-gradient(135deg,rgba(50,15,40,.95),rgba(38,10,32,.95));
  border:1.5px solid rgba(217,127,196,.3);box-shadow:0 8px 24px rgba(217,127,196,.1);}
/* Friends 18+ — amber */
.mode-card-friends{background:linear-gradient(135deg,rgba(50,32,8,.95),rgba(38,24,6,.95));
  border:1.5px solid rgba(240,192,64,.3);box-shadow:0 8px 24px rgba(240,192,64,.08);}
/* Family — blue/purple */
.mode-card-family{background:linear-gradient(135deg,rgba(18,20,55,.95),rgba(14,16,44,.95));
  border:1.5px solid rgba(140,120,240,.3);box-shadow:0 8px 24px rgba(140,120,240,.08);}

.mc-icon{font-size:38px;flex-shrink:0;filter:drop-shadow(0 0 10px rgba(255,255,255,.15));}
.mc-info{flex:1;}
.mc-name{font-family:'Space Mono',monospace;font-size:17px;font-weight:700;color:#fff;letter-spacing:.3px;margin-bottom:3px;}
.mc-desc{font-size:11px;color:rgba(255,255,255,.5);font-weight:600;line-height:1.4;}
.mc-badge{display:flex;align-items:center;gap:5px;margin-top:5px;}
.mc-free-tag{background:rgba(94,207,190,.15);border:1px solid rgba(94,207,190,.3);
  border-radius:20px;padding:2px 10px;font-family:'Space Mono',monospace;
  font-size:10px;font-weight:700;color:var(--accent);letter-spacing:.5px;}
.mc-lock-tag{background:rgba(240,192,64,.12);border:1px solid rgba(240,192,64,.28);
  border-radius:20px;padding:2px 10px;font-family:'Space Mono',monospace;
  font-size:10px;font-weight:700;color:#f0c040;letter-spacing:.5px;display:flex;align-items:center;gap:4px;}
.mc-owned-tag{background:rgba(94,207,190,.12);border:1px solid rgba(94,207,190,.28);
  border-radius:20px;padding:2px 10px;font-family:'Space Mono',monospace;
  font-size:10px;font-weight:700;color:var(--accent);letter-spacing:.5px;}

/* Lock overlay on locked cards */
.mode-card-locked{opacity:.78;}
.mode-card-locked::after{content:'🔒';position:absolute;top:14px;right:16px;font-size:18px;opacity:.6;}

/* ── SETUP ── */
.setup-heading{font-family:'Space Mono',monospace;font-size:24px;font-weight:700;letter-spacing:-1px;
  align-self:flex-start;margin-bottom:-4px;}

/* ── GAME ── */
.game-top{width:100%;display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;}
.round-badge{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:2px;color:var(--text3);text-transform:uppercase;}
.mode-chip{font-family:'Space Mono',monospace;font-size:10px;font-weight:700;
  padding:3px 10px;border-radius:20px;letter-spacing:.5px;}

.scores-row{display:flex;gap:8px;width:100%;margin-bottom:10px;}
.score-card{flex:1;border-radius:14px;padding:11px 13px;background:var(--surface);border:1.5px solid var(--border);transition:all .35s;}
.score-card.active{background:rgba(94,207,190,.06);border-color:rgba(94,207,190,.3);box-shadow:0 0 16px rgba(94,207,190,.07);}
.score-card.active-pink{background:rgba(217,127,196,.06);border-color:rgba(217,127,196,.3);box-shadow:0 0 16px rgba(217,127,196,.07);}
.sc-team{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text3);margin-bottom:2px;}
.sc-score{font-family:'Space Mono',monospace;font-size:30px;font-weight:700;line-height:1;color:var(--text2);}
.score-card.active .sc-score{color:var(--accent);}
.score-card.active-pink .sc-score{color:var(--accent2);}

.concept-bar{width:100%;display:flex;align-items:center;gap:10px;margin-bottom:8px;
  background:var(--surface);border:1.5px solid var(--border);border-radius:14px;padding:13px 16px;
  position:relative;overflow:hidden;}
.concept-bar::before{content:'';position:absolute;inset:0;pointer-events:none;
  background:linear-gradient(90deg,rgba(210,120,110,.05),transparent 38%,transparent 62%,rgba(100,140,210,.05));}
.concept-word{font-family:'Space Mono',monospace;font-size:15px;font-weight:700;flex:1;}
.concept-left{color:#c98a82;text-align:left;}
.concept-right{color:#7ea8cc;text-align:right;}
.concept-sep{color:var(--text3);font-size:16px;flex-shrink:0;}

.dial-wrap{width:100%;margin:2px 0 4px;}
#dialCanvas{width:100%;display:block;cursor:pointer;touch-action:none;border-radius:16px 16px 4px 4px;}

.phase-strip{width:100%;background:var(--surface);border:1.5px solid var(--border);
  border-radius:12px;padding:8px 16px;font-size:12px;font-weight:700;
  color:var(--text3);text-align:center;margin-bottom:4px;}
.phase-strip span{color:var(--accent);}
.phase-strip span.pink{color:var(--accent2);}

.clue-box{width:100%;background:rgba(94,207,190,.04);border:1.5px solid rgba(94,207,190,.16);
  border-radius:14px;padding:13px 15px;display:flex;flex-direction:column;gap:7px;transition:all .3s;}
.clue-box.pink-mode{background:rgba(217,127,196,.04);border-color:rgba(217,127,196,.16);}
.clue-label{font-size:9px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--accent);opacity:.8;}
.clue-box.pink-mode .clue-label{color:var(--accent2);}
.clue-input{background:rgba(255,255,255,.04);border:1.5px solid rgba(255,255,255,.08);
  border-radius:10px;padding:10px 14px;color:var(--text);font-family:'Syne',sans-serif;
  font-size:15px;font-weight:600;outline:none;width:100%;transition:border-color .2s;}
.clue-input:focus{border-color:rgba(94,207,190,.38);}
.clue-display{font-family:'Space Mono',monospace;font-size:22px;font-weight:700;
  text-align:center;letter-spacing:1px;padding:3px 0;}

.result-banner{width:100%;border-radius:13px;padding:13px 18px;text-align:center;
  font-family:'Space Mono',monospace;font-size:13px;font-weight:700;letter-spacing:1px;
  animation:bannerIn .4s cubic-bezier(.175,.885,.32,1.275);}
@keyframes bannerIn{from{opacity:0;transform:scale(.9)}to{opacity:1;transform:scale(1)}}
.res-4{background:rgba(94,207,190,.14);border:1.5px solid rgba(94,207,190,.38);color:#7dd9c9;}
.res-3{background:rgba(120,200,140,.12);border:1.5px solid rgba(120,200,140,.3);color:#8ecba2;}
.res-2{background:rgba(210,190,80,.1);border:1.5px solid rgba(210,190,80,.28);color:#c4b060;}
.res-1{background:rgba(210,145,75,.1);border:1.5px solid rgba(210,145,75,.25);color:#c0885a;}
.res-0{background:rgba(200,90,90,.1);border:1.5px solid rgba(200,90,90,.24);color:#c07070;}

.game-actions{display:flex;gap:8px;width:100%;margin-top:4px;}

/* ── RESULT ── */
#result-screen{text-align:center;gap:14px;}
.winner-badge{font-size:68px;animation:floatLogo 2s ease-in-out infinite;}
.winner-title{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--text3);}
.winner-name{font-family:'Space Mono',monospace;font-size:clamp(26px,7vw,40px);font-weight:700;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:4px 0 14px;}
.final-scores{width:100%;display:flex;flex-direction:column;gap:8px;}
.fs-row{display:flex;align-items:center;justify-content:space-between;
  background:var(--surface);border:1.5px solid var(--border);border-radius:13px;padding:13px 17px;}
.fs-row.winner-row{background:rgba(94,207,190,.07);border-color:rgba(94,207,190,.26);}
.fs-name{font-weight:700;font-size:14px;}
.fs-score{font-family:'Space Mono',monospace;font-size:22px;font-weight:700;}

/* ── MODALS ── */
.modal-overlay{display:none;position:fixed;inset:0;z-index:500;
  background:rgba(4,6,18,.8);backdrop-filter:blur(8px);
  align-items:flex-end;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal-sheet{width:100%;max-width:480px;background:var(--bg2);
  border:1.5px solid var(--border2);border-bottom:none;
  border-radius:22px 22px 0 0;padding:22px 22px 42px;
  display:flex;flex-direction:column;gap:14px;
  animation:sheetUp .3s cubic-bezier(.25,.8,.25,1);}
@keyframes sheetUp{from{transform:translateY(100%);opacity:0}to{transform:translateY(0);opacity:1}}
.modal-handle{width:36px;height:4px;border-radius:2px;background:var(--border2);align-self:center;margin-bottom:2px;}
.modal-title{font-family:'Space Mono',monospace;font-size:16px;font-weight:700;color:var(--text);letter-spacing:-.5px;}

/* UNLOCK MODAL */
.unlock-hero{text-align:center;padding:4px 0;}
.unlock-icon{font-size:56px;margin-bottom:8px;display:block;}
.unlock-name{font-family:'Space Mono',monospace;font-size:20px;font-weight:700;
  background:linear-gradient(135deg,#f0c040,#f07040);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.unlock-desc{font-size:13px;color:var(--text2);margin-top:6px;line-height:1.55;}
.unlock-features{width:100%;display:flex;flex-direction:column;gap:7px;}
.uf-row{display:flex;align-items:flex-start;gap:12px;padding:10px 14px;
  background:var(--surface);border:1px solid var(--border);border-radius:12px;}
.uf-icon{font-size:18px;flex-shrink:0;margin-top:1px;}
.uf-text{font-size:13px;color:var(--text2);line-height:1.4;}
.uf-text b{color:var(--text);}
.price-row{display:flex;align-items:center;justify-content:center;gap:10px;
  padding:12px;background:rgba(240,192,64,.06);border:1.5px solid rgba(240,192,64,.15);border-radius:14px;}
.price-main{font-family:'Space Mono',monospace;font-size:28px;font-weight:700;
  background:linear-gradient(135deg,#f0c040,#d4860a);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.price-sub{font-size:12px;color:var(--text3);}

/* HOW TO */
.how-to{width:100%;display:flex;flex-direction:column;gap:8px;}
.how-step{display:flex;align-items:flex-start;gap:12px;padding:11px 14px;
  background:var(--surface);border:1px solid var(--border);border-radius:12px;}
.how-num{font-family:'Space Mono',monospace;font-size:10px;font-weight:700;color:var(--accent);
  background:rgba(94,207,190,.09);border-radius:6px;padding:2px 7px;flex-shrink:0;margin-top:1px;}
.how-text{font-size:13px;color:var(--text2);line-height:1.55;}

/* AD */
.ad-overlay{display:none;position:fixed;inset:0;z-index:900;
  background:rgba(2,3,12,.9);backdrop-filter:blur(8px);
  align-items:center;justify-content:center;flex-direction:column;gap:0;}
.ad-overlay.open{display:flex;}
.ad-card{width:100%;max-width:380px;margin:0 16px;background:var(--surface2);
  border:1.5px solid var(--border2);border-radius:20px;overflow:hidden;}
.ad-header{display:flex;align-items:center;justify-content:space-between;
  padding:10px 14px;background:rgba(255,255,255,.03);border-bottom:1px solid var(--border);}
.ad-label{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--text3);}
.ad-skip-btn{font-family:'Space Mono',monospace;font-size:12px;font-weight:700;
  background:rgba(255,255,255,.07);border:1.5px solid rgba(255,255,255,.1);
  border-radius:8px;padding:5px 12px;color:var(--text2);cursor:pointer;transition:all .2s;min-width:90px;text-align:center;}
.ad-skip-btn.ready{background:rgba(94,207,190,.12);border-color:rgba(94,207,190,.3);color:var(--accent);cursor:pointer;}
.ad-body{padding:28px 24px;text-align:center;}
.ad-emoji{font-size:48px;margin-bottom:10px;display:block;}
.ad-title{font-family:'Space Mono',monospace;font-size:17px;font-weight:700;color:var(--text);margin-bottom:5px;}
.ad-desc{font-size:13px;color:var(--text2);line-height:1.5;margin-bottom:16px;}
.ad-cta{display:inline-block;padding:9px 20px;background:linear-gradient(135deg,#4d90d8,#2d5fa0);
  border-radius:10px;font-family:'Space Mono',monospace;font-size:12px;font-weight:700;color:#fff;}
.ad-progress{width:100%;height:3px;background:rgba(255,255,255,.06);}
.ad-progress-bar{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));width:0%;transition:width .1s linear;}
.ad-hint{font-family:'Space Mono',monospace;font-size:10px;color:var(--text3);margin-top:12px;letter-spacing:1px;}

/* FAB */
.fab-help{position:fixed;bottom:22px;right:22px;width:46px;height:46px;border-radius:50%;
  background:var(--surface2);border:1.5px solid var(--border2);color:var(--accent);
  font-family:'Space Mono',monospace;font-size:18px;font-weight:700;cursor:pointer;z-index:100;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 16px rgba(0,0,0,.3);transition:all .2s;-webkit-appearance:none;touch-action:manipulation;}
.fab-help:active{transform:scale(.92);}
#confetti{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:999;}
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}
</style>
</head>
<body>
<canvas id="confetti"></canvas>

<!-- ══ HELP MODAL ══ -->
<div class="modal-overlay" id="helpModal">
  <div class="modal-sheet">
    <div class="modal-handle"></div>
    <div class="modal-title">〰️ Nasıl Oynanır?</div>
    <div class="how-to">
      <div class="how-step"><span class="how-num">01</span>
        <div class="how-text">Bir kavram çifti belirir: <b style="color:#c98a82">Sıcak</b> ↔ <b style="color:#7ea8cc">Soğuk</b> gibi.</div></div>
      <div class="how-step"><span class="how-num">02</span>
        <div class="how-text"><b style="color:var(--accent)">İpucu veren takım</b> kadrandaki parlak hedef bölgeyi görür. Diğer takım bakamaz!</div></div>
      <div class="how-step"><span class="how-num">03</span>
        <div class="how-text">Hedef gizlenir. İpucu veren <b style="color:var(--accent)">tek kelime</b> ipucu verir.</div></div>
      <div class="how-step"><span class="how-num">04</span>
        <div class="how-text"><b style="color:var(--accent2)">Diğer takım</b> ibreyi çevirerek tahmin eder. Yakınlık = puan! 🎯</div></div>
      <div class="how-step"><span class="how-num">🏆</span>
        <div class="how-text">+4 tam isabet · +3 çok yakın · +2 yakın · +1 az kaldı. Her turda roller değişir!</div></div>
    </div>
    <button class="btn btn-primary" id="btnCloseHelp">ANLADIM ✓</button>
  </div>
</div>

<!-- ══ UNLOCK MODAL ══ -->
<div class="modal-overlay" id="unlockModal">
  <div class="modal-sheet">
    <div class="modal-handle"></div>
    <div class="unlock-hero">
      <span class="unlock-icon" id="unlockIcon">💑</span>
      <div class="unlock-name" id="unlockName">MOD ADI</div>
      <div class="unlock-desc" id="unlockDesc">Açıklama</div>
    </div>
    <div class="unlock-features" id="unlockFeatures"></div>
    <div class="price-row">
      <div><div class="price-main" id="unlockPrice">₺30</div><div class="price-sub">tek seferlik · sadece bu mod</div></div>
    </div>
    <button class="btn btn-gold" id="btnUnlockBuy">SATIN AL ⭐</button>
    <button class="btn btn-ghost" id="btnUnlockClose">Belki daha sonra</button>
  </div>
</div>

<!-- ══ AD ══ -->
<div class="ad-overlay" id="adOverlay">

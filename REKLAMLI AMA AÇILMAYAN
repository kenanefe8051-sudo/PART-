// Satın alınan modları localStorage'dan yükle
function getOwnedModes(){
  try{ return JSON.parse(localStorage.getItem('frekans_modes')||'{}'); }
  catch(e){ return {}; }
}
function saveModes(obj){ localStorage.setItem('frekans_modes', JSON.stringify(obj)); }


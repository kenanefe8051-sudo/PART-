/* ══ EKRAN GEÇİŞ ══ */
function show(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  if(id==='game') setTimeout(()=>{setupDialEvents();drawDial();},80);
}

/* ══ MOD BADGE GÜNCELLEMESİ ══ */
function refreshModeBadges(){
  ['couple','friends','family'].forEach(m=>{
    const el = document.getElementById('badge-'+m);
    const card = document.getElementById('mc-'+m);
    if(!el || !card) return;
    if(ownedModes[m]){
      el.innerHTML = '<span class="mc-owned-tag">✓ AÇIK</span>';
      card.classList.remove('mode-card-locked');
    } else {
      el.innerHTML = `<span class="mc-lock-tag">🔒 ${MODE_META[m].price}</span>`;
      card.classList.add('mode-card-locked');
    }
  });
}


/* ══ OYUN LOJİĞİ ══ */
function pickConcept(){
  const pool_all = CONCEPT_PACKS[selectedMode] || CONCEPT_PACKS.general;
  let pool = pool_all.map((_,i)=>i).filter(i=>!state.usedConcepts.includes(i));
  if(!pool.length){ state.usedConcepts=[]; pool=pool_all.map((_,i)=>i); }
  const idx = pool[Math.floor(Math.random()*pool.length)];
  state.usedConcepts.push(idx);
  return pool_all[idx];
}

function newRound(){
  state.concept=pickConcept(); state.targetAngle=15+Math.random()*150;
  state.needleAngle=90; state.clue=''; state.phase='reveal'; renderGame();
}

function renderGame(){
  const t=state.teams, ct=state.clueTeam, gt=state.guessTeam;
  document.getElementById('roundBadge').textContent=`TUR ${state.round} / ${state.totalRounds}`;
  ['sc0','sc1'].forEach((id,i)=>{
    const el=document.getElementById(id);
    const active=(state.phase==='guess'||state.phase==='result')?gt:ct;
    el.className='score-card'+(i===active?(i===0?' active':' active-pink'):'');
    document.getElementById('scName'+i).textContent=t[i].name.toUpperCase();
    document.getElementById('scScore'+i).textContent=t[i].score;
  });
  document.getElementById('conceptLeft').textContent=state.concept[0];
  document.getElementById('conceptRight').textContent=state.concept[1];
  const pl=document.getElementById('phaseLabel');
  if(state.phase==='reveal'){pl.className=ct===0?'':'pink';pl.textContent=`${t[ct].name} hedefi görüyor`;}
  else if(state.phase==='clue'){pl.className=ct===0?'':'pink';pl.textContent=`${t[ct].name} — İpucu Veriyor`;}
  else if(state.phase==='guess'){pl.className=gt===0?'':'pink';pl.textContent=`${t[gt].name} — Tahmin Ediyor`;}
  else{pl.className='';pl.textContent='Sonuç!';}
  const box=document.getElementById('clueBox');
  const inp=document.getElementById('clueInput');
  const lbl=document.getElementById('clueBoxLabel');
  box.querySelectorAll('.clue-display,.reveal-info').forEach(e=>e.remove());
  if(state.phase==='reveal'){
    box.className='clue-box'+(ct===0?'':' pink-mode');box.style.display='flex';
    lbl.textContent='HEDEFİ GÖR — İPUCU HAZIRLA';inp.style.display='none';
    const d=document.createElement('div');d.className='reveal-info';
    d.style.cssText='font-size:13px;color:rgba(218,234,234,.5);line-height:1.65;text-align:center;padding:3px 0;';
    d.innerHTML=`Parlak bölge <b style="color:var(--accent)">hedef alandır</b>.<br>Diğer takım bakmasın!<br><span style="color:${ct===0?'var(--accent)':'var(--accent2)'};">${state.concept[0]} ↔ ${state.concept[1]}</span>`;
    box.appendChild(d);
  } else if(state.phase==='clue'){
    box.className='clue-box'+(ct===0?'':' pink-mode');box.style.display='flex';
    lbl.textContent='İPUCUNU YAZ (1 KELİME)';inp.style.display='block';
    inp.value=state.clue;inp.disabled=false;setTimeout(()=>inp.focus(),100);
  } else if(state.phase==='guess'){
    box.className='clue-box'+(gt===0?'':' pink-mode');box.style.display='flex';
    lbl.textContent='VERİLEN İPUCU';inp.style.display='none';
    const d=document.createElement('div');d.className='clue-display';
    d.textContent=state.clue||'—';d.style.color=gt===0?'var(--accent)':'var(--accent2)';box.appendChild(d);
  } else {
    box.style.display='none';
  }
  if(state.phase!=='result') document.getElementById('resultBanner').style.display='none';
  const btn=document.getElementById('btnAction');
  btn.style.flex='1';btn.style.fontSize='13px';
  if(state.phase==='reveal'){btn.textContent='HAZIR — İPUCU GİR →';btn.className='btn btn-sm'+(ct===0?' btn-primary':' btn-pink');}
  else if(state.phase==='clue'){btn.textContent='İPUCU KİLİTLE 🔒';btn.className='btn btn-sm'+(ct===0?' btn-primary':' btn-pink');}
  else if(state.phase==='guess'){btn.textContent='TAHMİN ET ✓';btn.className='btn btn-sm'+(gt===0?' btn-primary':' btn-pink');}
  else{btn.textContent=state.round>=state.totalRounds?'OYUNU BİTİR 🏁':'SONRAKİ TUR →';btn.className='btn btn-primary btn-sm';}
  drawDial();
}

document.getElementById('btnAction').addEventListener('click',handleAction);
document.getElementById('clueInput').addEventListener('keydown',e=>{if(e.key==='Enter')handleAction();});

function handleAction(){
  if(state.phase==='reveal'){state.phase='clue';renderGame();}
  else if(state.phase==='clue'){
    const v=document.getElementById('clueInput').value.trim();
    if(!v){const i=document.getElementById('clueInput');i.style.borderColor='rgba(217,127,196,.45)';i.placeholder='Bir kelime yaz!';setTimeout(()=>{i.style.borderColor='';i.placeholder='Kelime ipucu...';},1000);return;}
    state.clue=v;state.needleAngle=90;state.phase='guess';renderGame();
  } else if(state.phase==='guess'){
    state.phase='result';
    const diff=Math.abs(state.needleAngle-state.targetAngle);
    let pts=0;
    if(diff<=4)pts=4;else if(diff<=9)pts=3;else if(diff<=16)pts=2;else if(diff<=24)pts=1;
    state.teams[state.guessTeam].score+=pts;renderGame();
    const bn=document.getElementById('resultBanner');bn.style.display='block';
    bn.textContent={4:'🎯 TAM 12! +4 PUAN',3:'✦ ÇOK YAKIN! +3 PUAN',2:'~ YAKIN! +2 PUAN',1:'△ AZ KALDI! +1 PUAN',0:'✕ ISKALADIN! 0 PUAN'}[pts];
    bn.className='result-banner res-'+pts;
    if(pts>=3){playSuccess();launchConfetti();}else if(pts===0)playFail();else playOk();
    drawDial();
  } else {
    if(state.round>=state.totalRounds){ showAd(()=>showResult()); }
    else{
      const shouldAd=(state.round%3===0);
      state.round++;const tmp=state.clueTeam;state.clueTeam=state.guessTeam;state.guessTeam=tmp;
      if(shouldAd){ showAd(()=>newRound()); } else { newRound(); }
    }
  }
}

function showResult(){
  const sorted=[...state.teams].sort((a,b)=>b.score-a.score);
  const isDraw=state.teams[0].score===state.teams[1].score;
  document.getElementById('winnerEmoji').textContent=isDraw?'🤝':'🏆';
  document.getElementById('winnerName').textContent=isDraw?'BERABERE!':sorted[0].name.toUpperCase();
  document.getElementById('finalScores').innerHTML=sorted.map((t,i)=>`
    <div class="fs-row ${i===0&&!isDraw?'winner-row':''}">
      <span class="fs-name">${t.name}</span>
      <span class="fs-score" style="color:${i===0&&!isDraw?'var(--accent)':'var(--text3)'}">${t.score}</span>
    </div>`).join('');
  show('result-screen');setTimeout(()=>launchConfetti(),200);
}


<script>
/* ══════ VERİ ══════ */
const CONCEPTS=[
  ["Sıcak","Soğuk"],["Hızlı","Yavaş"],["Büyük","Küçük"],["Eski","Yeni"],
  ["Güzel","Çirkin"],["Pahalı","Ucuz"],["Akıllı","Aptal"],["Güçlü","Zayıf"],
  ["Mutlu","Üzgün"],["Tehlikeli","Güvenli"],["Kolay","Zor"],["Popüler","Yalnız"],
  ["Sessiz","Gürültülü"],["Temiz","Kirli"],["Tatlı","Acı"],["Genç","Yaşlı"],
  ["Yumuşak","Sert"],["Aydınlık","Karanlık"],["Heyecanlı","Sıkıcı"],["Doğal","Yapay"],
  ["Romantik","Soğuk"],["Komik","Ciddi"],["Lüks","Mütevazı"],["Egzotik","Sıradan"],
  ["Cesur","Korkak"],["Eğlenceli","Sıkıcı"],["Zarif","Kaba"],["İnanılmaz","Sıradan"],
  ["Nadir","Yaygın"],["Masum","Suçlu"],["Özgür","Bağımlı"],["Enerjik","Yorgun"],
  ["Şanslı","Şanssız"],["Sakin","Stresli"],["Renkli","Donuk"],["Antik","Modern"],
  ["Hafif","Ağır"],["Mükemmel","Berbat"],["Yaratıcı","Sıradan"],["Büyülü","Sıradan"],
  ["Tehlikeli","Masum"],["Saf","Karmaşık"],["Açık","Kapalı"],["İddialı","Mütevazı"],
  ["Gizemli","Açık"],["Pratik","Romantik"],["Efsanevi","Unutulmuş"],["Maceracı","Yerinde"],
  ["Korkutucu","Güven verici"],["Çılgın","Mantıklı"],["Sofistike","Kaba"],["Huzurlu","Kaotik"],
  ["Yenilikçi","Geleneksel"],["Sıradan","Eşsiz"],["Şeffaf","Gizemli"],["Sonsuz","Sınırlı"],
];

/* Simüle reklam içerikleri — gerçek uygulamada AdMob SDK ile değiştirilir */
const ADS=[
  {emoji:'🍕',title:'Lezzetli Pizza',desc:'Şehrin en iyi pizzası kapınıza gelsin. İlk siparişe %20 indirim!',cta:'Hemen Sipariş Ver'},
  {emoji:'📱',title:'Yeni Uygulama',desc:'Arkadaşlarınla bağlı kal. Ücretsiz indir, eğlenceli oyna!',cta:'Ücretsiz İndir'},
  {emoji:'☕',title:'Kahve Molası',desc:'Günün yorgunluğunu at. En iyi kahveler, en iyi fiyatlarla.',cta:'Keşfet'},
  {emoji:'🎵',title:'Müzik Platformu',desc:'60 milyon şarkı, reklamız. 3 ay ücretsiz dene!',cta:'Ücretsiz Dene'},
  {emoji:'🏋️',title:'Spor Salonu',desc:'Yeni yıl kararın sporla başlasın. İlk ay ücretsiz!',cta:'Üye Ol'},
];

/* ══════ PREMIUM / REKLAM DURUMU ══════ */
let isPremium = localStorage.getItem('frekans_premium') === 'true';
let adTimer = null, adSkipEnabled = false, adCallback = null;
const AD_DURATION = 30; // saniye
const AD_SKIP_AFTER = 5; // saniye

function updatePremiumBadge(){
  const badge = document.getElementById('splashPremiumBadge');
  const txt = document.getElementById('splashPremiumText');
  if(isPremium){
    badge.className = 'premium-badge owned';
    txt.textContent = '✓ Pro — Reklamlar Kaldırıldı';
  } else {
    badge.className = 'premium-badge';
    txt.textContent = 'Reklamsız Pro — ₺50';
  }
}

/* ══════ REKLAM SİSTEMİ ══════ */
function showAd(callback){
  if(isPremium){ callback(); return; } // Premium ise reklam gösterme

  adCallback = callback;
  adSkipEnabled = false;

  const ad = ADS[Math.floor(Math.random() * ADS.length)];
  document.getElementById('adEmoji').textContent = ad.emoji;
  document.getElementById('adTitle').textContent = ad.title;
  document.getElementById('adDesc').textContent = ad.desc;
  document.getElementById('adCta').textContent = ad.cta;
  document.getElementById('adProgressBar').style.width = '0%';
  document.getElementById('adSkipBtn').textContent = `${AD_SKIP_AFTER}s bekle...`;
  document.getElementById('adSkipBtn').className = 'ad-skip-btn';

  document.getElementById('adOverlay').classList.add('open');

  let elapsed = 0;
  const interval = 100; // ms
  clearInterval(adTimer);
  adTimer = setInterval(()=>{
    elapsed += interval;
    const pct = Math.min((elapsed / (AD_DURATION * 1000)) * 100, 100);
    document.getElementById('adProgressBar').style.width = pct + '%';
    const secsLeft = Math.ceil((AD_SKIP_AFTER * 1000 - elapsed) / 1000);
    if(elapsed >= AD_SKIP_AFTER * 1000 && !adSkipEnabled){
      adSkipEnabled = true;
      document.getElementById('adSkipBtn').textContent = 'Geç ⟩⟩';
      document.getElementById('adSkipBtn').className = 'ad-skip-btn ready';
    } else if(!adSkipEnabled){
      document.getElementById('adSkipBtn').textContent = `${secsLeft}s bekle...`;
    }
    if(elapsed >= AD_DURATION * 1000){
      clearInterval(adTimer);
      closeAd();
    }
  }, interval);
}

function closeAd(){
  clearInterval(adTimer);
  document.getElementById('adOverlay').classList.remove('open');
  if(adCallback){ adCallback(); adCallback = null; }
}

document.getElementById('adSkipBtn').addEventListener('click',()=>{
  if(adSkipEnabled) closeAd();
});

/* ══════ PREMIUM MODAL ══════ */
document.getElementById('splashPremiumBadge').addEventListener('click',()=>{
  document.getElementById('premiumModal').classList.add('open');
});
document.getElementById('btnClosePremium').addEventListener('click',()=>{
  document.getElementById('premiumModal').classList.remove('open');
});
document.getElementById('premiumModal').addEventListener('click',e=>{
  if(e.target===document.getElementById('premiumModal'))
    document.getElementById('premiumModal').classList.remove('open');
});
document.getElementById('btnBuyPremium').addEventListener('click',()=>{
  // Gerçek uygulamada burada Google Play / App Store ödeme API'si çağrılır
  // Simülasyon için onay kutusu:
  if(confirm('₺50 Frekans Pro satın alınacak. Onaylıyor musunuz?\n\n(Bu bir simülasyondur — gerçek ödeme alınmayacak)')){
    isPremium = true;
    localStorage.setItem('frekans_premium','true');
    updatePremiumBadge();
    document.getElementById('premiumModal').classList.remove('open');
    setTimeout(()=>alert('⭐ Frekans Pro aktif! Reklamlar kaldırıldı. Teşekkürler!'),200);
  }
});
document.getElementById('btnRestorePurchase').addEventListener('click',()=>{
  // Gerçek uygulamada Google Play restore API çağrısı yapılır
  const restored = localStorage.getItem('frekans_premium') === 'true';
  if(restored){
    isPremium = true;
    updatePremiumBadge();
    document.getElementById('premiumModal').classList.remove('open');
    alert('✓ Satın alma geri yüklendi!');
  } else {
    alert('Geri yüklenecek bir satın alma bulunamadı.');
  }
});

/* ══════ HELP MODAL ══════ */
document.getElementById('btnHelp').addEventListener('click',()=>document.getElementById('helpModal').classList.add('open'));
document.getElementById('btnCloseHelp').addEventListener('click',()=>document.getElementById('helpModal').classList.remove('open'));
document.getElementById('helpModal').addEventListener('click',e=>{if(e.target===document.getElementById('helpModal'))document.getElementById('helpModal').classList.remove('open');});

/* ══════ SETUP ══════ */
let selectedRounds = 10;
document.querySelectorAll('[data-rounds]').forEach(btn=>{
  btn.addEventListener('click',()=>{
    selectedRounds = parseInt(btn.dataset.rounds);
    document.querySelectorAll('[data-rounds]').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
  });
});

/* ══════ STATE ══════ */
let state={
  teams:[{name:'Takım 1',score:0},{name:'Takım 2',score:0}],
  clueTeam:0,guessTeam:1,round:1,totalRounds:10,
  targetAngle:90,needleAngle:90,concept:null,clue:'',
  phase:'reveal',usedConcepts:[],dragging:false,
};

function show(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  if(id==='game') setTimeout(()=>{setupDialEvents();drawDial();},80);
}

/* ══════ NAVİGASYON ══════ */
document.getElementById('btnGoSetup').addEventListener('click',()=>show('setup'));
document.getElementById('btnSetupBack').addEventListener('click',()=>show('splash'));
document.getElementById('btnGameHome').addEventListener('click',()=>{if(confirm('Oyundan çıkmak istiyor musun?'))show('splash');});
document.getElementById('btnGameBack2').addEventListener('click',()=>show('setup'));
document.getElementById('btnPlayAgain').addEventListener('click',()=>show('setup'));
document.getElementById('btnResultHome').addEventListener('click',()=>show('splash'));

document.getElementById('btnStartGame').addEventListener('click',()=>{
  const t1=document.getElementById('team1Input').value.trim()||'Takım 1';
  const t2=document.getElementById('team2Input').value.trim()||'Takım 2';
  state.teams=[{name:t1,score:0},{name:t2,score:0}];
  state.clueTeam=0;state.guessTeam=1;state.round=1;
  state.totalRounds=selectedRounds;state.usedConcepts=[];
  newRound();show('game');
});

/* ══════ OYUN LOJİĞİ ══════ */
function pickConcept(){
  let pool=CONCEPTS.map((_,i)=>i).filter(i=>!state.usedConcepts.includes(i));
  if(!pool.length){state.usedConcepts=[];pool=CONCEPTS.map((_,i)=>i);}
  const idx=pool[Math.floor(Math.random()*pool.length)];
  state.usedConcepts.push(idx);return CONCEPTS[idx];
}
function newRound(){
  state.concept=pickConcept();state.targetAngle=15+Math.random()*150;
  state.needleAngle=90;state.clue='';state.phase='reveal';renderGame();
}

function renderGame(){
  const t=state.teams,ct=state.clueTeam,gt=state.guessTeam;
  document.getElementById('roundBadge').textContent=`TUR ${state.round} / ${state.totalRounds}`;
  ['sc0','sc1'].forEach((id,i)=>{
    const el=document.getElementById(id);
    const active=(state.phase==='guess'||state.phase==='result')?gt:ct;
    el.className='score-card'+(i===active?(i===0?' active':' active-pink'):'');
    document.getElementById('scName'+i).textContent=t[i].name.toUpperCase();
    document.getElementById('scScore'+i).textContent=t[i].score;
  });
  document.getElementById('conceptLeft').textContent=state.concept[0];
  document.getElementById('conceptRight').textContent=state.concept[1];
  const pl=document.getElementById('phaseLabel');
  if(state.phase==='reveal'){pl.className=ct===0?'':'pink';pl.textContent=`${t[ct].name} hedefi görüyor`;}
  else if(state.phase==='clue'){pl.className=ct===0?'':'pink';pl.textContent=`${t[ct].name} — İpucu Veriyor`;}
  else if(state.phase==='guess'){pl.className=gt===0?'':'pink';pl.textContent=`${t[gt].name} — Tahmin Ediyor`;}
  else{pl.className='';pl.textContent='Sonuç!';}
  const box=document.getElementById('clueBox');
  const inp=document.getElementById('clueInput');
  const lbl=document.getElementById('clueBoxLabel');
  box.querySelectorAll('.clue-display,.reveal-info').forEach(e=>e.remove());
  if(state.phase==='reveal'){
    box.className='clue-box'+(ct===0?'':' pink-mode');box.style.display='flex';
    lbl.textContent='HEDEFİ GÖR — İPUCU HAZIRLA';inp.style.display='none';
    const d=document.createElement('div');d.className='reveal-info';
    d.style.cssText='font-size:13px;color:rgba(218,234,234,.5);line-height:1.65;text-align:center;padding:3px 0;';
    d.innerHTML=`Parlak bölge <b style="color:var(--accent)">hedef alandır</b>.<br>Diğer takım bakmasın!<br><span style="color:${ct===0?'var(--accent)':'var(--accent2)'};">${state.concept[0]} ↔ ${state.concept[1]}</span>`;
    box.appendChild(d);
  } else if(state.phase==='clue'){
    box.className='clue-box'+(ct===0?'':' pink-mode');box.style.display='flex';
    lbl.textContent='İPUCUNU YAZ (1 KELİME)';inp.style.display='block';
    inp.value=state.clue;inp.disabled=false;setTimeout(()=>inp.focus(),100);
  } else if(state.phase==='guess'){
    box.className='clue-box'+(gt===0?'':' pink-mode');box.style.display='flex';
    lbl.textContent='VERİLEN İPUCU';inp.style.display='none';
    const d=document.createElement('div');d.className='clue-display';
    d.textContent=state.clue||'—';d.style.color=gt===0?'var(--accent)':'var(--accent2)';box.appendChild(d);
  } else {
    box.style.display='none';
  }
  if(state.phase!=='result') document.getElementById('resultBanner').style.display='none';
  const btn=document.getElementById('btnAction');
  btn.style.flex='1';btn.style.fontSize='13px';
  if(state.phase==='reveal'){btn.textContent='HAZIR — İPUCU GİR →';btn.className='btn btn-sm'+(ct===0?' btn-primary':' btn-pink');}
  else if(state.phase==='clue'){btn.textContent='İPUCU KİLİTLE 🔒';btn.className='btn btn-sm'+(ct===0?' btn-primary':' btn-pink');}
  else if(state.phase==='guess'){btn.textContent='TAHMİN ET ✓';btn.className='btn btn-sm'+(gt===0?' btn-primary':' btn-pink');}
  else{btn.textContent=state.round>=state.totalRounds?'OYUNU BİTİR 🏁':'SONRAKİ TUR →';btn.className='btn btn-primary btn-sm';}
  drawDial();
}

document.getElementById('btnAction').addEventListener('click',handleAction);
document.getElementById('clueInput').addEventListener('keydown',e=>{if(e.key==='Enter')handleAction();});

function handleAction(){
  if(state.phase==='reveal'){
    state.phase='clue';renderGame();
  } else if(state.phase==='clue'){
    const v=document.getElementById('clueInput').value.trim();
    if(!v){
      const i=document.getElementById('clueInput');
      i.style.borderColor='rgba(217,127,196,.45)';i.placeholder='Bir kelime yaz!';
      setTimeout(()=>{i.style.borderColor='';i.placeholder='Kelime ipucu...';},1000);return;
    }
    state.clue=v;state.needleAngle=90;state.phase='guess';renderGame();
  } else if(state.phase==='guess'){
    state.phase='result';
    const diff=Math.abs(state.needleAngle-state.targetAngle);
    let pts=0;
    if(diff<=4)pts=4;else if(diff<=9)pts=3;else if(diff<=16)pts=2;else if(diff<=24)pts=1;
    state.teams[state.guessTeam].score+=pts;renderGame();
    const bn=document.getElementById('resultBanner');bn.style.display='block';
    bn.textContent={4:'🎯 TAM 12! +4 PUAN',3:'✦ ÇOK YAKIN! +3 PUAN',2:'~ YAKIN! +2 PUAN',1:'△ AZ KALDI! +1 PUAN',0:'✕ ISKALADIN! 0 PUAN'}[pts];
    bn.className='result-banner res-'+pts;
    if(pts>=3){playSuccess();launchConfetti();}else if(pts===0)playFail();else playOk();
    drawDial();
  } else {
    // Sonraki tur veya oyun bitiş — reklam göster
    if(state.round>=state.totalRounds){
      // Oyun bitmeden önce reklam
      showAd(()=>showResult());
    } else {
      // Tur arası reklam (her tur değil — örneğin her 3 turda bir)
      const shouldShowAd = (state.round % 3 === 0);
      state.round++;
      const tmp=state.clueTeam;state.clueTeam=state.guessTeam;state.guessTeam=tmp;
      if(shouldShowAd){
        showAd(()=>newRound());
      } else {
        newRound();
      }
    }
  }
}

function showResult(){
  const sorted=[...state.teams].sort((a,b)=>b.score-a.score);
  const isDraw=state.teams[0].score===state.teams[1].score;
  document.getElementById('winnerEmoji').textContent=isDraw?'🤝':'🏆';
  document.getElementById('winnerName').textContent=isDraw?'BERABERE!':sorted[0].name.toUpperCase();
  document.getElementById('finalScores').innerHTML=sorted.map((t,i)=>`
    <div class="fs-row ${i===0&&!isDraw?'winner-row':''}">
      <span class="fs-name">${t.name}</span>
      <span class="fs-score" style="color:${i===0&&!isDraw?'var(--accent)':'var(--text3)'}">${t.score}</span>
    </div>`).join('');
  show('result-screen');setTimeout(()=>launchConfetti(),200);
}

/* ══════ KADRAN ══════ */
function drawDial(){
  const cv=document.getElementById('dialCanvas');
  const W=cv.offsetWidth||420;cv.width=W;cv.height=170;
  const ctx=cv.getContext('2d');ctx.clearRect(0,0,W,170);
  const cx=W/2,cy=162,r=148;
  ctx.beginPath();ctx.arc(cx,cy,r,Math.PI,2*Math.PI);
  ctx.strokeStyle='rgba(255,255,255,.04)';ctx.lineWidth=30;ctx.stroke();
  const gr=ctx.createLinearGradient(0,0,W,0);
  gr.addColorStop(0,'rgba(200,115,105,.1)');gr.addColorStop(.5,'rgba(94,207,190,.05)');gr.addColorStop(1,'rgba(105,135,200,.1)');
  ctx.beginPath();ctx.arc(cx,cy,r,Math.PI,2*Math.PI);ctx.strokeStyle=gr;ctx.lineWidth=30;ctx.stroke();
  if(state.phase==='reveal'||state.phase==='result'){
    [{s:50,c:'rgba(200,145,75,.16)'},{s:32,c:'rgba(200,180,75,.22)'},{s:18,c:'rgba(94,207,190,.32)'},{s:8,c:'rgba(94,207,190,.7)'}].forEach(z=>{
      const a1=Math.PI+(state.targetAngle-z.s/2)/180*Math.PI;
      const a2=Math.PI+(state.targetAngle+z.s/2)/180*Math.PI;
      ctx.beginPath();ctx.arc(cx,cy,r,a1,a2);ctx.strokeStyle=z.c;ctx.lineWidth=30;ctx.stroke();
    });
    const ta=Math.PI+state.targetAngle/180*Math.PI;
    ctx.beginPath();ctx.moveTo(cx+Math.cos(ta)*(r-20),cy+Math.sin(ta)*(r-20));
    ctx.lineTo(cx+Math.cos(ta)*(r+5),cy+Math.sin(ta)*(r+5));
    ctx.strokeStyle='rgba(255,255,255,.5)';ctx.lineWidth=2.5;ctx.lineCap='round';ctx.stroke();
    ctx.beginPath();ctx.arc(cx+Math.cos(ta)*r,cy+Math.sin(ta)*r,8,0,2*Math.PI);
    ctx.fillStyle='rgba(255,255,255,.2)';ctx.shadowColor='rgba(94,207,190,.5)';ctx.shadowBlur=12;ctx.fill();ctx.shadowBlur=0;
    if(state.phase==='reveal'){
      ctx.font='bold 9px "Space Mono",monospace';ctx.fillStyle='rgba(94,207,190,.7)';ctx.textAlign='center';
      ctx.fillText('HEDEF',cx+Math.cos(ta)*(r-50),cy+Math.sin(ta)*(r-50));
    }
  }
  for(let i=0;i<=18;i++){
    const a=Math.PI+(i/18)*Math.PI,len=i%3===0?13:6,ro=r+18;
    ctx.beginPath();ctx.moveTo(cx+Math.cos(a)*ro,cy+Math.sin(a)*ro);
    ctx.lineTo(cx+Math.cos(a)*(ro-len),cy+Math.sin(a)*(ro-len));
    ctx.strokeStyle=i%3===0?'rgba(255,255,255,.14)':'rgba(255,255,255,.05)';ctx.lineWidth=i%3===0?1.5:1;ctx.stroke();
  }
  if(state.phase==='guess'||state.phase==='result'){
    const na=Math.PI+state.needleAngle/180*Math.PI;
    const nc=state.guessTeam===0?'#5ecfbe':'#d97fc4';
    ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(cx+Math.cos(na)*(r+12),cy+Math.sin(na)*(r+12));
    ctx.shadowColor=nc;ctx.shadowBlur=state.phase==='guess'?10:4;
    ctx.strokeStyle=nc;ctx.lineWidth=3.5;ctx.lineCap='round';ctx.stroke();ctx.shadowBlur=0;
    ctx.beginPath();ctx.arc(cx,cy,9,0,2*Math.PI);ctx.fillStyle=nc;
    ctx.shadowColor=nc;ctx.shadowBlur=state.phase==='guess'?14:4;ctx.fill();ctx.shadowBlur=0;
    if(state.phase==='guess'){
      ctx.font='bold 10px "Space Mono",monospace';ctx.fillStyle='rgba(218,234,234,.32)';ctx.textAlign='center';
      ctx.fillText(Math.round(state.needleAngle)+'°',cx,cy-14);
    }
  } else {
    ctx.beginPath();ctx.arc(cx,cy,7,0,2*Math.PI);ctx.fillStyle='rgba(255,255,255,.07)';ctx.fill();
    ctx.beginPath();ctx.arc(cx,cy,3,0,2*Math.PI);ctx.fillStyle='rgba(255,255,255,.16)';ctx.fill();
  }
}

function setupDialEvents(){
  const cv=document.getElementById('dialCanvas');
  cv.removeEventListener('mousedown',onDown);cv.removeEventListener('touchstart',onTouchStart);
  cv.addEventListener('mousedown',onDown);cv.addEventListener('touchstart',onTouchStart,{passive:false});
}
function getAngle(e,cv){
  const rc=cv.getBoundingClientRect();
  const x=(e.touches?e.touches[0].clientX:e.clientX)-rc.left-rc.width/2;
  const y=(e.touches?e.touches[0].clientY:e.clientY)-rc.top-162;
  let a=Math.atan2(y,x)*180/Math.PI-180;if(a<0)a+=360;return Math.max(0,Math.min(180,a));
}
function onDown(e){if(state.phase!=='guess')return;state.dragging=true;state.needleAngle=getAngle(e,e.currentTarget);drawDial();document.addEventListener('mousemove',onMove);document.addEventListener('mouseup',onUp);}
function onMove(e){if(!state.dragging||state.phase!=='guess')return;e.preventDefault();state.needleAngle=getAngle(e,document.getElementById('dialCanvas'));drawDial();}
function onUp(){state.dragging=false;document.removeEventListener('mousemove',onMove);document.removeEventListener('mouseup',onUp);}
function onTouchStart(e){if(state.phase!=='guess')return;e.preventDefault();state.needleAngle=getAngle(e,e.currentTarget);drawDial();e.currentTarget.addEventListener('touchmove',onTouchMove,{passive:false});e.currentTarget.addEventListener('touchend',onTouchEnd);}
function onTouchMove(e){if(state.phase!=='guess')return;e.preventDefault();state.needleAngle=getAngle(e,e.currentTarget);drawDial();}
function onTouchEnd(e){e.currentTarget.removeEventListener('touchmove',onTouchMove);e.currentTarget.removeEventListener('touchend',onTouchEnd);}

/* ══════ SES ══════ */
let AC;
function ac(){if(!AC)AC=new(window.AudioContext||window.webkitAudioContext)();if(AC.state==='suspended')AC.resume();return AC;}
function playSuccess(){const c=ac();[523,659,784,1047].forEach((f,i)=>{const o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.type='sine';o.frequency.value=f;const t=c.currentTime+i*.09;g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(.17,t+.02);g.gain.exponentialRampToValueAtTime(.001,t+.22);o.start(t);o.stop(t+.22);});}
function playOk(){const c=ac();[440,550].forEach((f,i)=>{const o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.type='sine';o.frequency.value=f;const t=c.currentTime+i*.1;g.gain.setValueAtTime(.12,t);g.gain.exponentialRampToValueAtTime(.001,t+.2);o.start(t);o.stop(t+.2);});}
function playFail(){const c=ac();[280,220].forEach((f,i)=>{const o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.type='sawtooth';o.frequency.value=f;const t=c.currentTime+i*.13;g.gain.setValueAtTime(.13,t);g.gain.exponentialRampToValueAtTime(.001,t+.22);o.start(t);o.stop(t+.23);});}

/* ══════ KONFETİ ══════ */
const CONF_COLORS=['#5ecfbe','#d97fc4','#e8c96a','#7ea8cc','#c98a82','#b8dcd8'];
let confParts=[],confRAF;
function launchConfetti(){
  const cv=document.getElementById('confetti');
  const W=cv.width=window.innerWidth,H=cv.height=window.innerHeight;
  const ctx=cv.getContext('2d');confParts=[];
  for(let i=0;i<140;i++){const a=(Math.random()*360)*Math.PI/180,sp=3+Math.random()*6;
    confParts.push({x:W/2+(Math.random()-.5)*W*.7,y:H*.45,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-5,
      w:5+Math.random()*7,h:4+Math.random()*5,rot:Math.random()*360,rv:(Math.random()-.5)*7,
      c:CONF_COLORS[Math.floor(Math.random()*CONF_COLORS.length)],life:1});}
  cancelAnimationFrame(confRAF);
  function draw(){ctx.clearRect(0,0,W,H);let alive=false;
    confParts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.vy+=.24;p.vx*=.99;p.rot+=p.rv;p.life-=.013;
      const a=Math.max(0,p.life);if(a>0){alive=true;ctx.save();ctx.globalAlpha=a;ctx.translate(p.x,p.y);
        ctx.rotate(p.rot*Math.PI/180);ctx.fillStyle=p.c;ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);ctx.restore();}});
    if(alive)confRAF=requestAnimationFrame(draw);else ctx.clearRect(0,0,W,H);}
  draw();
}


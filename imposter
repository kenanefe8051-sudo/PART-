  const sim = similarity(guess, q.name), correct = isCorrectGuess(guess, q.name), veryClose = !correct && sim >= 0.60;
  if(correct){
    kb.solved = true; const pts = kb.triesLeft * 10 + (kb.cluesShown===1?20:kb.cluesShown===2?10:5); kb.totalScore += pts;
    playSoundCorrect(); renderKbBlanks(q.name, true);
    document.getElementById('kbResultBox').innerHTML=`<div class="kb-result-win"><div class="kb-result-title" style="color:#6bcb77">🎉 Doğru!</div><div class="kb-result-name">${q.name}</div>${sim<1&&sim>=0.80?`<div style="font-size:11px;color:rgba(255,255,255,.4);margin-top:4px;">yakın sayıldı ✓</div>`:''}<div class="kb-score-pill">+${pts} puan</div></div>`;
    document.getElementById('kbInput').disabled=true; document.getElementById('btnKbSubmit').disabled=true;
    document.getElementById('btnKbNext').style.display=''; document.getElementById('btnKbSkipQ').style.display='none'; document.getElementById('btnKbHint').style.display='none';
    document.getElementById('kbScore').textContent=kb.totalScore+' puan'; launchConfetti();
  } else {
    playSoundWrong(); kb.triesLeft--; document.getElementById('kbInput').value='';
    document.querySelectorAll('.kb-letter').forEach(l=>{ l.classList.add('wrong-flash'); setTimeout(()=>l.classList.remove('wrong-flash'),400); });
    if(kb.triesLeft<=0) kbGameOver();
    else { document.getElementById('kbTries').textContent = (kb.triesLeft===2 ? '2 hakkın kaldı' : 'Son hakkın!') + (veryClose ? ' 🔥 Çok yaklaştın!' : ''); revealLetterHint(q.name); }
  }
}
function kbGameOver(){
  kb.solved=false; kb.skipped=true; const q=kb.pool[kb.idx]; playSoundWrong(); renderKbBlanks(q.name, true);
  document.getElementById('kbResultBox').innerHTML=`<div class="kb-result-lose"><div class="kb-result-title" style="color:#ff6b6b">😔 Hakkın Bitti</div><div class="kb-result-name">Cevap: <b style="color:#ffd93d">${q.name}</b></div></div>`;
  document.getElementById('kbInput').disabled=true; document.getElementById('btnKbSubmit').disabled=true;
  document.getElementById('btnKbNext').style.display=''; document.getElementById('btnKbSkipQ').style.display='none'; document.getElementById('btnKbHint').style.display='none';
}
function kbShowHint(){ if(kb.cluesShown<kb.pool[kb.idx].clues.length){ kb.cluesShown++; renderKbClues(); } }
function kbSkip(){
  kb.skipped=true; const q=kb.pool[kb.idx]; renderKbBlanks(q.name,true);
  document.getElementById('kbResultBox').innerHTML=`<div class="kb-result-lose"><div class="kb-result-title" style="color:rgba(255,255,255,.5)">⏭ Geçildi</div><div class="kb-result-name">Cevap: <b style="color:#ffd93d">${q.name}</b></div></div>`;
  document.getElementById('kbInput').disabled=true; document.getElementById('btnKbSubmit').disabled=true;
  document.getElementById('btnKbNext').style.display=''; document.getElementById('btnKbSkipQ').style.display='none'; document.getElementById('btnKbHint').style.display='none';
}
function kbNext(){ kb.idx++; loadKbQuestion(); }
function showKimBu(){ kb.pool=[]; kb.idx=0; kb.totalScore=0; document.getElementById('kbCategoryPick').style.display='flex'; document.getElementById('kbGameWrap').style.display='none'; document.getElementById('kbScore').textContent='0 puan'; showScreen('screen-kimbu'); }

/* ══════════════ QUIZ ══════════════ */
let qz = { cat: 'foreign', seriesIdx: 0, questions: [], qIdx: 0, score: 0, answered: false, bestStreak: 0, currentStreak: 0 };
function renderQuizGrid(){
  document.getElementById('quizSeriesGrid').innerHTML = QUIZ_DATA.map((s,i)=> {
    if(s.cat !== qz.cat) return '';
    return `<button class="quiz-series-btn" data-qseries="${i}" style="background:${s.color};box-shadow:0 8px 20px ${s.shadow};">
      <div class="quiz-series-emoji">${s.emoji}</div><div class="quiz-series-name">${s.name}</div><div class="quiz-series-count">${s.questions.length} soru</div></button>`;
  }).join('');
}
function showQuiz(){
  qz.score=0; qz.qIdx=0; qz.answered=false; qz.bestStreak=0; qz.currentStreak=0; renderQuizGrid();
  document.getElementById('quizSeriesPick').style.display='flex'; document.getElementById('quizGameArea').style.display='none'; document.getElementById('quizResultArea').style.display='none'; showScreen('screen-quiz');
}
function startQuizSeries(idx){
  const series = QUIZ_DATA[idx]; qz.seriesIdx = idx; qz.questions = [...series.questions]; qz.qIdx = 0; qz.score = 0; qz.answered = false; qz.bestStreak = 0; qz.currentStreak = 0;
  document.getElementById('quizSeriesLabel').textContent = series.emoji+' '+series.name; document.getElementById('quizProgBar').style.background = series.color;
  document.getElementById('quizSeriesPick').style.display='none'; document.getElementById('quizGameArea').style.display='flex'; document.getElementById('quizResultArea').style.display='none'; loadQuizQuestion();
}
function loadQuizQuestion(){
  const q = qz.questions[qz.qIdx]; if(!q){ showQuizResult(); return; }
  qz.answered = false; const total = qz.questions.length;
  document.getElementById('quizProgBar').style.width = Math.round((qz.qIdx/total)*100)+'%'; document.getElementById('quizQNum').textContent = `Soru ${qz.qIdx+1} / ${total}`;
  document.getElementById('quizPts').textContent = qz.score+' puan'; document.getElementById('quizQText').textContent = q.q;
  document.getElementById('quizExplain').className='quiz-explain'; document.getElementById('quizExplain').textContent='';
  document.getElementById('btnQuizNext').style.display='none'; document.getElementById('btnQuizSkip').style.display='';
  const letters=['A','B','C','D'];
  document.getElementById('quizChoices').innerHTML = q.choices.map((c,i)=>`<button class="quiz-choice" data-qchoice="${i}"><div class="quiz-choice-letter">${letters[i]}</div><span>${c}</span></button>`).join('');
}
function answerQuiz(choiceIdx){
  if(qz.answered) return; qz.answered = true; const q = qz.questions[qz.qIdx], correct = (choiceIdx === q.answer);
  document.querySelectorAll('.quiz-choice').forEach((btn,i)=>{
    btn.classList.add('disabled'); if(i===q.answer) btn.classList.add('correct'); else if(i===choiceIdx && !correct) btn.classList.add('wrong');
  });
  const exp = document.getElementById('quizExplain'); exp.textContent = q.explain; exp.classList.add('show');
  if(correct){ qz.currentStreak++; if(qz.currentStreak>qz.bestStreak) qz.bestStreak=qz.currentStreak; qz.score += 10 + Math.min(qz.currentStreak-1,3)*5; document.getElementById('quizPts').textContent = qz.score+' puan'; playSoundCorrect(); }
  else { qz.currentStreak=0; playSoundWrong(); }
  document.getElementById('btnQuizNext').style.display=''; document.getElementById('btnQuizSkip').style.display='none';
}
function quizSkip(){
  if(qz.answered) return; qz.answered=true; qz.currentStreak=0; const q=qz.questions[qz.qIdx];
  document.querySelectorAll('.quiz-choice').forEach((btn,i)=>{ btn.classList.add('disabled'); if(i===q.answer) btn.classList.add('correct'); });
  const exp=document.getElementById('quizExplain'); exp.textContent=q.explain; exp.classList.add('show');
  document.getElementById('btnQuizNext').style.display=''; document.getElementById('btnQuizSkip').style.display='none'; playSoundSkip();
}
function showQuizResult(){
  document.getElementById('quizGameArea').style.display='none'; document.getElementById('quizResultArea').style.display='flex';
  const pct=qz.score/(qz.questions.length*10); let emoji='😅'; if(pct>=0.9) emoji='🏆'; else if(pct>=0.7) emoji='🎉'; else if(pct>=0.5) emoji='👍';
  document.getElementById('quizResEmoji').textContent=emoji; document.getElementById('quizResPts').textContent=qz.score;
  document.getElementById('quizResStreak').textContent=qz.bestStreak>=3 ? `🔥 En uzun seri: ${qz.bestStreak} doğru!` : '';
  if(pct>=0.7) setTimeout(()=>launchConfetti(),300);
}

/* ══════════════ O MU BU MU (OMB) ══════════════ */
let omb = { cat: 'good', mode: 'tournament', totalCount: 32, pool: [], currentMatch: [], nextPool: [], roundName: '', matchIndex: 0, matchTotal: 0, kingChamp: null };
let lastOmbColorIdx = -1;
function applyRandomOmbColors() {
  let idx = Math.floor(Math.random() * OMB_COLORS.length); while(idx === lastOmbColorIdx) idx = Math.floor(Math.random() * OMB_COLORS.length);
  lastOmbColorIdx = idx; const pair = OMB_COLORS[idx];
  document.getElementById('ombTextTop').style.background = pair.top; document.getElementById('ombTextBottom').style.background = pair.bottom;
}
function showOmbSetup(){ showScreen('screen-omb-setup'); }
function updateOmbModeHint(mode){
  omb.mode = mode; document.querySelectorAll('[data-omb-mode]').forEach(b=>b.classList.toggle('active', b.dataset.ombMode===mode));
  document.getElementById('ombModeHint').textContent = mode === 'tournament' ? "Turnuva: Eşleşerek finale çıkılır." : "Kral: Seçtiğin kalır, havuzdan yeni seçenek gelir.";
}
function startOmbGame(){
  omb.pool = getOmbPool(omb.cat, omb.totalCount); omb.nextPool = [];
  if(omb.mode === 'tournament') prepareTournamentRound();
  else { omb.kingChamp = omb.pool.pop(); omb.matchTotal = omb.totalCount - 1; omb.matchIndex = 1; loadKingMatch(); }
  showScreen('screen-omb');
}
function prepareTournamentRound(){
  omb.matchTotal = omb.pool.length / 2; omb.matchIndex = 1; const len = omb.pool.length;
  omb.roundName = len === 64 ? "SON 64" : len === 32 ? "SON 32" : len === 16 ? "SON 16" : len === 8 ? "ÇEYREK FİNAL" : len === 4 ? "YARI FİNAL" : "FİNAL 🏆";
  loadTournamentMatch();
}
function loadTournamentMatch(){
  omb.currentMatch = [omb.pool.pop(), omb.pool.pop()]; document.getElementById('ombRoundText').textContent = omb.roundName;
  document.getElementById('ombProgressText').textContent = `Maç ${omb.matchIndex} / ${omb.matchTotal}`;
  document.getElementById('ombTextTop').textContent = omb.currentMatch[0]; document.getElementById('ombTextBottom').textContent = omb.currentMatch[1]; applyRandomOmbColors();
}
function loadKingMatch(){
  let challenger = omb.pool.pop(); omb.currentMatch = [omb.kingChamp, challenger];
  document.getElementById('ombRoundText').textContent = "KRAL MODU 👑"; document.getElementById('ombProgressText').textContent = `Kalan Seçenek: ${omb.pool.length}`;
  document.getElementById('ombTextTop').textContent = omb.currentMatch[0]; document.getElementById('ombTextBottom').textContent = omb.currentMatch[1]; applyRandomOmbColors();
}
function handleOmbChoice(pickIndex){
  let winnerText = omb.currentMatch[pickIndex]; playSoundCardFlip(); 
  if(omb.mode === 'tournament'){
    omb.nextPool.push(winnerText); omb.matchIndex++;
    if(omb.pool.length === 0){
      if(omb.nextPool.length === 1) showOmbResult(omb.nextPool[0]);
      else { omb.pool = omb.nextPool.sort(()=>Math.random()-.5); omb.nextPool = []; prepareTournamentRound(); }
    } else loadTournamentMatch();
  } else {
    omb.kingChamp = winnerText; if(omb.pool.length === 0) showOmbResult(omb.kingChamp); else loadKingMatch();
  }
}
function showOmbResult(winnerText){ document.getElementById('ombWinnerText').textContent = winnerText; showScreen('screen-omb-result'); setTimeout(()=>launchConfetti(), 300); }

/* ══════════════ IMPOSTER ══════════════ */
function renderImpPlayers(){ document.getElementById('impPlayersList').innerHTML=st.imp.players.map((p,i)=>`<div class="player-tag"><div class="player-left"><div class="player-dot" style="background:${DOT_COLORS[i%8]}"></div><div class="player-name">${p}</div></div><button class="remove-btn" data-imp-remove="${p}">✕</button></div>`).join(''); }
function addImpPlayer(){ const inp=document.getElementById('impPlayerInput'); const name=inp.value.trim(); if(!name||st.imp.players.includes(name)) return; if(st.imp.players.length>=15){alert('Maksimum 15 oyuncu!');return;} st.imp.players.push(name); inp.value=''; renderImpPlayers(); }
function removeImpPlayer(name){ st.imp.players=st.imp.players.filter(p=>p!==name); renderImpPlayers(); }
function addImpCustomWord(){
  const inp=document.getElementById('impCustomWord'); const word=inp.value.trim();
  if(word){
    st.imp.customWords.push(word);
    document.getElementById('impCustomCount').textContent = `${st.imp.customWords.length} kelime eklendi (SADECE BUNLAR ÇIKACAK).`;
    document.getElementById('btnImpClearWords').style.display = 'block';
  }
  inp.value='';
}
function clearImpCustomWords(){
  st.imp.customWords = [];
  document.getElementById('impCustomCount').textContent = `0 özel kelime. (Hazır havuz devrede)`;
  document.getElementById('btnImpClearWords').style.display = 'none';
}
function startImposter(){
  if(st.imp.players.length < 3){alert('En az 3 oyuncu gerekli!'); return;}
  
  // YENİ MANTIK: Özel kelime eklendiyse YALNIZCA ONLARI kullan
  const pool = st.imp.customWords.length > 0 ? st.imp.customWords : IMP_WORDS;
  st.imp.currentWord = pool[Math.floor(Math.random() * pool.length)]; 
  
  st.imp.roles = [];
  const imposterIdx = Math.floor(Math.random() * st.imp.players.length), shuffledPlayers = [...st.imp.players].sort(()=>Math.random()-.5);
  shuffledPlayers.forEach((p, i) => { st.imp.roles.push({ name: p, isImp: (i === imposterIdx), word: (i === imposterIdx) ? "SEN IMPOSTERSIN!" : st.imp.currentWord }); });
  st.imp.turnIdx = 0; showImpPassScreen();
}
function showImpPassScreen(){
  if(st.imp.turnIdx >= st.imp.roles.length){ showScreen('screen-imp-discuss'); playSoundTimeUp(); return; }
  document.getElementById('impTurnName').textContent = st.imp.roles[st.imp.turnIdx].name; showScreen('screen-imp-pass');
}
function showImpSecret(){ playSoundCardFlip(); const p = st.imp.roles[st.imp.turnIdx]; const wordEl = document.getElementById('impSecretWord'); wordEl.textContent = p.word; document.getElementById('impRoleIcon').textContent = p.isImp ? "🕵️‍♂️" : "✅"; wordEl.style.color = p.isImp ? "#ef4444" : "#22c55e"; showScreen('screen-imp-secret'); }
function hideImpSecret(){ playSoundCardFlip(); st.imp.turnIdx++; showImpPassScreen(); }

/* ══════════════ EVENT DELEGATION (MOBİL TIKLAMA ÇÖZÜMÜ) ══════════════ */
function handleAction(target){
  const id=target.id;
  if(id==='btnShowPick'){showPick();return;}
  if(id==='btnShowScore'){showScore();return;}
  if(id==='btnPickBack'){showScreen('screen-splash');return;}
  if(id==='btnPickMlto'){st.game='mlto';showSetup();return;}
  if(id==='btnPickBottle'){st.game='bottle';showSetup();return;}
  if(id==='btnPickTabu'){showScreen('screen-tabu-setup');renderTabuPlayers();return;}
  if(id==='btnPickKimbu'){showKimBu();return;}
  if(id==='btnPickQuiz'){showQuiz();return;}
  if(id==='btnQuizBack'||id==='btnQuizHome'||id==='btnQuizHomeEnd'){showScreen('screen-splash');return;}
  if(id==='btnQuizRestart'){showQuiz();return;}
  if(id==='btnQuizNext'){qz.qIdx++;loadQuizQuestion();return;}
  if(id==='btnQuizSkip'){quizSkip();return;}
  if(target.dataset.qcat){ qz.cat = target.dataset.qcat; document.querySelectorAll('[data-qcat]').forEach(b=>b.classList.toggle('active', b.dataset.qcat===qz.cat)); renderQuizGrid(); return; }
  if(target.dataset.qseries!==undefined){startQuizSeries(parseInt(target.dataset.qseries));return;}
  if(target.dataset.qchoice!==undefined){answerQuiz(parseInt(target.dataset.qchoice));return;}
  if(id==='btnKbFutbol'){startKimBu('futbolcu');return;}
  if(id==='btnKbActor'){startKimBu('aktor');return;}
  if(id==='btnKbTurkFutbol'){startKimBu('turk_futbolcu');return;}
  if(id==='btnKbTurkActor'){startKimBu('turk_aktor');return;}
  if(id==='btnKbBack'||id==='btnKbHome2'||id==='btnKbHomeEnd'){showScreen('screen-splash');return;}
  if(id==='btnKbHint'){kbShowHint();return;}
  if(id==='btnKbSubmit'){submitKbGuess();return;}
  if(id==='btnKbSkipQ'){kbSkip();return;}
  if(id==='btnKbNext'){kbNext();return;}
  if(id==='btnKbRestart'){showKimBu();return;}
  if(id==='btnSetupBack'){showPick();return;}
  if(id==='btnStartGame'){startCurrentGame();return;}
  if(id==='btnAddPlayer'){addPlayer();return;}
  if(id==='btnGameSetup'||id==='btnBottleSetup'){showSetup();return;}
  if(id==='modeVote'){setMode('vote');return;}
  if(id==='modeCard'){setMode('card');return;}
  if(target.dataset.q){ st.qCount=parseInt(target.dataset.q); document.querySelectorAll('#qCountTabs .mode-tab').forEach(t=>t.classList.remove('active')); target.classList.add('active');return; }
  if(id==='btnTabuAddPlayer'){addTabuPlayer();return;}
  if(id==='btnTabuSetupBack'){showPick();return;}
  if(id==='btnStartTabu'){startTabu();return;}
  if(id==='btnTabuNextTurn'){startNextTabuTurn();return;}
  if(target.dataset.tabuCat){setTabuCategory(target.dataset.tabuCat);return;}
  if(target.dataset.tabuTime){setTabuTime(target.dataset.tabuTime);return;}
  if(target.dataset.diff){setDifficulty(target.dataset.diff);return;}
  if(target.dataset.tabuRemove){removeTabuPlayer(target.dataset.tabuRemove);return;}
  if(id==='mainCard'){flipCard();return;}
  if(id==='btnNextCard'){nextCard();return;}
  if(target.dataset.vote){vote(target.dataset.vote,target);return;}
  if(target.dataset.pick){pickPlayer(target.dataset.pick,target);return;}
  if(target.dataset.remove){removePlayer(target.dataset.remove);return;}
  if(id==='spinBtn'||id==='bottleWrap'||target.closest('#bottleWrap')){spinBottle();return;}
  if(id==='btnBottleScore'){showScore();return;}
  if(target.dataset.choice){revealChallenge(target.dataset.winner,target.dataset.choice==='truth');return;}
  if(id==='btnTabuCorrect'){tabuCorrect();return;}
  if(id==='btnTabuSkip'){tabuSkip();return;}
  if(id==='btnTabuMistake'){tabuMistake();return;}
  if(id==='btnTabuSetup2'){clearInterval(st.tabu.timerInterval);stopAllTabuSounds();showScreen('screen-tabu-setup');return;}
  if(id==='btnReplay'){startCurrentGame();return;}
  if(id==='btnScoreHome'){showScreen('screen-splash');return;}
  if(id==='btnPickOmuBumu'){showOmbSetup();return;}
  if(id==='btnOmbSetupBack'){showPick();return;}
  if(target.dataset.ombCat){ omb.cat = target.dataset.ombCat; document.querySelectorAll('[data-omb-cat]').forEach(b=>b.classList.toggle('active', b.dataset.ombCat===omb.cat)); return; }
  if(target.dataset.ombMode){updateOmbModeHint(target.dataset.ombMode);return;}
  if(target.dataset.ombCount){ omb.totalCount = parseInt(target.dataset.ombCount); document.querySelectorAll('[data-omb-count]').forEach(b=>b.classList.toggle('active', b.dataset.ombCount===target.dataset.ombCount)); return; }
  if(id==='btnStartOmuBumu'){startOmbGame();return;}
  if(id==='btnOmbTop'||target.closest('#btnOmbTop')){handleOmbChoice(0);return;}
  if(id==='btnOmbBottom'||target.closest('#btnOmbBottom')){handleOmbChoice(1);return;}
  if(id==='btnOmbQuit'){showPick();return;}
  if(id==='btnOmbReplay'){showOmbSetup();return;}
  if(id==='btnOmbHome'){showScreen('screen-splash');return;}
  // IMPOSTER CLICK EVENTS
  if(id==='btnPickImp'){showScreen('screen-imp-setup'); renderImpPlayers(); return;}
  if(id==='btnImpSetupBack'){showPick(); return;}
  if(id==='btnImpAddPlayer'){addImpPlayer(); return;}
  if(target.dataset.impRemove){removeImpPlayer(target.dataset.impRemove); return;}
  if(id==='btnImpAddWord'){addImpCustomWord(); return;}
  if(id==='btnImpClearWords'){clearImpCustomWords(); return;}
  if(id==='btnStartImp'){startImposter(); return;}
  if(id==='btnImpShowSecret'){showImpSecret(); return;}
  if(id==='btnImpHideSecret'){hideImpSecret(); return;}
  if(id==='btnImpReplay'){startImposter(); return;}
  if(id==='btnImpHome'){showScreen('screen-splash'); return;}
}

// BÜTÜN MOBİL TIKLAMA SORUNLARINI ÇÖZEN GARANTİLİ YÖNTEM
document.addEventListener('click', function(e) {
  const target = e.target.closest('button, .game-card, .mode-tab, .omb-card, #mainCard, #bottleWrap');
  if (target) {
    handleAction(target);
  }
});

// Klavyeden enter basılma durumları
document.getElementById('playerInput').addEventListener('keydown',e=>{if(e.key==='Enter')addPlayer();});
document.getElementById('tabuPlayerInput').addEventListener('keydown',e=>{if(e.key==='Enter')addTabuPlayer();});
document.getElementById('kbInput').addEventListener('keydown',e=>{if(e.key==='Enter')submitKbGuess();});
document.getElementById('impPlayerInput').addEventListener('keydown',e=>{if(e.key==='Enter')addImpPlayer();});
document.getElementById('impCustomWord').addEventListener('keydown',e=>{if(e.key==='Enter')addImpCustomWord();});

// Konfetiyi ekran boyutuna uydurma
window.addEventListener('resize', () => {
  const canvas = document.getElementById('confetti-canvas');
  if (canvas) { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
});

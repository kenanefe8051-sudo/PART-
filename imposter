/* ══════════════ SCREENS ══════════════ */
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function showPick(){showScreen('screen-pick');}
function showSetup(){
  const mlt=document.getElementById('mltOptions');
  const btn=document.getElementById('btnStartGame');
  mlt.style.display=st.game==='mlto'?'flex':'none';
  btn.className='btn '+(st.game==='mlto'?'btn-red':'btn-amber');
  renderPlayers(); showScreen('screen-setup');
}
function showScore(){
  if(!st.players.length&&!st.tabu.players.length){alert('Henüz oyun oynanmadı!');return;}
  renderScoreboard(); showScreen('screen-score');
  setTimeout(()=>launchConfetti(), 200);
}

/* ══════════════ PLAYERS (MLT/Bottle) ══════════════ */
function addPlayer(){
  const inp=document.getElementById('playerInput');
  const name=inp.value.trim();
  if(!name||st.players.includes(name)){inp.value='';return;}
  if(st.players.length>=8){alert('Maksimum 8 oyuncu!');return;}
  st.players.push(name); st.scores[name]=st.scores[name]||0;
  inp.value=''; renderPlayers();
}
function removePlayer(name){st.players=st.players.filter(p=>p!==name);renderPlayers();}
function renderPlayers(){
  document.getElementById('playersList').innerHTML=st.players.map((p,i)=>`
    <div class="player-tag">
      <div class="player-left">
        <div class="player-dot" style="background:${DOT_COLORS[i%8]}"></div>
        <div class="player-name">${p}</div>
      </div>
      <button class="remove-btn" data-remove="${p}">✕</button>
    </div>`).join('');
}

/* ══════════════ MLT CONFIG ══════════════ */
function setMode(m){
  st.mode=m;
  document.getElementById('modeVote').classList.toggle('active',m==='vote');
  document.getElementById('modeCard').classList.toggle('active',m==='card');
  document.getElementById('modeHint').textContent=
    m==='vote'?'Herkes grubun en çok kimi seçeceğini oylayacak':'Kartı çek, soruyu oku, birini seç';
}
function startCurrentGame(){
  if(st.players.length<2){alert('En az 2 oyuncu gerekli!');showSetup();return;}
  if(st.game==='mlto')startMLTO(); else startBottle();
}

/* ══════════════ MLTO ══════════════ */
function startMLTO(){
  st.questions=[...MLT_QUESTIONS].sort(()=>Math.random()-.5).slice(0,st.qCount);
  st.current=0; st.cardFlipped=false;
  renderCard(); showScreen('screen-game');
}
function renderCard(){
  const total=st.questions.length,i=st.current;
  document.getElementById('progressBar').style.width=Math.round((i/total)*100)+'%';
  document.getElementById('cardCount').textContent=`${i+1}/${total}`;
  document.getElementById('cardQuestion').textContent=st.questions[i]||'—';
  document.getElementById('mainCard').classList.remove('flipped');
  st.cardFlipped=false;
  st.voteRound=0;
  st.cardVotes={};
  if(st.mode==='vote'){
    renderVoterTurn();
  }else{
    document.getElementById('voteSection').innerHTML=`
      <div class="vote-grid">
        ${st.players.map(p=>`<button class="vote-btn" data-pick="${p}">${p}</button>`).join('')}
      </div>`;
  }
}
function renderVoterTurn(){
  if(!st.voterOrder || st.voteRound===0){
    st.voterOrder=[...Array(st.players.length).keys()].sort(()=>Math.random()-.5);
  }
  const voterIdx=st.voterOrder[st.voteRound];
  const voter=st.players[voterIdx];
  const color=DOT_COLORS[voterIdx%8];
  const total=st.players.length;
  const candidates=st.players.filter(p=>p!==voter);

  document.getElementById('voteSection').innerHTML=`
    <div class="voter-banner">
      <div class="voter-dot" style="background:${color}"></div>
      <div>
        <div class="voter-label">Oy veriyor</div>
        <div class="voter-name">${voter}</div>
      </div>
      <div class="voter-progress">${st.voteRound+1} / ${total}</div>
    </div>
    <div class="vote-grid" id="voteGrid">
      ${candidates.map(p=>`<button class="vote-btn" data-vote="${p}">${p}</button>`).join('')}
    </div>`;
}
function renderVoteResults(){
  const counts={};
  st.players.forEach(p=>counts[p]=0);
  Object.values(st.cardVotes).forEach(v=>{ counts[v]=(counts[v]||0)+1; });
  const maxV=Math.max(...Object.values(counts));
  const sorted=[...st.players].sort((a,b)=>counts[b]-counts[a]);
  const winners=sorted.filter(p=>counts[p]===maxV&&maxV>0);

  document.getElementById('voteSection').innerHTML=`
    <div style="font-size:11px;color:rgba(255,255,255,.4);font-weight:700;letter-spacing:1px;text-align:center;margin-bottom:6px;">
      SONUÇLAR ${winners.length>0?'🏆':''}
    </div>
    <div class="vote-tally">
      ${sorted.map(p=>`
        <div class="tally-row">
          <div class="tally-name" style="color:${winners.includes(p)?'#ffd93d':'rgba(255,255,255,.7)'}">${p}</div>
          <div class="tally-bar-wrap">
            <div class="tally-bar" style="width:${maxV>0?Math.round((counts[p]/maxV)*100):0}%;${winners.includes(p)?'background:linear-gradient(90deg,#ffd93d,#ff6b6b)':''}"></div>
          </div>
          <div class="tally-count">${counts[p]}</div>
        </div>`).join('')}
    </div>`;
  winners.forEach(w=>{ st.scores[w]=(st.scores[w]||0)+1; });
}
function flipCard(){
  if(st.cardFlipped)return;
  playSoundCardFlip();
  document.getElementById('mainCard').classList.add('flipped'); st.cardFlipped=true;
}
function vote(player,btn){
  if(!st.cardFlipped){flipCard();return;}
  const voterIdx=st.voterOrder[st.voteRound];
  const voter=st.players[voterIdx];
  st.cardVotes[voter]=player;
  document.querySelectorAll('#voteGrid .vote-btn').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
  st.voteRound++;
  if(st.voteRound>=st.players.length){
    setTimeout(()=>renderVoteResults(), 300);
  } else {
    setTimeout(()=>renderVoterTurn(), 350);
  }
}
function pickPlayer(player,btn){
  if(!st.cardFlipped){flipCard();return;}
  document.querySelectorAll('#screen-game .vote-btn').forEach(b=>b.classList.remove('selected'));

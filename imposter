function spinBottle(){
  if(st.bottleSpinning)return;
  st.bottleSpinning=true;
  document.getElementById('spinBtn').disabled=true;
  document.getElementById('bottleResult').innerHTML='<div class="bottle-result-idle">🌀 Çevriliyor...</div>';
  document.querySelectorAll('.pdot').forEach(d=>d.classList.remove('highlighted'));

  const w=document.getElementById('bottleWrap');
  w.style.animation='none';
  w.style.transition='none';
  void w.offsetWidth;

  const n=st.players.length;
  const targetIdx=Math.floor(Math.random()*n);
  const targetAngleDeg=(360/n)*targetIdx;

  const curNorm=((st.bottleAngle%360)+360)%360;
  let diff=((targetAngleDeg-curNorm)+360)%360;
  if(diff<30)diff+=360; 

  const extraSpins=(8+Math.floor(Math.random()*5))*360;
  const finalAngle=st.bottleAngle+extraSpins+diff;
  const dur=3000+Math.random()*1500;

  w.style.transition=`transform ${dur}ms cubic-bezier(0.17,0.72,0.22,1.0)`;
  w.style.transform=`rotate(${finalAngle}deg)`;
  st.bottleAngle=finalAngle;

  setTimeout(()=>{
    w.style.transition='none';
    w.style.transform=`rotate(${finalAngle}deg)`;
    st.bottleSpinning=false;
    document.getElementById('spinBtn').disabled=false;
    setTimeout(()=>{w.style.animation='';w.classList.add('idle-hint');},600);

    document.querySelectorAll('.pdot').forEach(d=>d.classList.remove('highlighted'));
    const dot=document.querySelector(`#pdot-${targetIdx} .pdot`);

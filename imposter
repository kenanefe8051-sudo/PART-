function kbNorm(s){ return s.toLowerCase().replace(/ğ/g,'g').replace(/ü/g,'u').replace(/ş/g,'s').replace(/ı/g,'i').replace(/ö/g,'o').replace(/ç/g,'c').replace(/[^a-z0-9 ]/g,'').replace(/\s+/g,' ').trim(); }
function levenshtein(a, b){
  const m=a.length, n=b.length, dp=Array.from({length:m+1},(_,i)=>Array.from({length:n+1},(_,j)=>j===0?i:0));
  for(let j=1;j<=n;j++) dp[0][j]=j;
  for(let i=1;i<=m;i++) for(let j=1;j<=n;j++) dp[i][j] = a[i-1]===b[j-1] ? dp[i-1][j-1] : 1+Math.min(dp[i-1][j], dp[i][j-1], dp[i-1][j-1]);
  return dp[m][n];
}
function similarity(a, b){ const na=kbNorm(a), nb=kbNorm(b); if(na===nb) return 1; const maxLen=Math.max(na.length, nb.length); return maxLen===0 ? 1 : 1 - levenshtein(na,nb)/maxLen; }
function lastNameMatch(guess, answer){
  const parts = kbNorm(answer).split(' '); if(parts.length < 2) return false;
  const lastName = parts[parts.length-1], g = kbNorm(guess);
  return g===lastName || (lastName.length>=4 && similarity(g,lastName)>=0.85);
}
function isCorrectGuess(guess, answer){
  if(!guess) return false; if(similarity(guess, answer) >= 0.80) return true; if(lastNameMatch(guess, answer)) return true;
  if(similarity(kbNorm(guess).split(' ').sort().join(' '), kbNorm(answer).split(' ').sort().join(' ')) >= 0.80) return true;
  return false;
}

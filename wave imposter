/* ── SOUNDS ── */
let _AC;
function ac(){if(!_AC)_AC=new(window.AudioContext||window.webkitAudioContext)();if(_AC.state==='suspended')_AC.resume();return _AC;}
function sndSuccess(){const c=ac();[523,659,784,1047].forEach((f,i)=>{const o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.type='sine';o.frequency.value=f;const t=c.currentTime+i*.09;g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(.2,t+.02);g.gain.exponentialRampToValueAtTime(.001,t+.22);o.start(t);o.stop(t+.22);});}
function sndOk(){const c=ac();[440,550].forEach((f,i)=>{const o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.type='sine';o.frequency.value=f;const t=c.currentTime+i*.1;g.gain.setValueAtTime(.15,t);g.gain.exponentialRampToValueAtTime(.001,t+.2);o.start(t);o.stop(t+.2);});}
function sndFail(){const c=ac();[280,220].forEach((f,i)=>{const o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.type='sawtooth';o.frequency.value=f;const t=c.currentTime+i*.13;g.gain.setValueAtTime(.18,t);g.gain.exponentialRampToValueAtTime(.001,t+.22);o.start(t);o.stop(t+.23);});}
function sndFlip(){const c=ac();const t=c.currentTime;const b=c.createBuffer(1,Math.floor(c.sampleRate*.1),c.sampleRate);const d=b.getChannelData(0);for(let i=0;i<d.length;i++)d[i]=(Math.random()*2-1)*(1-i/d.length);const n=c.createBufferSource();n.buffer=b;const f2=c.createBiquadFilter();f2.type='bandpass';f2.frequency.value=2200;const g=c.createGain();g.gain.setValueAtTime(.35,t);g.gain.exponentialRampToValueAtTime(.001,t+.1);n.connect(f2);f2.connect(g);g.connect(c.destination);n.start(t);n.stop(t+.1);}

/* ── CONFETTI ── */
const CCOLORS=['#3BFFD8','#FF4ECD','#FFD93D','#7AADFF','#FF8A8A','#fff'];
let cParts=[],cRAF;
function confetti(){
  const cv=document.getElementById('confetti-cv');
  const W=cv.width=window.innerWidth,H=cv.height=window.innerHeight;
  const ctx=cv.getContext('2d');cParts=[];
  for(let i=0;i<160;i++){const a=(Math.random()*360)*Math.PI/180,sp=3+Math.random()*7;
    cParts.push({x:W/2+(Math.random()-.5)*W*.7,y:H*.45,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-5,
      w:6+Math.random()*8,h:4+Math.random()*6,rot:Math.random()*360,rv:(Math.random()-.5)*8,
      c:CCOLORS[Math.floor(Math.random()*CCOLORS.length)],life:1});}
  cancelAnimationFrame(cRAF);
  function draw(){ctx.clearRect(0,0,W,H);let alive=false;
    cParts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.vy+=.25;p.vx*=.99;p.rot+=p.rv;p.life-=.013;
      const a=Math.max(0,p.life);if(a>0){alive=true;ctx.save();ctx.globalAlpha=a;
        ctx.translate(p.x,p.y);ctx.rotate(p.rot*Math.PI/180);ctx.fillStyle=p.c;
        ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);ctx.restore();}});
    if(alive)cRAF=requestAnimationFrame(draw);else ctx.clearRect(0,0,W,H);}
  draw();
}


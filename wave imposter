<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Party Games</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;touch-action:manipulation;}

:root{
  --bg:#050810;--surface:#0d1120;--border:rgba(99,220,220,.12);
  --accent:#3BFFD8;--accent2:#FF4ECD;--accent3:#FFD93D;--red:#FF4757;
  --text:#e8f4f4;--muted:rgba(232,244,244,.4);
}

body{font-family:'Syne',sans-serif;background:var(--bg);color:var(--text);
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  overflow:hidden;position:relative;}

body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:linear-gradient(rgba(59,255,216,.04) 1px,transparent 1px),
    linear-gradient(90deg,rgba(59,255,216,.04) 1px,transparent 1px);
  background-size:50px 50px;animation:gridDrift 20s linear infinite;}
@keyframes gridDrift{from{background-position:0 0}to{background-position:50px 50px}}

body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:radial-gradient(ellipse 60% 40% at 20% 30%,rgba(59,255,216,.07) 0%,transparent 70%),
    radial-gradient(ellipse 50% 35% at 80% 70%,rgba(255,78,205,.07) 0%,transparent 70%);}

/* ── SCREENS ── */
.screen{display:none;width:100%;max-width:480px;min-height:100vh;padding:28px 22px;
  flex-direction:column;align-items:center;justify-content:center;
  position:relative;z-index:1;gap:16px;}
.screen.active{display:flex;}
.screen-top{justify-content:flex-start;padding-top:44px;}

/* ── COMMON ── */
@keyframes floatLogo{0%,100%{transform:translateY(0) rotate(-3deg)}50%{transform:translateY(-10px) rotate(3deg)}}
@keyframes slideIn{from{opacity:0;transform:translateX(-12px)}to{opacity:1;transform:translateX(0)}}
@keyframes bannerIn{from{opacity:0;transform:scale(.9)}to{opacity:1;transform:scale(1)}}

.title-xl{font-family:'Space Mono',monospace;font-size:clamp(32px,9vw,50px);
  font-weight:700;letter-spacing:-2px;line-height:1;
  background:linear-gradient(135deg,var(--accent),#7DF9FF,var(--accent2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.label-sm{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:3px;
  text-transform:uppercase;color:var(--accent);align-self:flex-start;}
.divider{width:100%;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);}

/* ── BUTTONS ── */
.btn{width:100%;padding:16px 22px;border:none;border-radius:12px;
  font-family:'Space Mono',monospace;font-size:14px;font-weight:700;
  cursor:pointer;touch-action:manipulation;-webkit-appearance:none;
  transition:all .18s;letter-spacing:1px;}
.btn:active{transform:scale(.97);}
.btn-cyan{background:linear-gradient(135deg,var(--accent),#00b8a0);color:#050810;
  box-shadow:0 0 28px rgba(59,255,216,.3);}
.btn-pink{background:linear-gradient(135deg,var(--accent2),#c026d3);color:#fff;
  box-shadow:0 0 22px rgba(255,78,205,.3);}
.btn-red{background:linear-gradient(135deg,var(--red),#c0392b);color:#fff;
  box-shadow:0 0 22px rgba(255,71,87,.3);}
.btn-outline{background:transparent;color:var(--muted);border:1.5px solid rgba(232,244,244,.12);font-size:13px;}
.btn-ghost{background:transparent;color:var(--muted);font-size:12px;padding:10px;border:none;}
.btn-sm{width:auto;padding:10px 18px;font-size:12px;border-radius:10px;}

/* ── INPUTS ── */
input[type=text]{flex:1;background:transparent;border:none;
  color:var(--text);font-family:'Syne',sans-serif;font-size:15px;font-weight:600;outline:none;}
input::placeholder{color:rgba(232,244,244,.2);}
.input-row{display:flex;align-items:center;gap:12px;
  background:var(--surface);border:1.5px solid var(--border);
  border-radius:14px;padding:14px 16px;width:100%;}
.input-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.add-btn{background:rgba(59,255,216,.12);border:1.5px solid rgba(59,255,216,.25);
  border-radius:10px;min-width:44px;height:44px;font-size:20px;color:var(--accent);
  cursor:pointer;flex-shrink:0;touch-action:manipulation;-webkit-appearance:none;
  display:flex;align-items:center;justify-content:center;transition:all .15s;}
.add-btn:active{transform:scale(.93);}
.add-btn-yellow{background:rgba(255,217,61,.1);border-color:rgba(255,217,61,.3);color:var(--accent3);}

.tab-row{display:flex;gap:6px;width:100%;background:rgba(255,255,255,.05);border-radius:12px;padding:4px;}
.tab{flex:1;padding:10px 5px;border:none;border-radius:9px;
  font-family:'Space Mono',monospace;font-weight:700;font-size:12px;
  background:transparent;color:var(--muted);cursor:pointer;transition:all .15s;text-align:center;}
.tab.active{background:#fff;color:#050810;}

/* ── PLAYER TAGS ── */
.players-list{display:flex;flex-direction:column;gap:6px;width:100%;max-height:180px;overflow-y:auto;}
.player-tag{display:flex;align-items:center;justify-content:space-between;
  background:rgba(255,255,255,.07);border-radius:10px;padding:10px 14px;animation:slideIn .2s ease;}
.player-left{display:flex;align-items:center;gap:10px;}
.player-name{font-weight:700;font-size:14px;}
.remove-x{background:none;border:none;color:rgba(255,255,255,.2);font-size:16px;padding:4px 8px;cursor:pointer;}

/* ── HOW-TO ── */
.how-to{width:100%;display:flex;flex-direction:column;gap:7px;}
.how-step{display:flex;align-items:flex-start;gap:12px;padding:10px 14px;
  background:var(--surface);border:1px solid var(--border);border-radius:12px;}
.how-num{font-family:'Space Mono',monospace;font-size:11px;font-weight:700;color:var(--accent);
  background:rgba(59,255,216,.12);border-radius:6px;padding:2px 7px;flex-shrink:0;margin-top:1px;}
.how-text{font-size:13px;color:rgba(232,244,244,.7);line-height:1.5;}

/* ── MENU CARDS ── */
.menu-cards{display:flex;flex-direction:column;gap:12px;width:100%;}
.menu-card{width:100%;border:none;border-radius:20px;padding:22px;
  display:flex;align-items:center;gap:16px;text-align:left;
  cursor:pointer;-webkit-appearance:none;transition:transform .2s;}
.menu-card:active{transform:scale(.97);}
.mc-icon{font-size:44px;flex-shrink:0;filter:drop-shadow(0 0 14px rgba(255,255,255,.2));}
.mc-name{font-family:'Space Mono',monospace;font-size:20px;font-weight:700;color:#fff;letter-spacing:.5px;}
.mc-desc{font-size:12px;color:rgba(255,255,255,.55);margin-top:4px;font-weight:600;}
.mc-wave{background:linear-gradient(135deg,rgba(15,58,48,.9),rgba(10,42,36,.9));
  border:1.5px solid rgba(59,255,216,.3);box-shadow:0 10px 30px rgba(59,255,216,.12),inset 0 1px 0 rgba(59,255,216,.08);}
.mc-imp{background:linear-gradient(135deg,rgba(58,15,15,.9),rgba(42,10,10,.9));
  border:1.5px solid rgba(255,71,87,.3);box-shadow:0 10px 30px rgba(255,71,87,.12),inset 0 1px 0 rgba(255,71,87,.08);}

/* ═══════════════════ WAVELENGTH ═══════════════════ */
#wl-game{gap:0;justify-content:flex-start;padding-top:20px;padding-bottom:22px;}
.game-top{width:100%;display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;}
.round-badge{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;}
.scores-row{display:flex;gap:8px;width:100%;margin-bottom:12px;}
.score-card{flex:1;border-radius:14px;padding:12px 14px;background:var(--surface);border:1.5px solid var(--border);transition:all .3s;}
.score-card.sc-a{background:rgba(59,255,216,.08);border-color:rgba(59,255,216,.4);box-shadow:0 0 20px rgba(59,255,216,.1);}
.score-card.sc-b{background:rgba(255,78,205,.08);border-color:rgba(255,78,205,.4);box-shadow:0 0 20px rgba(255,78,205,.1);}
.sc-team{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:2px;}
.sc-score{font-family:'Space Mono',monospace;font-size:30px;font-weight:700;line-height:1;}
.score-card.sc-a .sc-score{color:var(--accent);}
.score-card.sc-b .sc-score{color:var(--accent2);}
.concept-bar{width:100%;display:flex;align-items:center;gap:10px;margin-bottom:9px;
  background:var(--surface);border:1.5px solid var(--border);border-radius:14px;
  padding:13px 16px;position:relative;overflow:hidden;}
.concept-bar::before{content:'';position:absolute;inset:0;pointer-events:none;
  background:linear-gradient(90deg,rgba(255,107,107,.06),transparent 40%,transparent 60%,rgba(77,150,255,.06));}
.concept-word{font-family:'Space Mono',monospace;font-size:16px;font-weight:700;flex:1;}
.c-left{color:#FF8A8A;text-align:left;}
.c-right{color:#7AADFF;text-align:right;}
.concept-sep{color:var(--muted);font-size:18px;flex-shrink:0;}
.dial-wrap{width:100%;margin:3px 0;}
#dialCanvas{width:100%;display:block;border-radius:16px;cursor:pointer;touch-action:none;}
.phase-strip{width:100%;background:var(--surface);border:1.5px solid var(--border);
  border-radius:12px;padding:9px 16px;font-size:12px;font-weight:700;color:var(--muted);
  text-align:center;margin-bottom:4px;}
.phase-strip span{color:var(--accent);}
.phase-strip span.pink{color:var(--accent2);}
.clue-box{width:100%;background:rgba(59,255,216,.06);border:1.5px solid rgba(59,255,216,.25);
  border-radius:14px;padding:13px 16px;display:flex;flex-direction:column;gap:8px;transition:all .3s;}
.clue-box.pink-mode{background:rgba(255,78,205,.06);border-color:rgba(255,78,205,.25);}
.clue-lbl{font-size:9px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--accent);}
.clue-box.pink-mode .clue-lbl{color:var(--accent2);}
.clue-in{background:rgba(255,255,255,.07);border:1.5px solid rgba(255,255,255,.1);
  border-radius:10px;padding:11px 14px;color:var(--text);font-family:'Syne',sans-serif;
  font-size:15px;font-weight:600;outline:none;width:100%;transition:border-color .2s;}
.clue-in:focus{border-color:rgba(59,255,216,.5);}
.clue-show{font-family:'Space Mono',monospace;font-size:24px;font-weight:700;
  text-align:center;letter-spacing:1px;padding:4px 0;}
.res-banner{width:100%;border-radius:14px;padding:13px 18px;text-align:center;
  font-family:'Space Mono',monospace;font-size:14px;font-weight:700;letter-spacing:1px;
  animation:bannerIn .4s cubic-bezier(.175,.885,.32,1.275);}
.r4{background:rgba(34,197,94,.15);border:1.5px solid rgba(34,197,94,.4);color:#4ade80;}
.r3{background:rgba(59,255,216,.12);border:1.5px solid rgba(59,255,216,.35);color:var(--accent);}
.r2{background:rgba(251,191,36,.12);border:1.5px solid rgba(251,191,36,.35);color:#fbbf24;}
.r1{background:rgba(249,115,22,.12);border:1.5px solid rgba(249,115,22,.35);color:#fb923c;}
.r0{background:rgba(239,68,68,.12);border:1.5px solid rgba(239,68,68,.35);color:#f87171;}
.game-actions{display:flex;gap:8px;width:100%;margin-top:5px;}
/* WL final */
#wl-final{text-align:center;gap:14px;}
.winner-badge{font-size:68px;animation:floatLogo 2s ease-in-out infinite;}
.winner-title{font-family:'Space Mono',monospace;font-size:12px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);}
.winner-name{font-family:'Space Mono',monospace;font-size:clamp(24px,7vw,38px);font-weight:700;
  background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;
  -webkit-text-fill-color:transparent;margin:4px 0 10px;}
.final-scores{width:100%;display:flex;flex-direction:column;gap:8px;}
.fs-row{display:flex;align-items:center;justify-content:space-between;
  background:var(--surface);border:1.5px solid var(--border);border-radius:14px;padding:13px 18px;}
.fs-row.win-row{background:rgba(59,255,216,.08);border-color:rgba(59,255,216,.35);}
.fs-name{font-weight:700;font-size:15px;}
.fs-pts{font-family:'Space Mono',monospace;font-size:24px;font-weight:700;}

/* ═══════════════════ IMPOSTER ═══════════════════ */
.imp-center{text-align:center;gap:16px;}
.big-emoji{font-size:68px;animation:floatLogo 2.5s ease-in-out infinite;}
.big-title{font-family:'Space Mono',monospace;font-size:26px;font-weight:700;letter-spacing:-1px;}
.player-spotlight{font-family:'Space Mono',monospace;font-size:30px;font-weight:700;
  color:var(--accent3);text-shadow:0 0 20px rgba(255,217,61,.4);text-align:center;}
.imp-hint-card{background:var(--surface);border:1.5px solid var(--border);
  border-radius:16px;padding:16px 20px;text-align:center;
  font-size:13px;color:var(--muted);line-height:1.7;width:100%;}
.secret-box{width:100%;border-radius:20px;padding:26px 20px;text-align:center;
  display:flex;flex-direction:column;align-items:center;gap:12px;}
.secret-crew{background:rgba(59,255,216,.08);border:2px solid rgba(59,255,216,.3);}
.secret-imp{background:rgba(255,71,87,.08);border:2px solid rgba(255,71,87,.3);}
.role-label{font-size:9px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--muted);}
.role-icon{font-size:52px;line-height:1;}
.secret-word{font-family:'Space Mono',monospace;font-size:34px;font-weight:700;letter-spacing:-1px;}
.secret-crew .secret-word{color:var(--accent);}
.secret-imp .secret-word{color:var(--red);}
.role-desc{font-size:13px;color:var(--muted);line-height:1.6;max-width:290px;}
.discuss-box{width:100%;background:rgba(255,217,61,.07);border:1.5px solid rgba(255,217,61,.2);
  border-radius:16px;padding:18px;text-align:center;font-size:14px;color:rgba(255,255,255,.7);line-height:1.7;}
.reveal-word-card{width:100%;background:var(--surface);border:1.5px solid var(--border);
  border-radius:16px;padding:18px;text-align:center;}
.rwc-label{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:8px;}
.rwc-word{font-family:'Space Mono',monospace;font-size:28px;font-weight:700;
  color:var(--accent3);letter-spacing:-1px;}
.custom-tags-wrap{display:flex;flex-wrap:wrap;gap:6px;width:100%;min-height:10px;}
.ctag{background:rgba(255,217,61,.1);border:1px solid rgba(255,217,61,.25);
  border-radius:20px;padding:4px 12px;font-size:12px;font-weight:700;color:var(--accent3);
  display:flex;align-items:center;gap:6px;}
.ctag button{background:none;border:none;color:rgba(255,217,61,.4);cursor:pointer;font-size:12px;padding:0;}

/* confetti */
#confetti-cv{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:999;}
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}
</style>
</head>
<body>
<canvas id="confetti-cv"></canvas>

<!-- ════════════ MAIN MENU ════════════ -->
<div id="screen-menu" class="screen active">
  <div style="text-align:center;margin-bottom:6px;">
    <div style="font-size:56px;margin-bottom:12px;filter:drop-shadow(0 0 22px rgba(59,255,216,.5));animation:floatLogo 3s ease-in-out infinite;">🎮</div>
    <div class="title-xl">PARTY GAMES</div>
    <div style="font-size:11px;color:var(--muted);letter-spacing:3px;text-transform:uppercase;margin-top:8px;font-family:'Space Mono',monospace;">Bir oyun seç</div>
  </div>
  <div class="menu-cards">
    <button class="menu-card mc-wave" id="btnGoWl">
      <div class="mc-icon">〰️</div>
      <div><div class="mc-name">WAVELENGTH</div><div class="mc-desc">Hedefi gör · İpucu ver · Frekansı bul</div></div>
    </button>
    <button class="menu-card mc-imp" id="btnGoImp">
      <div class="mc-icon">🕵️</div>
      <div><div class="mc-name">IMPOSTER</div><div class="mc-desc">Aramızdaki hain kim? · Kelimeyi bul</div></div>
    </button>
  </div>
</div>

<!-- ════════════ WL SETUP ════════════ -->
<div id="screen-wl-setup" class="screen screen-top" style="gap:15px;">
  <div class="title-xl" style="font-size:26px;align-self:flex-start;">〰️ WAVELENGTH</div>
  <div class="label-sm">Takım İsimleri</div>
  <div style="display:flex;flex-direction:column;gap:9px;width:100%;">
    <div class="input-row"><div class="input-dot" style="background:var(--accent)"></div><input type="text" id="wlT1" placeholder="Takım 1" maxlength="18" value="Takım 1"></div>
    <div class="input-row"><div class="input-dot" style="background:var(--accent2)"></div><input type="text" id="wlT2" placeholder="Takım 2" maxlength="18" value="Takım 2"></div>
  </div>
  <div class="divider"></div>
  <div class="label-sm">Kaç Tur?</div>
  <div class="tab-row">
    <button class="tab" data-rounds="5">5</button>
    <button class="tab active" data-rounds="10">10</button>
    <button class="tab" data-rounds="15">15</button>
    <button class="tab" data-rounds="20">20</button>
  </div>
  <div class="how-to">
    <div class="how-step"><span class="how-num">01</span><div class="how-text">Kavram çifti belirir: <b style="color:#FF8A8A">Sıcak</b> ↔ <b style="color:#7AADFF">Soğuk</b> gibi.</div></div>
    <div class="how-step"><span class="how-num">02</span><div class="how-text"><b style="color:var(--accent)">İpucu veren takım</b> kadrandaki parlak hedef bölgeyi görür — diğer takım bakamaz!</div></div>
    <div class="how-step"><span class="how-num">03</span><div class="how-text">Hedef gizlenir, ipucu veren <b style="color:var(--accent)">tek kelime</b> söyler.</div></div>
    <div class="how-step"><span class="how-num">04</span><div class="how-text"><b style="color:var(--accent2)">Diğer takım</b> ibreyi çevirerek tahmin eder. Yakınlık = Puan! 🎯</div></div>
  </div>
  <button class="btn btn-cyan" id="btnStartWl">BAŞLAT →</button>
  <button class="btn btn-ghost" id="btnWlSetupBack">← Ana Menü</button>
</div>

<!-- ════════════ WL GAME ════════════ -->
<div id="screen-wl-game" class="screen" style="justify-content:flex-start;padding-top:18px;padding-bottom:20px;gap:0;">
  <div class="game-top">
    <div class="round-badge" id="wlRound">TUR 1 / 10</div>
    <button class="btn btn-ghost btn-sm" id="btnWlHome" style="padding:6px 10px;">🏠</button>
  </div>
  <div class="scores-row">
    <div class="score-card" id="wlSc0"><div class="sc-team" id="wlSN0">TAKIM 1</div><div class="sc-score" id="wlSS0">0</div></div>
    <div class="score-card" id="wlSc1"><div class="sc-team" id="wlSN1">TAKIM 2</div><div class="sc-score" id="wlSS1">0</div></div>
  </div>
  <div class="concept-bar">
    <div class="concept-word c-left" id="wlCL">SICAK</div>
    <div class="concept-sep">↔</div>
    <div class="concept-word c-right" id="wlCR">SOĞUK</div>
  </div>
  <div class="dial-wrap"><canvas id="dialCanvas" height="170"></canvas></div>
  <div class="phase-strip" style="margin-top:4px;margin-bottom:4px;">Aşama: <span id="wlPhase">—</span></div>
  <div class="clue-box" id="wlClueBox">
    <div class="clue-lbl" id="wlClueLbl">İPUCU</div>
    <input class="clue-in" id="wlClueIn" placeholder="Kelime ipucu..." maxlength="30" autocomplete="off">
  </div>
  <div id="wlBanner" style="display:none;margin-top:4px;"></div>
  <div class="game-actions">
    <button class="btn btn-ghost btn-sm" style="flex:0;padding:12px 14px;" id="btnWlCog">⚙️</button>
    <button class="btn btn-cyan btn-sm" id="btnWlAction" style="flex:1;font-size:13px;">HAZIR →</button>
  </div>
</div>

<!-- ════════════ WL FINAL ════════════ -->
<div id="screen-wl-final" class="screen" style="text-align:center;gap:14px;">
  <div class="winner-badge" id="wlWinIcon">🏆</div>
  <div class="winner-title">KAZANAN TAKIM</div>
  <div class="winner-name" id="wlWinName">—</div>
  <div class="final-scores" id="wlFinalScores"></div>
  <button class="btn btn-cyan" id="btnWlAgain">TEKRAR OYNA 🔄</button>
  <button class="btn btn-outline" id="btnWlFinalHome">← Ana Menü</button>
</div>

<!-- ════════════ IMP SETUP ════════════ -->
<div id="screen-imp-setup" class="screen screen-top" style="gap:13px;">
  <div class="title-xl" style="font-size:26px;align-self:flex-start;">🕵️ IMPOSTER</div>
  <div class="label-sm">Oyuncular (En az 3)</div>
  <div class="players-list" id="impList"></div>
  <div style="display:flex;gap:10px;width:100%;">
    <div class="input-row" style="flex:1;"><input type="text" id="impPInput" placeholder="Oyuncu adı..." maxlength="16"></div>

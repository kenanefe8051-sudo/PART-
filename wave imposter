function wlPick(){
  let pool=WL_CONCEPTS.map((_,i)=>i).filter(i=>!wl.used.includes(i));
  if(!pool.length){wl.used=[];pool=WL_CONCEPTS.map((_,i)=>i);}
  const i=pool[Math.floor(Math.random()*pool.length)];wl.used.push(i);return WL_CONCEPTS[i];
}
function wlNew(){wl.concept=wlPick();wl.target=15+Math.random()*150;wl.needle=90;wl.clue='';wl.phase='reveal';wlRender();}

function wlRender(){
  const T=wl.teams,ct=wl.ct,gt=wl.gt;
  document.getElementById('wlRound').textContent=`TUR ${wl.round} / ${wl.total}`;
  // Scores
  [0,1].forEach(i=>{
    const el=document.getElementById('wlSc'+i);
    const active=(wl.phase==='guess'||wl.phase==='result')?gt:ct;
    el.className='score-card'+(i===active?(i===0?' sc-a':' sc-b'):'');
    document.getElementById('wlSN'+i).textContent=T[i].name.toUpperCase();
    document.getElementById('wlSS'+i).textContent=T[i].score;
  });
  // Concept
  document.getElementById('wlCL').textContent=wl.concept[0];
  document.getElementById('wlCR').textContent=wl.concept[1];
  // Phase
  const pl=document.getElementById('wlPhase');
  const ctT0=ct===0,gtT0=gt===0;
  if(wl.phase==='reveal'){pl.className=ctT0?'':'pink';pl.textContent=`${T[ct].name} hedefi görüyor`;}
  else if(wl.phase==='clue'){pl.className=ctT0?'':'pink';pl.textContent=`${T[ct].name} — İpucu Veriyor`;}
  else if(wl.phase==='guess'){pl.className=gtT0?'':'pink';pl.textContent=`${T[gt].name} — Tahmin Ediyor`;}
  else{pl.className='';pl.textContent='Sonuç!';}
  // Clue box
  const box=document.getElementById('wlClueBox');
  const inp=document.getElementById('wlClueIn');
  const lbl=document.getElementById('wlClueLbl');
  box.querySelectorAll('.clue-show,.reveal-inf').forEach(e=>e.remove());
  if(wl.phase==='reveal'){
    box.className='clue-box'+(ctT0?'':' pink-mode');box.style.display='flex';
    lbl.textContent='HEDEFİ GÖR — İPUCU HAZIRLA';inp.style.display='none';
    const d=document.createElement('div');d.className='reveal-inf';
    d.style.cssText='font-size:13px;color:rgba(232,244,244,.6);line-height:1.7;text-align:center;';
    d.innerHTML=`Parlak bölge <b style="color:var(--accent)">hedef alandır</b>.<br>Diğer takım bakmasın!<br><span style="color:${ctT0?'var(--accent)':'var(--accent2)'};">${wl.concept[0]} ↔ ${wl.concept[1]}</span>`;
    box.appendChild(d);
  } else if(wl.phase==='clue'){
    box.className='clue-box'+(ctT0?'':' pink-mode');box.style.display='flex';
    lbl.textContent='İPUCUNU YAZ (1 KELİME)';inp.style.display='block';
    inp.value=wl.clue;inp.disabled=false;setTimeout(()=>inp.focus(),100);
  } else if(wl.phase==='guess'){
    box.className='clue-box'+(gtT0?'':' pink-mode');box.style.display='flex';
    lbl.textContent='VERİLEN İPUCU';inp.style.display='none';
    const d=document.createElement('div');d.className='clue-show';
    d.textContent=wl.clue||'—';d.style.color=gtT0?'var(--accent)':'var(--accent2)';
    box.appendChild(d);
  } else {
    box.style.display='none';
  }
  if(wl.phase!=='result') document.getElementById('wlBanner').style.display='none';
  // Button
  const btn=document.getElementById('btnWlAction');
  btn.style.flex='1';btn.style.fontSize='13px';
  if(wl.phase==='reveal'){btn.textContent='HAZIR — İPUCU GİR →';btn.className='btn btn-sm'+(ctT0?' btn-cyan':' btn-pink');}
  else if(wl.phase==='clue'){btn.textContent='İPUCU KİLİTLE 🔒';btn.className='btn btn-sm'+(ctT0?' btn-cyan':' btn-pink');}
  else if(wl.phase==='guess'){btn.textContent='TAHMİN ET ✓';btn.className='btn btn-sm'+(gtT0?' btn-cyan':' btn-pink');}
  else{btn.textContent=wl.round>=wl.total?'OYUNU BİTİR 🏁':'SONRAKİ TUR →';btn.className='btn btn-cyan btn-sm';}
  wlDraw();
}

document.getElementById('btnWlAction').addEventListener('click',wlAction);
document.getElementById('wlClueIn').addEventListener('keydown',e=>{if(e.key==='Enter')wlAction();});

function wlAction(){
  if(wl.phase==='reveal'){wl.phase='clue';wlRender();}
  else if(wl.phase==='clue'){
    const v=document.getElementById('wlClueIn').value.trim();
    if(!v){const i=document.getElementById('wlClueIn');i.style.borderColor='rgba(255,78,205,.6)';i.placeholder='Bir kelime yaz!';setTimeout(()=>{i.style.borderColor='';i.placeholder='Kelime ipucu...';},1000);return;}
    wl.clue=v;wl.needle=90;wl.phase='guess';wlRender();
  } else if(wl.phase==='guess'){
    wl.phase='result';
    const diff=Math.abs(wl.needle-wl.target);
    let pts=0;if(diff<=4)pts=4;else if(diff<=9)pts=3;else if(diff<=16)pts=2;else if(diff<=24)pts=1;
    wl.teams[wl.gt].score+=pts;wlRender();
    const bn=document.getElementById('wlBanner');bn.style.display='block';
    bn.textContent={4:'🎯 TAM 12! +4 PUAN',3:'✦ ÇOK YAKIN! +3 PUAN',2:'~ YAKIN! +2 PUAN',1:'△ AZ KALDI! +1 PUAN',0:'✕ ISKALADIN! 0 PUAN'}[pts];
    bn.className='res-banner r'+pts;
    if(pts>=3){sndSuccess();confetti();}else if(pts===0)sndFail();else sndOk();
    wlDraw();
  } else {
    if(wl.round>=wl.total){wlFinal();}
    else{wl.round++;const tmp=wl.ct;wl.ct=wl.gt;wl.gt=tmp;wlNew();}
  }
}

function wlFinal(){
  const s=[...wl.teams].sort((a,b)=>b.score-a.score);
  const draw=wl.teams[0].score===wl.teams[1].score;
  document.getElementById('wlWinIcon').textContent=draw?'🤝':'🏆';
  document.getElementById('wlWinName').textContent=draw?'BERABERE!':s[0].name.toUpperCase();

    </div>`).join('');
  show('screen-wl-final');setTimeout(()=>confetti(),200);
}

/* ── DIAL ── */
function wlDraw(){
  const cv=document.getElementById('dialCanvas');
  const W=cv.offsetWidth||420;cv.width=W;cv.height=170;
  const ctx=cv.getContext('2d');ctx.clearRect(0,0,W,170);
  const cx=W/2,cy=162,r=148;
  ctx.beginPath();ctx.arc(cx,cy,r,Math.PI,2*Math.PI);ctx.strokeStyle='rgba(255,255,255,.06)';ctx.lineWidth=32;ctx.stroke();
  const gr=ctx.createLinearGradient(0,0,W,0);
  gr.addColorStop(0,'rgba(255,138,138,.15)');gr.addColorStop(.5,'rgba(59,255,216,.08)');gr.addColorStop(1,'rgba(122,173,255,.15)');
  ctx.beginPath();ctx.arc(cx,cy,r,Math.PI,2*Math.PI);ctx.strokeStyle=gr;ctx.lineWidth=32;ctx.stroke();
  if(wl.phase==='reveal'||wl.phase==='result'){
    [{s:50,c:'rgba(249,115,22,.2)'},{s:32,c:'rgba(251,191,36,.3)'},{s:18,c:'rgba(59,255,216,.4)'},{s:8,c:'rgba(59,255,216,.85)'}].forEach(z=>{
      const a1=Math.PI+(wl.target-z.s/2)/180*Math.PI,a2=Math.PI+(wl.target+z.s/2)/180*Math.PI;
      ctx.beginPath();ctx.arc(cx,cy,r,a1,a2);ctx.strokeStyle=z.c;ctx.lineWidth=32;ctx.stroke();
    });
    const ta=Math.PI+wl.target/180*Math.PI;
    ctx.beginPath();ctx.moveTo(cx+Math.cos(ta)*(r-22),cy+Math.sin(ta)*(r-22));ctx.lineTo(cx+Math.cos(ta)*(r+6),cy+Math.sin(ta)*(r+6));
    ctx.strokeStyle='#fff';ctx.lineWidth=3;ctx.lineCap='round';ctx.stroke();
    ctx.beginPath();ctx.arc(cx+Math.cos(ta)*r,cy+Math.sin(ta)*r,9,0,2*Math.PI);
    ctx.fillStyle='rgba(255,255,255,.3)';ctx.shadowColor='#3BFFD8';ctx.shadowBlur=16;ctx.fill();ctx.shadowBlur=0;
    if(wl.phase==='reveal'){ctx.font='bold 10px "Space Mono",monospace';ctx.fillStyle='rgba(59,255,216,.9)';ctx.textAlign='center';ctx.fillText('HEDEF',cx+Math.cos(ta)*(r-52),cy+Math.sin(ta)*(r-52));}
  }
  for(let i=0;i<=18;i++){
    const a=Math.PI+(i/18)*Math.PI,len=i%3===0?14:7,ro=r+18;
    ctx.beginPath();ctx.moveTo(cx+Math.cos(a)*ro,cy+Math.sin(a)*ro);ctx.lineTo(cx+Math.cos(a)*(ro-len),cy+Math.sin(a)*(ro-len));
    ctx.strokeStyle=i%3===0?'rgba(255,255,255,.2)':'rgba(255,255,255,.08)';ctx.lineWidth=i%3===0?2:1;ctx.stroke();
  }
  if(wl.phase==='guess'||wl.phase==='result'){
    const na=Math.PI+wl.needle/180*Math.PI,nc=wl.gt===0?'#3BFFD8':'#FF4ECD';
    ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(cx+Math.cos(na)*(r+14),cy+Math.sin(na)*(r+14));
    ctx.shadowColor=nc;ctx.shadowBlur=wl.phase==='guess'?14:6;ctx.strokeStyle=nc;ctx.lineWidth=4;ctx.lineCap='round';ctx.stroke();ctx.shadowBlur=0;
    ctx.beginPath();ctx.arc(cx,cy,10,0,2*Math.PI);ctx.fillStyle=nc;ctx.shadowColor=nc;ctx.shadowBlur=wl.phase==='guess'?18:4;ctx.fill();ctx.shadowBlur=0;
    if(wl.phase==='guess'){ctx.font='bold 11px "Space Mono",monospace';ctx.fillStyle='rgba(255,255,255,.45)';ctx.textAlign='center';ctx.fillText(Math.round(wl.needle)+'°',cx,cy-16);}
  } else {
    ctx.beginPath();ctx.arc(cx,cy,8,0,2*Math.PI);ctx.fillStyle='rgba(255,255,255,.12)';ctx.fill();
    ctx.beginPath();ctx.arc(cx,cy,3,0,2*Math.PI);ctx.fillStyle='rgba(255,255,255,.25)';ctx.fill();
  }
}

function wlAngle(e,cv){
  const rc=cv.getBoundingClientRect();
  const x=(e.touches?e.touches[0].clientX:e.clientX)-rc.left-rc.width/2;
  const y=(e.touches?e.touches[0].clientY:e.clientY)-rc.top-162;
  let a=Math.atan2(y,x)*180/Math.PI-180;if(a<0)a+=360;return Math.max(0,Math.min(180,a));
}
function wlSetupDial(){
  const cv=document.getElementById('dialCanvas');
  cv.removeEventListener('mousedown',wlMD);cv.removeEventListener('touchstart',wlTS);
  cv.addEventListener('mousedown',wlMD);cv.addEventListener('touchstart',wlTS,{passive:false});
}
function wlMD(e){if(wl.phase!=='guess')return;wl.drag=true;wl.needle=wlAngle(e,e.currentTarget);wlDraw();document.addEventListener('mousemove',wlMV);document.addEventListener('mouseup',wlMU);}
function wlMV(e){if(!wl.drag||wl.phase!=='guess')return;e.preventDefault();wl.needle=wlAngle(e,document.getElementById('dialCanvas'));wlDraw();}
function wlMU(){wl.drag=false;document.removeEventListener('mousemove',wlMV);document.removeEventListener('mouseup',wlMU);}
function wlTS(e){if(wl.phase!=='guess')return;e.preventDefault();wl.needle=wlAngle(e,e.currentTarget);wlDraw();e.currentTarget.addEventListener('touchmove',wlTM,{passive:false});e.currentTarget.addEventListener('touchend',wlTE);}
function wlTM(e){if(wl.phase!=='guess')return;e.preventDefault();wl.needle=wlAngle(e,e.currentTarget);wlDraw();}
function wlTE(e){e.currentTarget.removeEventListener('touchmove',wlTM);e.currentTarget.removeEventListener('touchend',wlTE);}
window.addEventListener('resize',()=>{if(document.getElementById('screen-wl-game').classList.contains('active'))wlDraw();});


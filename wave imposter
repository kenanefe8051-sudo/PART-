════════════════════════════════════ */
const IMP_POOL=[
  "Hastane","Havalimanı","Uzay Gemisi","Denizaltı","Kütüphane","Stadyum","Sinema","Restoran",
  "Banka","Hayvanat Bahçesi","Plaj","Lunapark","Sirk","Bilgisayar","Telefon","Bisiklet","Gitar",
  "Düğün","Cenaze","Hamam","Hapishane","Üniversite","Karakol","Otobüs Terminali","Kuaför",
  "Konser","Müze","Buzul","Okul","Piknik","Çöl","Dağ Evi","Disko","Tren","Yat","Çiftlik",
  "Uzay İstasyonu","Roket","Robot","Akvaryum","Kale","Tekne","Manastır","Fuar","Tiyatro",
  "Buz Pateni Pisti","Kumarevi","Sirkü","Bataklık","Mağara","Orman","Saray","Fabrika",
];

let imp={players:[],cWords:[],roles:[],idx:0,word:''};

document.getElementById('btnImpSetupBack').addEventListener('click',()=>show('screen-menu'));
document.getElementById('btnImpDiscHome').addEventListener('click',()=>show('screen-menu'));
document.getElementById('btnImpReplay').addEventListener('click',()=>startImp());

document.getElementById('btnImpAdd').addEventListener('click',impAddP);
document.getElementById('impPInput').addEventListener('keydown',e=>{if(e.key==='Enter')impAddP();});
document.getElementById('btnImpAddW').addEventListener('click',impAddW);
document.getElementById('impWInput').addEventListener('keydown',e=>{if(e.key==='Enter')impAddW();});

function impAddP(){
  const i=document.getElementById('impPInput');
  const n=i.value.trim();if(!n||imp.players.includes(n)){i.value='';return;}
  if(imp.players.length>=15)return;
  imp.players.push(n);i.value='';impRender();
}
function impRemP(n){imp.players=imp.players.filter(p=>p!==n);impRender();}
function impRender(){
  document.getElementById('impList').innerHTML=imp.players.map((p,i)=>`
    <div class="player-tag">
      <div class="player-left">
        <div style="width:10px;height:10px;border-radius:50%;background:${DOT_COLORS[i%8]};flex-shrink:0;"></div>
        <div class="player-name">${p}</div>
      </div>
      <button class="remove-x" onclick="impRemP('${p}')">✕</button>
    </div>`).join('');
}

function impAddW(){
  const i=document.getElementById('impWInput');
  const w=i.value.trim();if(!w)return;
  if(!imp.cWords.includes(w))imp.cWords.push(w);
  i.value='';impRenderW();
}
function impRemW(w){imp.cWords=imp.cWords.filter(x=>x!==w);impRenderW();}
function impRenderW(){
  document.getElementById('impCTags').innerHTML=imp.cWords.map(w=>`
    <div class="ctag">${w}<button onclick="impRemW('${w}')">✕</button></div>`).join('');
  document.getElementById('impWordInfo').textContent=imp.cWords.length>0
    ?`${imp.cWords.length} özel kelime — SADECE BUNLAR ÇIKACAK`
    :'Kelime eklenmedi — hazır havuz kullanılacak';
}

document.getElementById('btnStartImp').addEventListener('click',()=>{
  if(imp.players.length<3){alert('En az 3 oyuncu gerekli!');return;}
  startImp();
});

function startImp(){
  const pool=imp.cWords.length>0?imp.cWords:IMP_POOL;
  imp.word=pool[Math.floor(Math.random()*pool.length)];
  const sh=[...imp.players].sort(()=>Math.random()-.5);
  const ii=Math.floor(Math.random()*sh.length);
  imp.roles=sh.map((name,i)=>({name,isImp:i===ii,word:i===ii?'SEN IMPOSTERSIN!':imp.word}));
  imp.idx=0;impShowPass();
}

function impShowPass(){
  if(imp.idx>=imp.roles.length){
    document.getElementById('impRevealWord').textContent=imp.word;
    show('screen-imp-discuss');sndSuccess();return;
  }
  document.getElementById('impPassName').textContent=imp.roles[imp.idx].name;
  show('screen-imp-pass');
}

document.getElementById('btnImpReveal').addEventListener('click',()=>{
  sndFlip();
  const p=imp.roles[imp.idx];
  const box=document.getElementById('impSecretBox');
  box.className='secret-box '+(p.isImp?'secret-imp':'secret-crew');
  document.getElementById('impRoleIcon').textContent=p.isImp?'🕵️':'✅';
  document.getElementById('impSecretWord').textContent=p.word;
  document.getElementById('impRoleDesc').innerHTML=p.isImp
    ?`Diğerleri bir kelime biliyor, <b style="color:var(--red)">sen bilmiyorsun!</b><br>Doğalmış gibi davran, yakalanma.`
    :`Bu kelimeyi bil, ipucu verirken <b style="color:var(--accent)">doğal görün</b>. Imposter'ı ele verme!`;
  show('screen-imp-secret');
});

document.getElementById('btnImpHide').addEventListener('click',()=>{
  sndFlip();imp.idx++;impShowPass();
});
</script>
</body>
</html>

function wlPickConcept(){
  const remaining = WL_CONCEPTS.filter((_,i)=>!wl.usedConcepts.includes(i));
  if(remaining.length===0){ wl.usedConcepts=[]; }
  const pool = wl.usedConcepts.length<WL_CONCEPTS.length ? WL_CONCEPTS.filter((_,i)=>!wl.usedConcepts.includes(i)) : WL_CONCEPTS;
  const idx = WL_CONCEPTS.indexOf(pool[Math.floor(Math.random()*pool.length)]);
  wl.usedConcepts.push(idx);
  return WL_CONCEPTS[idx];
}


function wlDrawDial(){
  const canvas = document.getElementById('wlCanvas');
  const W = canvas.offsetWidth || 360;
  canvas.width = W;
  canvas.height = 160;
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0,0,W,160);

  const cx = W/2, cy = 150, r = 135;

  // Arka plan yay
  ctx.beginPath();
  ctx.arc(cx,cy,r,Math.PI,2*Math.PI);
  ctx.strokeStyle='rgba(255,255,255,.08)';
  ctx.lineWidth=28;
  ctx.stroke();

  if(wl.phase==='result'){
    // Hedef bölgeleri göster
    const target = wl.targetAngle; // 0-180
    // 4 puan: ±8 derece
    // 3 puan: ±16 derece
    // 2 puan: ±24 derece
    const zones=[
      {pts:2,spread:32,color:'rgba(251,191,36,.35)'},
      {pts:3,spread:18,color:'rgba(34,197,94,.45)'},
      {pts:4,spread:8,color:'rgba(34,197,94,.75)'},
    ];
    zones.forEach(z=>{
      const a1 = Math.PI + (target-z.spread/2)/180*Math.PI;
      const a2 = Math.PI + (target+z.spread/2)/180*Math.PI;
      ctx.beginPath();
      ctx.arc(cx,cy,r,a1,a2);
      ctx.strokeStyle=z.color;
      ctx.lineWidth=28;
      ctx.stroke();
    });
    // Hedef çizgisi
    const ta = Math.PI + target/180*Math.PI;
    ctx.beginPath();
    ctx.moveTo(cx+Math.cos(ta)*(r-20),cy+Math.sin(ta)*(r-20));
    ctx.lineTo(cx+Math.cos(ta)*(r+4),cy+Math.sin(ta)*(r+4));
    ctx.strokeStyle='#fff';
    ctx.lineWidth=3;
    ctx.stroke();
  }

  // İğne
  const needleA = Math.PI + wl.needleAngle/180*Math.PI;
  ctx.beginPath();
  ctx.moveTo(cx,cy);
  ctx.lineTo(cx+Math.cos(needleA)*(r+8),cy+Math.sin(needleA)*(r+8));
  ctx.strokeStyle= wl.phase==='guess'?'#ffd93d':'rgba(255,255,255,.4)';
  ctx.lineWidth=4;
  ctx.lineCap='round';
  ctx.stroke();
  // İğne topu
  ctx.beginPath();
  ctx.arc(cx,cy,8,0,2*Math.PI);
  ctx.fillStyle= wl.phase==='guess'?'#ffd93d':'rgba(255,255,255,.3)';
  ctx.fill();

  // Sol/Sağ etiket
  ctx.font='bold 13px Nunito,sans-serif';
  ctx.fillStyle='rgba(255,107,107,.8)';
  ctx.textAlign='left';
  ctx.fillText(wl.concept ? wl.concept[0] : '', 6, 148);
  ctx.fillStyle='rgba(77,150,255,.8)';
  ctx.textAlign='right';
  ctx.fillText(wl.concept ? wl.concept[1] : '', W-6, 148);

  // Ortada derece göstergesi (sadece tahmin aşamasında)
  if(wl.phase==='guess'){
    ctx.font='bold 11px Nunito,sans-serif';
    ctx.fillStyle='rgba(255,217,61,.6)';
    ctx.textAlign='center';
    ctx.fillText(Math.round(wl.needleAngle)+'°', cx, cy-12);
  }
}

// Kadran dokunma/tıklama
function wlSetupDial(){
  const canvas = document.getElementById('wlCanvas');

  function getAngle(e){
    const rect = canvas.getBoundingClientRect();
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    const x = clientX - rect.left - rect.width/2;
    const y = clientY - rect.top - 150;
    let angle = Math.atan2(y, x) * 180 / Math.PI - 180;
    if(angle < 0) angle += 360;
    // 0-180 arasına sıkıştır
    angle = Math.max(0, Math.min(180, angle));
    return angle;
  }

  function onMove(e){
    if(wl.phase!=='guess') return;
    e.preventDefault();
    wl.needleAngle = getAngle(e);
    wlDrawDial();
  }

  canvas.addEventListener('mousedown', e=>{if(wl.phase==='guess'){wl.dragging=true;wl.needleAngle=getAngle(e);wlDrawDial();}});
  canvas.addEventListener('mousemove', e=>{if(wl.dragging) onMove(e);});
  canvas.addEventListener('mouseup', ()=>wl.dragging=false);
  canvas.addEventListener('touchstart', e=>{if(wl.phase==='guess'){wl.needleAngle=getAngle(e);wlDrawDial();}},{passive:false});
  canvas.addEventListener('touchmove', onMove, {passive:false});
}

function wlHandleAction(){
  if(wl.phase==='clue'){
    const inp = document.getElementById('wlClueInput').value.trim();
    if(!inp){alert('Bir ipucu yaz!');return;}
    wl.clue = inp;
    wl.phase='guess';
    wlRender();
  } else if(wl.phase==='guess'){
    wl.phase='result';
    // Puan hesapla
    const diff = Math.abs(wl.needleAngle - wl.targetAngle);
    let pts = 0;
    if(diff<=4) pts=4;
    else if(diff<=9) pts=3;
    else if(diff<=16) pts=2;
    else if(diff<=24) pts=1;
    wl.teams[wl.activeTeam].score += pts;
    wlRender();
    // Sonuç banner
    const banner = document.getElementById('wlResultBanner');
    banner.style.display='block';
    const msgs = {4:'🎯 Tam 12! +4 Puan!',3:'🟢 Çok Yakın! +3 Puan',2:'🟡 Yakın! +2 Puan',1:'🟠 Az Kaldı! +1 Puan',0:'❌ Iskaladın! 0 Puan'};
    banner.textContent = msgs[pts];
    banner.className = 'wl-result-banner wl-result-'+pts;
    if(pts>=3) launchConfetti();
    playSoundCorrect();
  } else {
    // Sonraki tur
    wl.activeTeam = 1 - wl.activeTeam;
    wl.round++;
    wlNewRound();
  }
}


<!DOCTYPE html>
<meta name="robots" content="noindex">
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Parti Oyunları 🎉</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;700;900&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{touch-action:manipulation;height:100%;}
body{font-family:'Nunito',sans-serif;background:#0e0b1a;color:#fff;
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  overflow:hidden;position:relative;}
body::before{content:'';position:fixed;inset:0;pointer-events:none;
  background:radial-gradient(ellipse at 20% 20%,rgba(255,107,107,.15) 0%,transparent 50%),
    radial-gradient(ellipse at 80% 80%,rgba(77,150,255,.15) 0%,transparent 50%),
    radial-gradient(ellipse at 50% 50%,rgba(199,125,255,.08) 0%,transparent 60%);}
.screen{display:none;width:100%;max-width:420px;min-height:100vh;
  padding:28px 20px;flex-direction:column;align-items:center;
  justify-content:center;position:relative;z-index:1;gap:16px;}
.screen.active{display:flex;}
#screen-splash{text-align:center;}
.splash-emoji{font-size:72px;animation:bounce 2s infinite;display:block;}
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
.splash-title{font-family:'Bebas Neue',cursive;font-size:52px;line-height:1;
  background:linear-gradient(135deg,#ff6b6b,#ffd93d,#c77dff);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  filter:drop-shadow(0 0 20px rgba(255,107,107,.4));}
.splash-sub{font-size:15px;color:rgba(255,255,255,.45);margin-top:-4px;margin-bottom:12px;}
#screen-pick{gap:16px;}
.pick-title{font-family:'Bebas Neue',cursive;font-size:34px;letter-spacing:1px;text-align:center;}
.game-cards{display:flex;flex-direction:column;gap:12px;width:100%;}
.game-card{width:100%;border:none;border-radius:20px;padding:20px 22px;
  display:flex;align-items:center;gap:16px;text-align:left;
  -webkit-appearance:none;user-select:none;touch-action:manipulation;cursor:pointer;}
.game-card:active{opacity:.82;}
.gc-mlto{background:linear-gradient(135deg,#ff6b6b,#ff4757);box-shadow:0 10px 28px rgba(255,71,87,.4);}
.gc-bottle{background:linear-gradient(135deg,#f5a623,#e8850a);box-shadow:0 10px 28px rgba(245,166,35,.4);}
.gc-tabu{background:linear-gradient(135deg,#a855f7,#7c3aed);box-shadow:0 10px 28px rgba(168,85,247,.4);}
.gc-icon{font-size:40px;flex-shrink:0;}
.gc-name{font-family:'Bebas Neue',cursive;font-size:24px;color:#fff;letter-spacing:.5px;}
.gc-desc{font-size:12px;color:rgba(255,255,255,.7);margin-top:2px;font-weight:600;}
.btn{width:100%;padding:16px;border:none;border-radius:14px;
  font-family:'Nunito',sans-serif;font-size:16px;font-weight:900;
  -webkit-appearance:none;user-select:none;touch-action:manipulation;cursor:pointer;
  transition:opacity .15s;}
.btn:active{opacity:.78;}
.btn:disabled{opacity:0.4;cursor:not-allowed;}
.btn-red{background:linear-gradient(135deg,#ff6b6b,#ff4757);color:#fff;box-shadow:0 8px 22px rgba(255,71,87,.35);}
.btn-amber{background:linear-gradient(135deg,#f5a623,#e8850a);color:#fff;box-shadow:0 8px 22px rgba(245,166,35,.4);}
.btn-purple{background:linear-gradient(135deg,#a855f7,#7c3aed);color:#fff;box-shadow:0 8px 22px rgba(168,85,247,.4);}
.btn-green{background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff;box-shadow:0 8px 22px rgba(34,197,94,.4);}
.btn-orange{background:linear-gradient(135deg,#f97316,#ea580c);color:#fff;box-shadow:0 8px 22px rgba(249,115,22,.4);}
.btn-secondary{background:rgba(255,255,255,.1);color:rgba(255,255,255,.7);border:1.5px solid rgba(255,255,255,.1);}
.btn-ghost{background:transparent;color:rgba(255,255,255,.35);font-size:14px;padding:10px;}
.btn-small{width:auto;padding:10px 18px;font-size:14px;border-radius:12px;}
#screen-setup{justify-content:flex-start;padding-top:48px;}
.section-title{font-family:'Bebas Neue',cursive;font-size:22px;letter-spacing:1px;align-self:flex-start;}
.players-list{width:100%;display:flex;flex-direction:column;gap:9px;max-height:190px;overflow-y:auto;}
.player-tag{display:flex;align-items:center;justify-content:space-between;
  background:rgba(255,255,255,.1);border-radius:12px;padding:11px 15px;animation:slideIn .2s ease;}
@keyframes slideIn{from{opacity:0;transform:translateX(-16px)}to{opacity:1;transform:translateX(0)}}
.player-dot{width:10px;height:10px;border-radius:50%;margin-right:10px;flex-shrink:0;}
.player-left{display:flex;align-items:center;}
.player-name{font-weight:700;font-size:15px;}
.remove-btn{background:none;border:none;color:rgba(255,255,255,.25);font-size:17px;padding:6px 8px;
  cursor:pointer;touch-action:manipulation;-webkit-appearance:none;}
.input-row{display:flex;gap:10px;width:100%;}
input[type=text]{flex:1;background:rgba(255,255,255,.1);border:1.5px solid rgba(255,255,255,.1);
  border-radius:12px;padding:13px 15px;color:#fff;font-family:'Nunito',sans-serif;
  font-size:15px;outline:none;transition:border-color .2s;}
input[type=text]:focus{border-color:rgba(255,107,107,.55);}
input[type=text]::placeholder{color:rgba(255,255,255,.22);}
.add-btn{background:linear-gradient(135deg,#ff6b6b,#ff4757);border:none;border-radius:12px;
  width:50px;height:50px;font-size:22px;color:#fff;cursor:pointer;flex-shrink:0;
  touch-action:manipulation;-webkit-appearance:none;}
.mode-tabs{display:flex;gap:6px;width:100%;background:rgba(255,255,255,.08);border-radius:14px;padding:5px;}
.mode-tab{flex:1;padding:10px 5px;border:none;border-radius:10px;
  font-family:'Nunito',sans-serif;font-weight:700;font-size:13px;
  background:transparent;color:rgba(255,255,255,.38);
  cursor:pointer;touch-action:manipulation;-webkit-appearance:none; text-align:center;}
.mode-tab.active{background:#fff;color:#0e0b1a;}
.hint{font-size:12px;color:rgba(255,255,255,.28);text-align:center;}
#mltOptions{width:100%;display:flex;flex-direction:column;gap:10px;}
#screen-game{gap:0;justify-content:space-between;padding-top:38px;padding-bottom:26px;}
.game-header{display:flex;justify-content:space-between;align-items:center;width:100%;margin-bottom:16px;}
.progress-wrap{flex:1;height:5px;background:rgba(255,255,255,.1);border-radius:99px;overflow:hidden;}
.progress-bar{height:100%;background:linear-gradient(90deg,#ff6b6b,#ffd93d);border-radius:99px;transition:width .4s ease;}
.card-count{font-size:12px;color:rgba(255,255,255,.35);margin-left:12px;white-space:nowrap;}
.card-area{flex:1;display:flex;align-items:center;justify-content:center;width:100%;perspective:1000px;}
.card-wrapper{width:100%;max-width:360px;height:450px;position:relative;}
.card{width:100%;height:100%;position:absolute;border-radius:28px;cursor:pointer;
  transition:transform .7s cubic-bezier(.175,.885,.32,1.275);transform-style:preserve-3d;}
.card.flipped{transform:rotateY(180deg);}
.card-face{position:absolute;inset:0;border-radius:28px;display:flex;flex-direction:column;
  align-items:center;justify-content:center;padding:26px 22px;
  backface-visibility:hidden;-webkit-backface-visibility:hidden;}
.card-back{background:linear-gradient(145deg,#1a1530,#221c3d);
  border:1.5px solid rgba(255,255,255,.07);
  box-shadow:0 20px 60px rgba(0,0,0,.5),inset 0 1px 0 rgba(255,255,255,.05);}
.card-back-icon{font-size:68px;margin-bottom:12px;filter:drop-shadow(0 0 18px rgba(255,107,107,.3));}
.card-back-text{font-size:13px;color:rgba(255,255,255,.22);}
.card-front{transform:rotateY(180deg);color:#fff;text-align:center;}
.card-label{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;opacity:.55;margin-bottom:8px;}
.card-question{font-family:'Bebas Neue',cursive;font-size:30px;line-height:1.2;margin-bottom:18px;}
.vote-section{width:100%;margin-top:8px;}
.vote-grid{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;}
.vote-btn{background:rgba(255,255,255,.13);border:1.5px solid rgba(255,255,255,.18);
  border-radius:12px;padding:8px 12px;color:#fff;
  font-family:'Nunito',sans-serif;font-weight:700;font-size:13px;
  cursor:pointer;touch-action:manipulation;-webkit-appearance:none;}
.vote-btn.selected{background:rgba(255,255,255,.92);color:#0e0b1a;border-color:#fff;transform:scale(1.05);}
.game-actions{display:flex;gap:10px;width:100%;margin-top:14px;}
.voter-banner{width:100%;background:rgba(255,255,255,.08);border:1.5px solid rgba(255,255,255,.12);
  border-radius:14px;padding:10px 16px;display:flex;align-items:center;gap:10px;margin-bottom:6px;}
.voter-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0;}
.voter-label{font-size:11px;color:rgba(255,255,255,.4);font-weight:700;letter-spacing:1px;text-transform:uppercase;}
.voter-name{font-family:'Bebas Neue',cursive;font-size:20px;color:#fff;line-height:1;}
.voter-progress{font-size:11px;color:rgba(255,255,255,.3);margin-left:auto;}
.vote-tally{width:100%;display:flex;flex-direction:column;gap:5px;margin-top:8px;}
.tally-row{display:flex;align-items:center;gap:8px;padding:5px 0;}
.tally-name{font-size:13px;font-weight:700;min-width:70px;color:rgba(255,255,255,.8);}
.tally-bar-wrap{flex:1;height:8px;background:rgba(255,255,255,.1);border-radius:99px;overflow:hidden;}
.tally-bar{height:100%;border-radius:99px;background:linear-gradient(90deg,#ff6b6b,#ffd93d);transition:width .4s ease;}
.tally-count{font-family:'Bebas Neue',cursive;font-size:16px;color:#ffd93d;min-width:20px;text-align:right;}
#screen-bottle{gap:0;justify-content:space-between;padding-top:34px;padding-bottom:26px;}
.bottle-header{width:100%;display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.bottle-title-bar{font-family:'Bebas Neue',cursive;font-size:26px;letter-spacing:1px;}
.bottle-round{font-size:12px;color:rgba(255,255,255,.35);}
.bottle-arena{flex:1;display:flex;align-items:center;justify-content:center;width:100%;}
.bottle-wheel{position:relative;width:320px;height:320px;}
.pdot-wrap{position:absolute;}
.pdot{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-weight:900;font-size:10px;text-align:center;border:2.5px solid rgba(255,255,255,.18);
  transition:all .5s cubic-bezier(.34,1.56,.64,1);line-height:1.2;padding:3px;color:#fff;}
.pdot.highlighted{border-color:#ffd93d;box-shadow:0 0 0 5px rgba(255,217,61,.3),0 0 30px rgba(255,217,61,.7);transform:scale(1.28);}
#bottleWrap{position:absolute;top:50%;left:50%;width:70px;height:150px;margin-left:-35px;margin-top:-75px;
  cursor:pointer;transform-origin:50% 50%;transform:rotate(0deg);will-change:transform;touch-action:manipulation;}
@keyframes idleWiggle{0%,100%{transform:rotate(-5deg);}50%{transform:rotate(5deg);}}
#bottleWrap.idle-hint{animation:idleWiggle 2s ease-in-out infinite;}
.bottle-result{width:100%;min-height:84px;background:rgba(255,255,255,.1);border-radius:18px;padding:14px 18px;text-align:center;margin-top:6px;}
.bottle-result-idle{font-size:14px;color:rgba(255,255,255,.3);}
.bottle-result-winner{font-family:'Bebas Neue',cursive;font-size:30px;color:#ffd93d;margin-top:2px;}
.bottle-result-challenge{font-size:13px;color:rgba(255,255,255,.65);margin-top:5px;font-style:italic;line-height:1.4;}
.dare-badge{display:inline-block;padding:3px 12px;border-radius:20px;font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:5px;}
.badge-truth{background:rgba(77,150,255,.28);color:#6db3ff;}
.badge-dare{background:rgba(255,107,107,.28);color:#ff8a8a;}
.choice-winner{font-family:'Bebas Neue',cursive;font-size:26px;color:#ffd93d;margin-bottom:4px;}
.choice-q{font-size:13px;color:rgba(255,255,255,.5);margin-bottom:10px;}
.choice-btns{display:flex;gap:10px;justify-content:center;}
.choice-btn{flex:1;max-width:130px;padding:12px 8px;border:none;border-radius:14px;
  font-family:'Nunito',sans-serif;font-weight:900;font-size:14px;cursor:pointer;touch-action:manipulation;-webkit-appearance:none;}
.choice-btn:active{opacity:.75;}
.choice-truth{background:linear-gradient(135deg,#4d96ff,#5c5fc4);color:#fff;box-shadow:0 6px 16px rgba(77,150,255,.4);}
.choice-dare{background:linear-gradient(135deg,#ff6b6b,#ff4757);color:#fff;box-shadow:0 6px 16px rgba(255,71,87,.4);}
.bottle-actions{display:flex;gap:10px;width:100%;margin-top:10px;}
#screen-tabu{gap:0;justify-content:space-between;padding-top:34px;padding-bottom:26px;}
#screen-tabu-setup{gap:12px;}
.tabu-header{width:100%;display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;}
.tabu-title-bar{font-family:'Bebas Neue',cursive;font-size:26px;letter-spacing:1px;}
.tabu-info{font-size:12px;color:rgba(255,255,255,.35);}
.tabu-card-area{flex:1;display:flex;align-items:center;justify-content:center;width:100%;}
.tabu-card{width:100%;max-width:340px;background:linear-gradient(145deg,#1e1040,#2d1a6e);
  border:1.5px solid rgba(168,85,247,.3);border-radius:24px;padding:24px 20px;box-shadow:0 20px 50px rgba(0,0,0,.5);
  display:flex;flex-direction:column;align-items:center;gap:14px;}
.tabu-target-label{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.4);}
.tabu-target-word{font-family:'Bebas Neue',cursive;font-size:44px;color:#fff;text-align:center;line-height:1;text-shadow:0 0 20px rgba(168,85,247,.6);}
.tabu-forbidden-label{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,107,107,.6);align-self:flex-start;margin-top:4px;}
.tabu-forbidden-list{width:100%;display:flex;flex-direction:column;gap:6px;}
.tabu-forbidden-item{background:rgba(255,107,107,.12);border:1px solid rgba(255,107,107,.25);border-radius:10px;padding:9px 14px;font-weight:700;font-size:15px;color:rgba(255,255,255,.8);display:flex;align-items:center;gap:8px;}
.tabu-forbidden-item::before{content:'🚫';font-size:12px;}
.tabu-timer-container{width:100%;margin-top:8px;}
.tabu-timer-text-row{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:6px;}
.tabu-timer-label{font-size:11px;font-weight:700;letter-spacing:1px;color:rgba(255,255,255,.5);}
.tabu-timer-value{font-family:'Bebas Neue',cursive;font-size:26px;color:#fff;line-height:1;transition:color 0.3s;}
.tabu-timer-wrap{width:100%;height:6px;background:rgba(255,255,255,.1);border-radius:99px;overflow:hidden;}
.tabu-timer-bar{height:100%;border-radius:99px;transition:width 0.3s linear;}
@keyframes flashRedBar{0%,100%{box-shadow:0 0 5px rgba(239,68,68,0);}50%{box-shadow:0 0 15px rgba(239,68,68,0.8);}}
@keyframes pulseText{from{transform:scale(1);}to{transform:scale(1.15);}}
.timer-danger{animation:flashRedBar 1s infinite;background:linear-gradient(90deg,#dc2626,#ef4444)!important;}
.timer-text-danger{color:#ef4444!important;transform-origin:right center;animation:pulseText 0.5s infinite alternate;}
.tabu-actions{display:flex;gap:6px;width:100%;margin-top:12px;}
.tabu-score-row{display:flex;gap:12px;width:100%;margin-bottom:4px;}
.tabu-team{flex:1;background:rgba(255,255,255,.08);border-radius:14px;padding:12px;text-align:center;}
.tabu-team.active-team{background:rgba(168,85,247,.2);border:1.5px solid rgba(168,85,247,.4);}
.tabu-team-name{font-size:11px;color:rgba(255,255,255,.45);font-weight:700;letter-spacing:1px;text-transform:uppercase;}
.tabu-team-score{font-family:'Bebas Neue',cursive;font-size:36px;color:#a855f7;margin-top:2px;}
.tabu-team.active-team .tabu-team-score{color:#ffd93d;}
#confetti-canvas{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:999;}
#screen-kimbu{gap:0;justify-content:flex-start;padding-top:30px;padding-bottom:24px;}
.kb-header{width:100%;display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;}
.kb-title{font-family:'Bebas Neue',cursive;font-size:26px;letter-spacing:1px;}
.kb-score{font-size:12px;color:rgba(255,255,255,.35);}
.kb-category-pick{display:flex;flex-direction:column;align-items:center;gap:18px;width:100%;flex:1;justify-content:center;}
.kb-cat-title{font-family:'Bebas Neue',cursive;font-size:32px;text-align:center;background:linear-gradient(135deg,#6bcb77,#4d96ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.kb-cat-cards{display:flex;gap:14px;width:100%;}
.kb-cat-card{flex:1;border:none;border-radius:20px;padding:22px 10px;display:flex;flex-direction:column;align-items:center;gap:10px;cursor:pointer;-webkit-appearance:none;touch-action:manipulation;}
.kb-cat-card:active{opacity:.8;}
.kb-cat-futbol{background:linear-gradient(145deg,#22c55e,#16a34a);box-shadow:0 10px 28px rgba(34,197,94,.4);}
.kb-cat-actor{background:linear-gradient(145deg,#f59e0b,#d97706);box-shadow:0 10px 28px rgba(245,158,11,.4);}
.kb-cat-icon{font-size:48px;}
.kb-cat-name{font-family:'Bebas Neue',cursive;font-size:22px;color:#fff;letter-spacing:.5px;}
.kb-game-wrap{flex:1;display:flex;flex-direction:column;width:100%;gap:14px;}
.kb-clues-box{background:rgba(255,255,255,.07);border:1.5px solid rgba(255,255,255,.1);border-radius:20px;padding:18px;display:flex;flex-direction:column;gap:8px;}
.kb-clue-label{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.35);margin-bottom:2px;}
.kb-clue-item{display:flex;align-items:center;gap:10px;padding:7px 10px;background:rgba(255,255,255,.06);border-radius:10px;font-size:14px;font-weight:700;color:rgba(255,255,255,.85);animation:slideIn .25s ease;}
.kb-clue-icon{font-size:16px;flex-shrink:0;}
.kb-hint-btn{background:rgba(255,255,255,.08);border:1.5px dashed rgba(255,255,255,.2);border-radius:10px;padding:8px 12px;font-size:13px;font-weight:700;color:rgba(255,255,255,.4);cursor:pointer;touch-action:manipulation;-webkit-appearance:none;width:100%;text-align:center;}
.kb-guess-area{display:flex;flex-direction:column;gap:10px;}
.kb-blanks{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;min-height:44px;align-items:center;}
.kb-blank-word{display:flex;gap:3px;}
.kb-letter{width:22px;height:30px;border-bottom:2.5px solid rgba(255,255,255,.4);display:flex;align-items:flex-end;justify-content:center;font-family:'Bebas Neue',cursive;font-size:20px;color:#ffd93d;padding-bottom:2px;transition:all .3s;}
.kb-letter.revealed{border-color:#ffd93d;}
.kb-letter.wrong-flash{border-color:#ff6b6b;animation:wrongFlash .4s ease;}
@keyframes wrongFlash{0%,100%{transform:translateX(0)}25%{transform:translateX(-4px)}75%{transform:translateX(4px)}}
.kb-input-row{display:flex;gap:10px;}
.kb-input{flex:1;background:rgba(255,255,255,.1);border:1.5px solid rgba(255,255,255,.15);border-radius:12px;padding:13px 15px;color:#fff;font-family:'Nunito',sans-serif;font-size:16px;outline:none;text-transform:uppercase;}
.kb-input:focus{border-color:rgba(255,217,61,.5);}
.kb-submit-btn{background:linear-gradient(135deg,#ffd93d,#f59e0b);border:none;border-radius:12px;width:54px;height:54px;font-size:22px;cursor:pointer;flex-shrink:0;touch-action:manipulation;-webkit-appearance:none;}
.kb-result-win{text-align:center;padding:16px;background:rgba(34,197,94,.15);border:1.5px solid rgba(34,197,94,.35);border-radius:18px;}
.kb-result-lose{text-align:center;padding:16px;background:rgba(255,107,107,.12);border:1.5px solid rgba(255,107,107,.3);border-radius:18px;}
.kb-result-title{font-family:'Bebas Neue',cursive;font-size:28px;}
.kb-result-name{font-size:14px;color:rgba(255,255,255,.6);margin-top:4px;}
.kb-score-pill{display:inline-flex;align-items:center;gap:6px;background:rgba(255,217,61,.2);border:1px solid rgba(255,217,61,.4);border-radius:20px;padding:4px 14px;font-size:13px;font-weight:700;color:#ffd93d;margin-top:8px;}
.kb-tries{font-size:12px;color:rgba(255,255,255,.3);text-align:center;}
#screen-quiz{gap:0;justify-content:flex-start;padding-top:28px;padding-bottom:22px;}
.quiz-series-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;width:100%;margin-top:4px;}
.quiz-series-btn{border:none;border-radius:18px;padding:16px 12px;display:flex;flex-direction:column;align-items:center;gap:7px;cursor:pointer;touch-action:manipulation;-webkit-appearance:none;transition:transform .15s,opacity .15s;position:relative;overflow:hidden;}
.quiz-series-btn:active{transform:scale(.96);opacity:.85;}
.quiz-series-emoji{font-size:34px;line-height:1;}
.quiz-series-name{font-family:'Bebas Neue',cursive;font-size:16px;color:#fff;letter-spacing:.5px;text-align:center;line-height:1.2;}
.quiz-series-count{font-size:10px;color:rgba(255,255,255,.5);font-weight:700;}
.quiz-header{width:100%;display:flex;flex-direction:column;gap:6px;margin-bottom:10px;}
.quiz-top-row{display:flex;justify-content:space-between;align-items:center;}
.quiz-series-label{font-family:'Bebas Neue',cursive;font-size:18px;letter-spacing:.5px;color:rgba(255,255,255,.7);}
.quiz-pts{font-size:12px;color:rgba(255,255,255,.35);}
.quiz-prog-wrap{height:4px;background:rgba(255,255,255,.1);border-radius:99px;overflow:hidden;}
.quiz-prog-bar{height:100%;border-radius:99px;transition:width .4s ease;}
.quiz-q-area{flex:1;display:flex;align-items:center;justify-content:center;width:100%;}
.quiz-card{width:100%;background:linear-gradient(145deg,#1a1530,#211940);border:1.5px solid rgba(255,255,255,.08);border-radius:24px;padding:20px 18px;box-shadow:0 16px 40px rgba(0,0,0,.45);display:flex;flex-direction:column;gap:14px;}
.quiz-q-num{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.3);}
.quiz-q-text{font-size:16px;font-weight:700;color:#fff;line-height:1.4;min-height:44px;}
.quiz-choices{display:flex;flex-direction:column;gap:8px;}
.quiz-choice{width:100%;border:1.5px solid rgba(255,255,255,.14);border-radius:14px;background:rgba(255,255,255,.07);padding:13px 16px;display:flex;align-items:center;gap:12px;font-family:'Nunito',sans-serif;font-weight:700;font-size:14px;color:#fff;cursor:pointer;touch-action:manipulation;-webkit-appearance:none;transition:all .2s;text-align:left;}
.quiz-choice:active{transform:scale(.98);}
.quiz-choice-letter{width:26px;height:26px;border-radius:8px;background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',cursive;font-size:16px;flex-shrink:0;transition:background .2s;}
.quiz-choice.correct{background:rgba(34,197,94,.18);border-color:rgba(34,197,94,.6);}
.quiz-choice.correct .quiz-choice-letter{background:#22c55e;color:#fff;}
.quiz-choice.wrong{background:rgba(255,107,107,.15);border-color:rgba(255,107,107,.4);}
.quiz-choice.wrong .quiz-choice-letter{background:#ff4757;color:#fff;}
.quiz-choice.disabled{opacity:.55;cursor:default;}
.quiz-explain{font-size:13px;color:rgba(255,255,255,.55);line-height:1.45;background:rgba(255,255,255,.05);border-radius:12px;padding:10px 14px;border-left:3px solid rgba(255,255,255,.15);display:none;}
.quiz-explain.show{display:block;animation:slideIn .25s ease;}
.quiz-footer{display:flex;gap:10px;width:100%;margin-top:8px;}
.quiz-result-wrap{display:flex;flex-direction:column;align-items:center;gap:14px;width:100%;flex:1;justify-content:center;text-align:center;}
.quiz-result-emoji{font-size:64px;animation:bounce 1.5s infinite;}
.quiz-result-title{font-family:'Bebas Neue',cursive;font-size:44px;background:linear-gradient(135deg,#ffd93d,#ff6b6b);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.quiz-result-score{font-size:18px;color:rgba(255,255,255,.7);}
.quiz-result-score b{color:#ffd93d;font-size:28px;}
.quiz-streak{font-size:13px;color:rgba(255,255,255,.4);}
#screen-score{gap:18px;}
.score-title{font-family:'Bebas Neue',cursive;font-size:46px;background:linear-gradient(135deg,#ffd93d,#ff6b6b);-webkit-background-clip:text;-webkit-text-fill-color:transparent;text-align:center;}
.score-list{width:100%;display:flex;flex-direction:column;gap:9px;}
.score-item{display:flex;align-items:center;gap:13px;background:rgba(255,255,255,.1);border-radius:15px;padding:13px 17px;animation:slideIn .3s ease both;}
.score-rank{font-family:'Bebas Neue',cursive;font-size:26px;width:34px;text-align:center;color:rgba(255,255,255,.28);}
.score-item.top1{background:linear-gradient(135deg,rgba(255,215,0,.18),rgba(255,107,107,.13));border:1px solid rgba(255,215,0,.28);}
.score-item.top1 .score-rank{color:#ffd93d;}
.score-player{flex:1;font-weight:700;font-size:15px;}
.score-votes{font-family:'Bebas Neue',cursive;font-size:20px;color:#ff6b6b;}
.score-votes span{font-family:'Nunito',sans-serif;font-size:11px;color:rgba(255,255,255,.35);}
.game-over-emoji{font-size:56px;animation:bounce 1.5s infinite;}
/* IMPOSTER */
#screen-imp-setup{gap:12px;}
#screen-imp-pass{gap:16px;text-align:center;}
#screen-imp-secret{gap:16px;text-align:center;}
#screen-imp-discuss{gap:16px;text-align:center;}
#screen-omb-setup{gap:12px;}
#screen-omb{gap:0;padding:0;justify-content:center;background:transparent;}
.omb-arena{width:100%;height:100vh;display:flex;flex-direction:column;position:relative;}
.omb-header{position:absolute;top:20px;left:0;width:100%;display:flex;flex-direction:column;align-items:center;z-index:10;pointer-events:none;gap:4px;}
.omb-round-text{background:rgba(0,0,0,.6);padding:6px 16px;border-radius:20px;font-family:'Bebas Neue',cursive;font-size:24px;color:#fff;letter-spacing:1px;border:1px solid rgba(255,255,255,.2);backdrop-filter:blur(5px);}
.omb-progress{font-size:12px;font-weight:700;color:rgba(255,255,255,.7);background:rgba(0,0,0,.5);padding:4px 12px;border-radius:12px;}
.omb-card{flex:1;display:flex;align-items:center;justify-content:center;padding:40px 20px;text-align:center;cursor:pointer;transition:transform .2s;position:relative;overflow:hidden;-webkit-appearance:none;border:none;background:transparent;}
.omb-card:active{transform:scale(0.95);}
.omb-text{font-family:'Nunito',sans-serif;font-size:24px;font-weight:900;color:#fff;line-height:1.4;padding:12px 24px;display:inline-block;border-radius:255px 15px 225px 15px/15px 225px 15px 255px;box-shadow:0 4px 15px rgba(0,0,0,.4);transition:background 0.3s ease;}
.omb-vs-circle{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:60px;height:60px;background:#0e0b1a;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',cursive;font-size:24px;color:#ffd93d;z-index:5;border:4px solid #fff;box-shadow:0 0 20px rgba(0,0,0,.5);}
.omb-quit{position:absolute;bottom:20px;left:50%;transform:translateX(-50%);z-index:10;background:rgba(0,0,0,.6);border:1px solid rgba(255,255,255,.2);color:#fff;padding:8px 16px;border-radius:14px;font-size:12px;font-weight:700;}
#screen-omb-result{gap:16px;}
.omb-winner-card{background:linear-gradient(135deg,#ffd93d,#f59e0b);border-radius:24px;padding:30px 20px;text-align:center;box-shadow:0 15px 40px rgba(245,158,11,.4);width:100%;margin-bottom:10px;}
.omb-winner-label{font-size:12px;font-weight:900;letter-spacing:2px;color:rgba(0,0,0,.5);margin-bottom:10px;}
.omb-winner-text{font-family:'Nunito',sans-serif;font-size:26px;font-weight:900;color:#0e0b1a;}

/* ══════════ WAVELENGTH STİLLERİ ══════════ */
#screen-wavelength{gap:0;justify-content:flex-start;padding-top:20px;padding-bottom:20px;}
.wl-header{width:100%;display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;}
.wl-title{font-family:'Bebas Neue',cursive;font-size:26px;letter-spacing:1px;}
.wl-teams{display:flex;gap:10px;width:100%;margin-bottom:10px;}
.wl-team{flex:1;background:rgba(255,255,255,.08);border-radius:14px;padding:10px;text-align:center;transition:all .3s;}
.wl-team.active-team{background:rgba(20,184,166,.25);border:1.5px solid rgba(20,184,166,.5);}
.wl-team-name{font-size:11px;color:rgba(255,255,255,.45);font-weight:700;letter-spacing:1px;text-transform:uppercase;}
.wl-team-score{font-family:'Bebas Neue',cursive;font-size:36px;color:#14b8a6;margin-top:2px;}
.wl-team.active-team .wl-team-score{color:#ffd93d;}

/* Kavram çifti */
.wl-concept-bar{width:100%;display:flex;align-items:center;justify-content:space-between;
  background:linear-gradient(135deg,rgba(20,184,166,.15),rgba(59,130,246,.15));
  border:1.5px solid rgba(20,184,166,.3);border-radius:16px;padding:14px 18px;margin-bottom:8px;}
.wl-concept-left{font-family:'Bebas Neue',cursive;font-size:22px;color:#ff6b6b;text-align:left;flex:1;}
.wl-concept-sep{font-size:18px;color:rgba(255,255,255,.3);margin:0 10px;}
.wl-concept-right{font-family:'Bebas Neue',cursive;font-size:22px;color:#4d96ff;text-align:right;flex:1;}

/* Kadran */
.wl-dial-wrap{width:100%;position:relative;margin:4px 0;}
.wl-dial-canvas{width:100%;border-radius:16px;display:block;cursor:pointer;touch-action:none;}

/* Aşama göstergesi */
.wl-phase{width:100%;text-align:center;padding:8px 14px;border-radius:12px;
  background:rgba(255,255,255,.08);font-size:13px;font-weight:700;color:rgba(255,255,255,.6);margin-bottom:6px;}
.wl-phase span{color:#ffd93d;}

/* Clue input */
.wl-clue-box{width:100%;background:rgba(20,184,166,.1);border:1.5px solid rgba(20,184,166,.3);
  border-radius:16px;padding:14px;display:flex;flex-direction:column;gap:10px;}
.wl-clue-label{font-size:11px;font-weight:700;letter-spacing:1.5px;color:rgba(20,184,166,.8);text-transform:uppercase;}
.wl-clue-input{background:rgba(255,255,255,.1);border:1.5px solid rgba(255,255,255,.15);
  border-radius:10px;padding:11px 14px;color:#fff;font-family:'Nunito',sans-serif;
  font-size:15px;outline:none;width:100%;}
.wl-clue-input:focus{border-color:rgba(20,184,166,.6);}
.wl-clue-show{font-family:'Bebas Neue',cursive;font-size:28px;color:#ffd93d;text-align:center;letter-spacing:1px;}

/* Sonuç banner */
.wl-result-banner{width:100%;border-radius:16px;padding:14px 18px;text-align:center;font-size:15px;font-weight:700;}
.wl-result-4{background:rgba(34,197,94,.2);border:1.5px solid rgba(34,197,94,.5);color:#6bcb77;}
.wl-result-3{background:rgba(251,191,36,.15);border:1.5px solid rgba(251,191,36,.4);color:#fbbf24;}
.wl-result-2{background:rgba(249,115,22,.15);border:1.5px solid rgba(249,115,22,.4);color:#fb923c;}
.wl-result-1{background:rgba(239,68,68,.15);border:1.5px solid rgba(239,68,68,.4);color:#f87171;}
.wl-actions{display:flex;gap:8px;width:100%;margin-top:6px;}
</style>
</head>
